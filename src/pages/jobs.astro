---
import Layout from '../layouts/Layout.astro';
import jobsData from '../mock/jobs.json';

const jobs = jobsData;
const activeJobs = jobs.filter((j: any) => j.status === 'active');
---

<Layout title="Jobs & Internships">
  
  <header class="bg-[#F5A623] pt-24 pb-16 text-center shadow-inner relative overflow-hidden">
    <div class="container mx-auto px-4 max-w-3xl relative z-10">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-[#003F8A] tracking-tighter">Opportunities Board</h1>
      <p class="text-lg text-[#003F8A]/80 font-medium">Discover jobs and internships shared by the District 3192 network.</p>
    </div>
  </header>

  <section class="py-16 bg-gray-50 min-h-[60vh]">
    <div class="container mx-auto px-4 lg:px-8 max-w-4xl">
      
      <div class="mb-8 flex flex-col sm:flex-row justify-between items-center gap-4">
        <div class="flex space-x-2 bg-white p-1 rounded-lg border border-gray-200">
          <button class="px-4 py-2 rounded-md bg-gray-100 text-gray-900 text-sm font-semibold shadow-sm">All Opportunities</button>
          <button class="px-4 py-2 rounded-md text-gray-500 hover:text-gray-900 text-sm font-medium transition-colors">Jobs</button>
          <button class="px-4 py-2 rounded-md text-gray-500 hover:text-gray-900 text-sm font-medium transition-colors">Internships</button>
        </div>
        <p class="text-sm text-gray-500 font-medium">{activeJobs.length} active listings</p>
      </div>

      <div class="space-y-4">
        {jobs.map(job => (
          <div class={`bg-white p-6 md:p-8 border rounded-2xl flex flex-col md:flex-row md:items-center justify-between gap-6 transition-all ${job.status === 'active' ? 'border-gray-200 card-shadow hover:border-[#F5A623]/50' : 'border-gray-100 opacity-60'}`}>
            
            <div class="flex-1">
              <div class="flex items-center mb-2">
                <span class={`text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-sm mr-3 
                  ${job.type === 'job' ? 'bg-blue-50 text-blue-600' : 'bg-green-50 text-green-600'}`}>
                  {job.type}
                </span>
                {job.status === 'closed' && (
                  <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-sm bg-gray-100 text-gray-500 line-through">Closed</span>
                )}
                
                <span class="text-xs font-semibold text-gray-400 ml-auto md:ml-3">Expires: {new Date(job.expires_at).toLocaleDateString('en-IN')}</span>
              </div>
              
              <h3 class="text-xl font-bold text-gray-900 mb-1">{job.title}</h3>
              <p class="text-sm font-semibold text-[#003F8A] mb-3">{job.company}</p>
              
              <p class="text-sm text-gray-600 line-clamp-2 md:line-clamp-none max-w-2xl leading-relaxed">{job.description}</p>
            </div>
            
            <div class="shrink-0 flex flex-col items-start md:items-end">
              <a href={job.status === 'active' ? job.apply_url : '#'} class={`px-8 py-3 font-semibold rounded-full w-full md:w-auto text-center transition-colors
                ${job.status === 'active' 
                  ? 'bg-gray-900 hover:bg-gray-800 text-white shadow-md' 
                  : 'bg-gray-100 text-gray-400 cursor-not-allowed'}`}>
                {job.status === 'active' ? 'Apply Now' : 'Applications Closed'}
              </a>
              <p class="text-[10px] text-gray-400 mt-3 font-medium">Shared by {job.posted_by}</p>
            </div>
            
          </div>
        ))}
      </div>

    </div>
  </section>

</Layout>
