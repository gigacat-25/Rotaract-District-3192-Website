---
import Layout from '../layouts/Layout.astro';
import jobsData from '../mock/jobs.json';

const jobs = jobsData;
const activeJobs = jobs.filter((j: any) => j.status === 'active');
---

<Layout title="Opportunities Horizon">
  <main class="pt-20">
    <header class="bg-primary text-white pt-32 pb-24 relative overflow-hidden px-6 lg:px-12 border-b border-white/5">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-20 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-surface/5 rounded-tr-[15rem] blur-2xl"></div>
      </div>
      <div class="container mx-auto max-w-screen-2xl relative z-10 text-center space-y-6">
        <span class="inline-block px-5 py-2 rounded-full bg-white/10 text-white text-[10px] font-black tracking-[0.3em] uppercase font-headline border border-white/10">
          The Marketplace
        </span>
        <h1 class="text-6xl md:text-8xl font-black mb-4 tracking-tighter font-headline uppercase leading-none">Career Signal</h1>
        <p class="text-xl text-white/70 max-w-2xl mx-auto font-body font-medium italic">Discover premium professional trajectories curated within the District 3192 intelligence network.</p>
      </div>
    </header>

    <section class="py-24 bg-surface px-6 lg:px-12 min-h-screen">
      <div class="max-w-screen-xl mx-auto space-y-12">
        
        <div class="flex flex-col md:flex-row justify-between items-center gap-10 bg-surface-container-low p-3 rounded-2xl border border-outline-variant/30 fluid-shadow">
          <div class="flex items-center gap-2 overflow-x-auto w-full md:w-auto scrollbar-hide">
            <button class="px-8 py-3 rounded-xl bg-primary text-on-primary font-black text-[10px] uppercase tracking-widest shadow-xl transition-all">All Signals</button>
            <button class="px-8 py-3 rounded-xl text-primary/40 hover:text-primary font-black text-[10px] uppercase tracking-widest transition-all">Direct Hire</button>
            <button class="px-8 py-3 rounded-xl text-primary/40 hover:text-primary font-black text-[10px] uppercase tracking-widest transition-all">Internships</button>
          </div>
          <p class="text-[10px] font-black text-primary uppercase tracking-[0.4em] px-6 py-3 bg-primary/5 rounded-xl border border-primary/5">
            {activeJobs.length} Active Nodes
          </p>
        </div>

        <div class="grid gap-8">
          {jobs.map(job => (
            <div class={`group bg-surface-container-low p-10 rounded-[2.5rem] flex flex-col xl:flex-row xl:items-center justify-between gap-12 transition-all border border-outline-variant/10 fluid-shadow hover:bg-surface-container-lowest ${job.status === 'closed' ? 'opacity-40 grayscale' : ''}`}>
              
              <div class="flex-1 space-y-6">
                <div class="flex flex-wrap items-center gap-4">
                  <span class={`text-[9px] font-black uppercase tracking-[0.3em] px-4 py-1.5 rounded-full border shadow-sm
                    ${job.type === 'job' ? 'bg-primary/5 text-primary border-primary/10' : 'bg-green-500/5 text-green-600 border-green-500/10'}`}>
                    Signal: {job.type}
                  </span>
                  {job.status === 'closed' && (
                    <span class="text-[9px] font-black uppercase tracking-[0.3em] px-4 py-1.5 rounded-full bg-surface-container-high text-primary/40 border border-primary/5">Sequence Terminated</span>
                  )}
                  <span class="text-[9px] font-black text-primary/30 uppercase tracking-widest flex items-center gap-2 ml-auto lg:ml-0">
                    <span class="material-symbols-outlined text-sm">schedule</span>
                    Expiry: {new Date(job.expires_at).toLocaleDateString('en-IN', {month:'short', day:'numeric', year:'numeric'})}
                  </span>
                </div>
                
                <div class="space-y-2">
                  <h3 class="text-4xl font-black text-primary font-headline tracking-tighter uppercase leading-none">{job.title}</h3>
                  <p class="text-[10px] font-black text-primary-container uppercase tracking-[0.5em]">{job.company}</p>
                </div>
                
                <p class="text-on-surface-variant text-base font-medium leading-relaxed opacity-70 italic font-body max-w-3xl">
                  "{job.description}"
                </p>
              </div>
              
              <div class="shrink-0 flex flex-col items-start xl:items-end gap-6">
                <a href={job.status === 'active' ? job.apply_url : '#'} class={`group/btn relative px-12 py-5 font-black uppercase tracking-[0.2em] text-[10px] rounded-2xl w-full xl:w-auto text-center transition-all overflow-hidden
                  ${job.status === 'active' 
                    ? 'bg-primary text-white shadow-2xl hover:translate-y-[-4px] active:translate-y-0' 
                    : 'bg-surface-container-high text-primary/20 cursor-not-allowed border border-primary/5'}`}>
                  <span class="relative z-10 flex items-center justify-center gap-3">
                    {job.status === 'active' ? (
                      <>Initialize Application <span class="material-symbols-outlined text-lg">bolt</span></>
                    ) : 'Sequence Offline'}
                  </span>
                  {job.status === 'active' && <div class="absolute inset-0 aqueous-gradient opacity-0 group-hover/btn:opacity-20 transition-opacity"></div>}
                </a>
                <div class="flex items-center gap-3 px-4">
                   <div class="w-1.5 h-1.5 rounded-full bg-primary/20 animate-pulse"></div>
                   <p class="text-[9px] font-black text-primary/30 uppercase tracking-widest">Transmitted by {job.posted_by}</p>
                </div>
              </div>
              
            </div>
          ))}
        </div>

      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>
