---
import Layout from '../layouts/Layout.astro';
import feedsData from '../mock/feeds.json';

const feeds = feedsData;
const types = [...new Set(feeds.map((f: any) => f.content_type))];
---

<Layout title="District News & Feed">
  <main class="pt-20">
    <header class="bg-primary text-white pt-32 pb-16 relative overflow-hidden px-6 lg:px-12">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-20 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-surface/5 rounded-tr-[15rem] blur-2xl"></div>
      </div>
      <div class="container mx-auto max-w-screen-2xl relative z-10 text-center space-y-6">
        <span class="inline-block px-5 py-2 rounded-full bg-white/10 text-white text-[10px] font-black tracking-[0.3em] uppercase font-headline border border-white/10">
          The Pulse
        </span>
        <h1 class="text-6xl md:text-8xl font-black mb-4 tracking-tighter font-headline uppercase leading-none">District Signal</h1>
        <p class="text-xl text-white/70 max-w-2xl mx-auto font-body font-medium italic">Live updates, announcements, and cultural artifacts from across District 3192.</p>
      </div>
    </header>

    <!-- CONTENT CONTROLS -->
    <section class="py-10 bg-surface px-6 lg:px-12 sticky top-20 z-30 border-b border-outline-variant/30 backdrop-blur-3xl bg-surface/80">
      <div class="max-w-screen-2xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
        <div class="flex items-center gap-3 overflow-x-auto w-full md:w-auto pb-4 md:pb-0 scrollbar-hide">
          <button class="px-8 py-3 rounded-full bg-primary text-white font-black text-[10px] uppercase tracking-widest fluid-shadow transition-all whitespace-nowrap">Source: All</button>
          {types.map(type => (
            <button class="px-8 py-3 rounded-full bg-surface-container-low text-primary/60 hover:text-primary font-black text-[10px] uppercase tracking-widest transition-all whitespace-nowrap border border-outline-variant/30">{type}</button>
          ))}
        </div>
        
        <div class="w-full md:w-auto">
          <div class="relative group">
            <input type="text" placeholder="Scan signals..." class="w-full md:w-80 pl-14 pr-8 py-4 bg-surface-container-low border border-outline-variant/30 rounded-2xl text-sm font-bold text-primary placeholder:text-primary/20 focus:outline-none focus:ring-4 focus:ring-primary/5 transition-all">
            <span class="material-symbols-outlined absolute left-5 top-1/2 -translate-y-1/2 text-primary/30 group-focus-within:text-primary transition-colors">search</span>
          </div>
        </div>
      </div>
    </section>

    <!-- FEED GRID -->
    <section class="py-24 bg-surface px-6 lg:px-12 min-h-screen">
      <div class="max-w-screen-2xl mx-auto">
        <div class="columns-1 md:columns-2 xl:columns-3 gap-10 space-y-10">
          {feeds.map(post => (
            <article class="break-inside-avoid bg-surface-container-low rounded-[2.5rem] overflow-hidden group border border-outline-variant/30 fluid-shadow hover:bg-surface-container-lowest transition-all">
              
              <!-- Media -->
              {post.media_url && (
                <div class="relative aspect-video overflow-hidden grayscale hover:grayscale-0 transition-all duration-700">
                  <img src={post.media_url} alt="" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" loading="lazy" />
                  <div class="absolute top-6 right-6">
                    <span class="bg-black/40 backdrop-blur-xl text-white text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-full border border-white/10">
                      {post.content_type}
                    </span>
                  </div>
                </div>
              )}
              
              <div class="p-10 space-y-8">
                <!-- Author Row -->
                <div class="flex items-center gap-5">
                  <div class="w-14 h-14 rounded-2xl overflow-hidden fluid-shadow border-2 border-primary/5">
                    <img src={post.author_pic} alt={post.author_name} class="w-full h-full object-cover" />
                  </div>
                  <div class="space-y-1">
                    <p class="text-lg font-black text-primary font-headline tracking-tight leading-none uppercase">{post.author_name}</p>
                    <p class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest opacity-40 leading-none">
                      {post.club_name} • {new Date(post.posted_at).toLocaleDateString('en-IN', {month:'short', day:'numeric'})}
                    </p>
                  </div>
                </div>
                
                <!-- Content -->
                <p class="text-on-surface-variant text-base font-medium leading-relaxed opacity-70 italic font-body">
                  "{post.caption}"
                </p>
                
                <!-- Interaction buttons -->
                <div class="flex items-center justify-between pt-8 border-t border-primary/5">
                  <button class="flex items-center gap-3 text-primary/40 hover:text-red-500 transition-all group/btn">
                    <span class="material-symbols-outlined text-2xl group-hover/btn:scale-125 transition-transform">favorite</span>
                    <span class="text-[10px] font-black uppercase tracking-widest">Protocol Like</span>
                  </button>
                  <button class="w-12 h-12 rounded-full bg-primary/5 text-primary flex items-center justify-center hover:bg-primary hover:text-white transition-all">
                    <span class="material-symbols-outlined text-xl">ios_share</span>
                  </button>
                </div>
              </div>
            </article>
          ))}
        </div>
        
        <!-- Pagination -->
        <div class="mt-32 text-center">
          <button class="bg-surface-container-high text-primary px-12 py-5 rounded-2xl font-black uppercase tracking-widest text-[10px] hover:bg-primary hover:text-on-primary transition-all fluid-shadow">
            Expand Signal Horizon
          </button>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 48px -12px rgba(13, 65, 116, 0.06);
  }
</style>
