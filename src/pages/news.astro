---
import Layout from '../layouts/Layout.astro';
import feedsData from '../mock/feeds.json';

const feeds = feedsData;
const types = [...new Set(feeds.map((f: any) => f.content_type))];
---

<Layout title="District News & Feed">
  <!-- HEADER -->
  <header class="bg-gray-50 border-b border-gray-200 pt-20 pb-12">
    <div class="container mx-auto px-4 lg:px-8 text-center max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 tracking-tight">District Newsboard</h1>
      <p class="text-lg text-gray-500">Live updates, announcements, and moments from Rotaract clubs across District 3192.</p>
    </div>
  </header>

  <!-- CONTENT CONTROLS -->
  <section class="py-6 border-b border-gray-100 bg-white sticky top-0 z-30 shadow-sm">
    <div class="container mx-auto px-4 lg:px-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <div class="flex space-x-2 overflow-x-auto w-full sm:w-auto pb-2 sm:pb-0 scrollbar-hide">
        <button class="px-4 py-1.5 rounded-full bg-gray-900 text-white font-medium text-sm whitespace-nowrap">All Posts</button>
        {types.map(type => (
          <button class="px-4 py-1.5 rounded-full bg-gray-100 text-gray-600 hover:bg-gray-200 font-medium text-sm capitalize whitespace-nowrap transition-colors">{type}</button>
        ))}
      </div>
      
      <div class="w-full sm:w-auto">
        <div class="relative">
          <input type="text" placeholder="Search feed..." class="w-full sm:w-64 pl-10 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-[#003F8A]/50 focus:border-[#003F8A]">
          <svg class="w-4 h-4 text-gray-400 absolute left-3.5 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
      </div>
    </div>
  </section>

  <!-- FEED GRID -->
  <section class="py-12 bg-gray-50 min-h-screen">
    <div class="container mx-auto px-4 lg:px-8">
      
      <!-- Masonry-style Grid (CSS Columns) -->
      <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
        {feeds.map(post => (
          <article class="break-inside-avoid bg-white rounded-xl overflow-hidden card-shadow border border-gray-100 group">
            
            <!-- Media (if present) -->
            {post.media_url && (
              <div class="relative aspect-video max-h-[600px] overflow-hidden bg-black">
                <img src={post.media_url} alt="" class="w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity duration-500" loading="lazy" />
                <div class="absolute top-3 right-3">
                  <span class="bg-black/50 backdrop-blur-md text-white text-xs font-bold uppercase tracking-wider px-2.5 py-1 rounded-md">
                    {post.content_type}
                  </span>
                </div>
              </div>
            )}
            
            <div class="p-5">
              <!-- Author Row -->
              <div class="flex items-center mb-4">
                <img src={post.author_pic} alt={post.author_name} class="w-10 h-10 rounded-full border border-gray-200" />
                <div class="ml-3">
                  <p class="text-sm font-bold text-gray-900 leading-none">{post.author_name}</p>
                  <p class="text-xs text-gray-500 mt-1">{post.club_name} &bull; {new Date(post.posted_at).toLocaleDateString('en-IN', {month:'short', day:'numeric'})}</p>
                </div>
              </div>
              
              <!-- Content -->
              <p class="text-gray-700 text-sm leading-relaxed mb-4">
                {post.caption}
              </p>
              
              <!-- Interaction buttons -->
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <button class="flex items-center text-gray-400 hover:text-red-500 transition-colors group/btn">
                  <svg class="w-5 h-5 mr-1 group-hover/btn:fill-red-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                  <span class="text-xs font-medium">Like</span>
                </button>
                <button class="text-gray-400 hover:text-[#003F8A] transition-colors">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg>
                </button>
              </div>
            </div>
            
          </article>
        ))}
      </div>
      
      <!-- Infinite Scroll Placeholder -->
      <div class="mt-16 text-center">
        <button class="bg-white border text-sm font-semibold border-gray-200 text-gray-600 px-6 py-2.5 rounded-full hover:bg-gray-50 shadow-sm transition-colors">
          Load More Posts
        </button>
      </div>

    </div>
  </section>
</Layout>
