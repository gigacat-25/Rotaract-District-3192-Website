---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Brand Centre | District 3192">
  <main class="pt-20">
    <header class="bg-primary text-white pt-32 pb-24 relative overflow-hidden px-6 lg:px-12">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-20 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-surface/5 rounded-tr-[15rem] blur-2xl"></div>
      </div>
      <div class="container mx-auto max-w-screen-2xl relative z-10 text-center space-y-6">
        <span class="inline-block px-5 py-2 rounded-full bg-white/10 text-white text-[10px] font-black tracking-[0.3em] uppercase font-headline border border-white/10">
          The Identity
        </span>
        <h1 class="text-6xl md:text-8xl font-black mb-4 tracking-tighter font-headline uppercase leading-none">Brand Centre</h1>
        <p class="text-xl text-white/70 max-w-2xl mx-auto font-body font-medium italic">Official guidelines and standard signals for Rotaract District 3192.</p>
      </div>
    </header>

    <!-- LOGOS SECTION -->
    <section class="py-24 bg-surface px-6 lg:px-12 border-t border-outline-variant/30">
      <div class="max-w-screen-2xl mx-auto space-y-16">
        <div class="space-y-4">
          <span class="text-primary font-black text-[10px] tracking-[.4em] uppercase opacity-40">Assets 01</span>
          <h2 class="text-4xl font-black text-primary tracking-tighter font-headline uppercase leading-none flex items-center gap-6">
            District Logos
            <span class="h-0.5 flex-grow bg-primary/5 rounded-full"></span>
          </h2>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
          <!-- Logo variant: Master -->
          <div class="bg-surface-container-low rounded-[2.5rem] p-10 border border-outline-variant/30 fluid-shadow group hover:bg-surface-container-lowest transition-all">
            <div class="aspect-video bg-white/50 backdrop-blur-xl rounded-[1.5rem] mb-10 flex items-center justify-center border border-primary/5 transition-transform group-hover:rotate-[-2deg]">
               <div class="text-center">
                <span class="block font-black text-3xl tracking-tighter text-primary font-headline uppercase leading-none">Rotaract</span>
                <span class="block text-[8px] uppercase tracking-[0.5em] text-primary/40 font-black mt-1">District 3192</span>
              </div>
            </div>
            <div class="space-y-6">
              <div class="space-y-2">
                <h3 class="text-2xl font-black text-primary font-headline tracking-tighter uppercase">Master Signal</h3>
                <p class="text-[10px] font-black text-primary/40 uppercase tracking-widest leading-relaxed">Primary visual identifier for light-mode environments and physical media.</p>
              </div>
              <div class="flex gap-4">
                <button class="flex-1 bg-primary text-on-primary text-[10px] font-black uppercase tracking-widest py-4 rounded-xl shadow-xl hover:translate-y-[-2px] transition-all">PNG</button>
                <button class="flex-1 bg-surface-container-high text-primary text-[10px] font-black uppercase tracking-widest py-4 rounded-xl border border-primary/5 hover:bg-primary hover:text-on-primary transition-all">SVG</button>
              </div>
            </div>
          </div>

          <!-- Logo variant: White -->
          <div class="bg-primary rounded-[2.5rem] p-10 fluid-shadow group hover:brightness-110 transition-all">
            <div class="aspect-video bg-white/10 backdrop-blur-xl rounded-[1.5rem] mb-10 flex items-center justify-center border border-white/5 transition-transform group-hover:rotate-[2deg]">
              <div class="text-center">
                <span class="block font-black text-3xl tracking-tighter text-white font-headline uppercase leading-none">Rotaract</span>
                <span class="block text-[8px] uppercase tracking-[0.5em] text-white/40 font-black mt-1">District 3192</span>
              </div>
            </div>
            <div class="space-y-6">
              <div class="space-y-2">
                <h3 class="text-2xl font-black text-white font-headline tracking-tighter uppercase">Negative Signal</h3>
                <p class="text-[10px] font-black text-white/40 uppercase tracking-widest leading-relaxed">Optimized for high-density dark backgrounds and night-mode interfaces.</p>
              </div>
              <div class="flex gap-4">
                <button class="flex-1 bg-white text-primary text-[10px] font-black uppercase tracking-widest py-4 rounded-xl shadow-xl hover:translate-y-[-2px] transition-all">PNG</button>
                <button class="flex-1 bg-white/10 text-white text-[10px] font-black uppercase tracking-widest py-4 rounded-xl border border-white/10 hover:bg-white hover:text-primary transition-all">SVG</button>
              </div>
            </div>
          </div>

          <!-- Logo variant: Gold -->
          <div class="bg-surface-container-low rounded-[2.5rem] p-10 border border-outline-variant/30 fluid-shadow group hover:bg-surface-container-lowest transition-all">
            <div class="aspect-video bg-[#F5A623]/5 backdrop-blur-xl rounded-[1.5rem] mb-10 flex items-center justify-center border border-[#F5A623]/10 transition-transform group-hover:rotate-[-4deg]">
              <div class="text-center">
                <span class="block font-black text-3xl tracking-tighter text-[#F5A623] font-headline uppercase leading-none">Rotaract</span>
                <span class="block text-[8px] uppercase tracking-[0.5em] text-[#F5A623]/40 font-black mt-1">District 3192</span>
              </div>
            </div>
            <div class="space-y-6">
              <div class="space-y-2">
                <h3 class="text-2xl font-black text-primary font-headline tracking-tighter uppercase">Monotone Gold</h3>
                <p class="text-[10px] font-black text-primary/40 uppercase tracking-widest leading-relaxed">Reserved for specific aesthetic applications and premium certifications.</p>
              </div>
              <div class="flex gap-4">
                <button class="flex-1 bg-primary text-on-primary text-[10px] font-black uppercase tracking-widest py-4 rounded-xl shadow-xl hover:translate-y-[-2px] transition-all">PNG</button>
                <button class="flex-1 bg-surface-container-high text-primary text-[10px] font-black uppercase tracking-widest py-4 rounded-xl border border-primary/5 hover:bg-primary hover:text-on-primary transition-all">SVG</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PALETTE & TYPE -->
    <section class="py-24 bg-surface px-6 lg:px-12">
      <div class="max-w-screen-2xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-24">
        
        <!-- Colour Palette -->
        <div class="lg:col-span-7 space-y-16">
          <div class="space-y-4">
            <span class="text-primary font-black text-[10px] tracking-[.4em] uppercase opacity-40">Core 02</span>
            <h2 class="text-4xl font-black text-primary tracking-tighter font-headline uppercase leading-none">Tonal Spectrum</h2>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div class="space-y-6">
              <div class="h-48 bg-primary rounded-[2.5rem] fluid-shadow relative overflow-hidden group">
                <div class="absolute inset-0 aqueous-gradient opacity-20 transition-opacity group-hover:opacity-40"></div>
                <div class="absolute bottom-10 left-10 text-white">
                   <p class="text-[10px] font-black uppercase tracking-[0.4em] opacity-60">Primary Token</p>
                   <p class="text-2xl font-black font-headline tracking-tighter italic">Protocol Blue</p>
                </div>
              </div>
              <div class="px-4 flex justify-between items-center text-[10px] font-black text-primary uppercase tracking-[0.2em] opacity-40">
                <span>CSS: --primary</span>
                <span>HEX: #0D4174</span>
              </div>
            </div>

            <div class="space-y-6">
              <div class="h-48 bg-surface-container-low rounded-[2.5rem] border border-outline-variant/30 fluid-shadow relative overflow-hidden group">
                <div class="absolute bottom-10 left-10 text-primary">
                   <p class="text-[10px] font-black uppercase tracking-[0.4em] opacity-60">Tonal Token</p>
                   <p class="text-2xl font-black font-headline tracking-tighter italic">Liquid Surface</p>
                </div>
              </div>
              <div class="px-4 flex justify-between items-center text-[10px] font-black text-primary uppercase tracking-[0.2em] opacity-40">
                <span>CSS: --surface-container-low</span>
                <span>HEX: #F0F4F8</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Typography -->
        <div class="lg:col-span-5 space-y-16">
          <div class="space-y-4">
            <span class="text-primary font-black text-[10px] tracking-[.4em] uppercase opacity-40">System 03</span>
            <h2 class="text-4xl font-black text-primary tracking-tighter font-headline uppercase leading-none">Signal Fonts</h2>
          </div>
          
          <div class="bg-surface-container-low rounded-[3rem] p-12 border border-outline-variant/30 space-y-12">
            <div class="space-y-4">
              <p class="text-[10px] font-black text-primary uppercase tracking-[0.4em] opacity-40">Headline System</p>
              <h3 class="text-4xl font-black text-primary font-headline tracking-tighter uppercase leading-none">Space Grotesk</h3>
              <p class="text-primary font-black text-base tracking-widest break-all">ABCDEFGHIJKLMNOPQRSTUVWXY&</p>
            </div>
            
            <div class="space-y-4 pt-12 border-t border-primary/5">
              <p class="text-[10px] font-black text-primary uppercase tracking-[0.4em] opacity-40">Body Framework</p>
              <h3 class="text-3xl font-black text-primary font-medium tracking-tight">Manrope</h3>
              <p class="text-on-surface-variant font-medium text-sm leading-relaxed italic opacity-70">
                A premium sans-serif optimized for deep readability and geometric clarity across the digital horizon.
              </p>
            </div>
          </div>
        </div>

      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 48px -12px rgba(13, 65, 116, 0.06);
  }
</style>
