---
import Layout from '../../layouts/Layout.astro';
import coursesData from '../../mock/courses.json';

const courses = coursesData;
---

<Layout title="Knowledge Academy">
  <main class="pt-20">
    <header class="bg-primary text-white pt-32 pb-24 relative overflow-hidden px-6 lg:px-12 border-b border-white/5">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-20 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-surface/5 rounded-tr-[15rem] blur-2xl"></div>
      </div>
      <div class="container mx-auto max-w-screen-2xl relative z-10 text-center space-y-6">
        <span class="inline-block px-5 py-2 rounded-full bg-white/10 text-white text-[10px] font-black tracking-[0.3em] uppercase font-headline border border-white/10">
          Intellectual Capital
        </span>
        <h1 class="text-6xl md:text-8xl font-black mb-4 tracking-tighter font-headline uppercase leading-none italic">Academy Core</h1>
        <p class="text-xl text-white/70 max-w-2xl mx-auto font-body font-medium italic">High-bandwidth knowledge synchronization for the District 3192 elite.</p>
      </div>
    </header>

    <section class="py-12 bg-surface px-6 lg:px-12 border-b border-outline-variant/30 sticky top-20 z-30 backdrop-blur-xl bg-surface/80">
      <div class="max-w-screen-2xl mx-auto">
        <div class="flex items-center gap-3 overflow-x-auto scrollbar-hide pb-2">
          <button class="px-8 py-3 rounded-xl bg-primary text-on-primary font-black text-[10px] uppercase tracking-widest shadow-xl transition-all">All Protocols</button>
          <button class="px-8 py-3 rounded-xl text-primary/40 hover:text-primary font-black text-[10px] uppercase tracking-widest transition-all">Marketing</button>
          <button class="px-8 py-3 rounded-xl text-primary/40 hover:text-primary font-black text-[10px] uppercase tracking-widest transition-all">Leadership</button>
          <button class="px-8 py-3 rounded-xl text-primary/40 hover:text-primary font-black text-[10px] uppercase tracking-widest transition-all">Finance</button>
        </div>
      </div>
    </section>

    <section class="py-24 bg-surface px-6 lg:px-12 min-h-screen">
      <div class="max-w-screen-2xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
          {courses.map(course => (
            <a href={`/lms/${course.id}`} class="group flex flex-col bg-surface-container-low rounded-[3rem] overflow-hidden border border-outline-variant/30 fluid-shadow hover:bg-surface-container-lowest hover:translate-y-[-8px] transition-all duration-500">
              <div class="relative aspect-video overflow-hidden">
                <img src={course.thumbnail_url} alt={course.title} class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-1000" />
                {course.is_ri_cert && (
                  <div class="absolute top-6 left-6 bg-white/20 backdrop-blur-md text-white text-[9px] font-black uppercase tracking-widest px-4 py-2 rounded-full border border-white/20 shadow-xl flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">verified</span>
                    RI Certified
                  </div>
                )}
                <div class="absolute inset-0 aqueous-gradient opacity-0 group-hover:opacity-10 transition-opacity"></div>
              </div>
              
              <div class="p-10 flex flex-col flex-grow space-y-6">
                <div class="space-y-3">
                  <div class="flex items-center gap-3">
                    <span class="w-2 h-2 rounded-full bg-primary/20"></span>
                    <p class="text-[9px] font-black uppercase tracking-[0.4em] text-primary/40">{course.category}</p>
                  </div>
                  <h3 class="text-3xl font-black text-primary font-headline tracking-tighter uppercase leading-tight italic">{course.title}</h3>
                </div>
                
                <p class="text-on-surface-variant text-base font-medium leading-relaxed opacity-60 italic line-clamp-2">"{course.description}"</p>
                
                <div class="mt-auto pt-8 border-t border-primary/5 flex items-center justify-between">
                  <div class="flex items-center gap-2">
                     <span class="material-symbols-outlined text-primary/30 text-lg">layers</span>
                     <span class="text-[10px] font-black text-primary/40 uppercase tracking-widest">{course.lessons.length} Modules</span>
                  </div>
                  <span class="text-[10px] font-black text-primary uppercase tracking-[0.3em] group-hover:underline underline-offset-8">Initialize →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>
