---
import Layout from '../../layouts/Layout.astro';
import coursesData from '../../mock/courses.json';

const courses = coursesData;
---

<Layout title="Learning Management System">
  
  <header class="bg-gray-900 border-b border-gray-800 py-16 text-center text-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 tracking-tight">Learning Academy</h1>
      <p class="text-lg text-gray-400 font-medium">Courses designed to build your leadership, professional, and technical skills.</p>
    </div>
  </header>

  <section class="py-6 bg-gray-800 border-b border-gray-700 sticky top-16 z-30 shadow-sm">
    <div class="container mx-auto px-4 lg:px-8 max-w-6xl">
      <div class="flex space-x-2 overflow-x-auto scrollbar-hide pb-2 sm:pb-0">
        <button class="px-5 py-2 rounded-full bg-white text-gray-900 font-semibold text-sm whitespace-nowrap shadow-sm">All Courses</button>
        <button class="px-5 py-2 rounded-full bg-gray-700 text-gray-300 hover:text-white hover:bg-gray-600 font-medium text-sm whitespace-nowrap transition-colors">Marketing</button>
        <button class="px-5 py-2 rounded-full bg-gray-700 text-gray-300 hover:text-white hover:bg-gray-600 font-medium text-sm whitespace-nowrap transition-colors">Leadership</button>
        <button class="px-5 py-2 rounded-full bg-gray-700 text-gray-300 hover:text-white hover:bg-gray-600 font-medium text-sm whitespace-nowrap transition-colors">Finance</button>
      </div>
    </div>
  </section>

  <section class="py-12 bg-white min-h-screen">
    <div class="container mx-auto px-4 lg:px-8 max-w-6xl">
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {courses.map(course => (
          <a href={`/lms/${course.id}`} class="group flex flex-col bg-white rounded-3xl overflow-hidden card-shadow border border-gray-100 transition-all hover:border-[#003F8A]/30 hover:shadow-xl">
            <div class="relative aspect-video overflow-hidden">
              <img src={course.thumbnail_url} alt={course.title} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" />
              {course.is_ri_cert && (
                <div class="absolute top-4 left-4 bg-yellow-400 text-yellow-900 text-[10px] font-black uppercase tracking-widest px-2.5 py-1 rounded shadow-md border border-yellow-300 flex items-center">
                  <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                  RI Certified
                </div>
              )}
            </div>
            
            <div class="p-6 flex flex-col flex-grow">
              <p class="text-[10px] font-bold uppercase tracking-widest text-[#003F8A] mb-2">{course.category}</p>
              <h3 class="text-xl font-bold text-gray-900 mb-3 leading-tight">{course.title}</h3>
              <p class="text-sm text-gray-500 mb-6 line-clamp-2">{course.description}</p>
              
              <div class="mt-auto border-t border-gray-100 pt-4 flex items-center justify-between">
                <span class="text-xs font-semibold text-gray-400">{course.lessons.length} Modules</span>
                <span class="text-xs font-bold text-[#003F8A] group-hover:underline">Start Course</span>
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</Layout>
