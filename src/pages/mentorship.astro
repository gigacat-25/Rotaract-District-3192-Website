---
import Layout from '../layouts/Layout.astro';
import membersData from '../mock/members.json';

const members = membersData;
// Filter a subset of members to act as mentors for mock data
const mentors = members.slice(0, 4).map((m: any) => ({
  ...m,
  expertise: m.role.includes('pres') ? ['Strategic Leadership', 'Impact Management'] : ['Growth Marketing', 'Signal Communication']
}));
---

<Layout title="Mentorship Synergy">
  <main class="pt-20">
    <header class="bg-primary text-white pt-32 pb-24 relative overflow-hidden px-6 lg:px-12 border-b border-white/5">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-20 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-surface/5 rounded-tr-[15rem] blur-2xl"></div>
      </div>
      <div class="container mx-auto max-w-screen-2xl relative z-10 text-center space-y-6">
        <span class="inline-block px-5 py-2 rounded-full bg-white/10 text-white text-[10px] font-black tracking-[0.3em] uppercase font-headline border border-white/10">
          Knowledge Protocol
        </span>
        <h1 class="text-6xl md:text-8xl font-black mb-4 tracking-tighter font-headline uppercase leading-none">Synergy Hub</h1>
        <p class="text-xl text-white/70 max-w-2xl mx-auto font-body font-medium italic">Connect with experienced district nodes for direct knowledge synchronization.</p>
      </div>
    </header>

    <section class="py-24 bg-surface px-6 lg:px-12 min-h-screen">
      <div class="max-w-screen-2xl mx-auto space-y-16">
        
        <div class="flex items-center gap-2 border-b border-primary/5 pb-1 relative">
          <button class="px-8 py-4 bg-primary/5 text-primary font-black text-[10px] uppercase tracking-widest rounded-t-2xl border-x border-t border-primary/10 relative z-10">Available Mentors</button>
          <button class="px-8 py-4 text-primary/40 hover:text-primary font-black text-[10px] uppercase tracking-widest transition-all">Active Sessions (0)</button>
          <div class="absolute bottom-0 left-0 w-36 h-0.5 bg-primary z-20"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          {mentors.map(mentor => (
             <div class="bg-surface-container-low rounded-[3rem] p-10 lg:p-12 border border-outline-variant/30 fluid-shadow flex flex-col lg:flex-row gap-10 group hover:bg-surface-container-lowest transition-all">
                <div class="shrink-0 text-center lg:text-left space-y-4">
                  <div class="relative inline-block">
                    <div class="absolute inset-0 bg-primary/20 rounded-[2.5rem] blur-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <img src={mentor.profile_pic_url} alt={mentor.name} class="w-32 h-32 rounded-[2.5rem] object-cover relative z-10 shadow-2xl border-4 border-white" />
                  </div>
                  <div class="flex flex-col gap-2">
                    <span class="inline-block text-[8px] font-black uppercase tracking-[.3em] bg-primary/5 text-primary px-3 py-1.5 rounded-full border border-primary/10">Signal: Verified</span>
                  </div>
                </div>
                <div class="flex-grow space-y-8">
                  <div class="space-y-2">
                    <h3 class="text-3xl font-black text-primary font-headline tracking-tighter uppercase italic leading-none">{mentor.name}</h3>
                    <p class="text-[10px] font-black text-primary-container uppercase tracking-[.4em] opacity-40">{mentor.club_id}</p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {mentor.expertise.map((skill: any) => (
                      <span class="text-[9px] font-black uppercase tracking-widest bg-white border border-outline-variant/30 text-primary px-4 py-2 rounded-xl shadow-sm italic">{skill}</span>
                    ))}
                  </div>
                  <button class="group/btn relative w-full bg-primary text-on-primary font-black py-5 rounded-2xl uppercase tracking-[0.2em] text-[10px] shadow-2xl hover:translate-y-[-4px] active:translate-y-0 transition-all overflow-hidden">
                    <span class="relative z-10 flex items-center justify-center gap-3">
                      Initialize Session <span class="material-symbols-outlined text-lg">bolt</span>
                    </span>
                    <div class="absolute inset-0 aqueous-gradient opacity-0 group-hover/btn:opacity-20 transition-opacity"></div>
                  </button>
                </div>
             </div>
          ))}
        </div>

      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>

