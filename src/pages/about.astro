---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About District 3192">
  <main class="pt-20">
    <!-- HERO -->
    <section class="relative min-h-[70vh] flex items-center overflow-hidden px-6 lg:px-12 bg-primary">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-20 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-surface/5 rounded-tr-[15rem] blur-2xl"></div>
        <div class="absolute inset-0 opacity-[0.05]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'100\' height=\'100\' viewBox=\'0 0 100 100\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cpath d=\'M0 50 Q 25 25, 50 50 T 100 50\' stroke=\'%23ffffff\' fill=\'none\'/%3E%3C/svg%3E'); background-repeat: repeat;"></div>
      </div>
      
      <div class="relative z-10 max-w-screen-2xl mx-auto w-full text-center">
        <span class="inline-block px-5 py-2 rounded-full bg-white/10 text-white text-[10px] font-black tracking-[0.3em] uppercase font-headline mb-8 border border-white/10">
          Our Identity
        </span>
        <h1 class="text-7xl md:text-9xl font-black text-white leading-[0.85] tracking-tighter mb-10 font-headline fade-in-up">
          Leaders. <br/>Innovators. <br/><span class="opacity-50">Changemakers.</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/70 max-w-2xl mx-auto leading-relaxed font-body font-medium italic">
          Rotaract District 3192 is a thriving network of passionate young adults committed to creating sustainable ripples of change.
        </p>
      </div>
    </section>

    <!-- MISSION & VISION (Tonal separation) -->
    <section class="py-40 px-6 lg:px-12 bg-surface">
      <div class="max-w-screen-2xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
          <div class="space-y-16">
            <div class="space-y-6">
              <span class="text-primary font-black text-[10px] tracking-[.4em] uppercase opacity-40">The Mission</span>
              <p class="text-4xl font-black text-primary leading-tight font-headline">To provide opportunities for young men and women to enhance their knowledge and skills.</p>
            </div>
            
            <div class="space-y-6">
              <span class="text-primary font-black text-[10px] tracking-[.4em] uppercase opacity-40">The Vision</span>
              <p class="text-2xl font-bold text-on-surface-variant leading-relaxed opacity-80">Together, we see a world where young people unite and take action to create lasting change — across the globe, in our communities, and in ourselves.</p>
            </div>
          </div>

          <div class="relative">
            <div class="relative rounded-[4rem] overflow-hidden aspect-video fluid-shadow border-[12px] border-white bg-surface-container-low">
              <img src="https://images.unsplash.com/photo-1559027615-cd4451d13488?auto=format&fit=crop&q=80&w=1200" alt="Service" class="w-full h-full object-cover" />
            </div>
            <div class="absolute -bottom-10 -right-10 w-64 h-64 bg-primary/5 rounded-[3rem] -z-10 blur-2xl"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- LEADERSHIP (Layered surfaces) -->
    <section class="py-40 px-6 lg:px-12 bg-surface-container-low">
      <div class="max-w-screen-2xl mx-auto">
        <div class="text-center mb-24 max-w-2xl mx-auto space-y-6">
          <h2 class="text-6xl font-black text-primary tracking-tighter font-headline">District Leadership</h2>
          <p class="text-on-surface-variant font-medium text-lg opacity-70">Meet the dedicated team steering District 3192 with authority and grace.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
          {[
            { name: "Dr. Priya Ramesh", role: "District Rotaract Representative", color: "bg-primary" },
            { name: "Rahul Krishnan", role: "District Secretary", color: "bg-green-600" },
            { name: "Sneha Venkatesh", role: "District Treasurer", color: "bg-red-600" },
            { name: "Karthik Reddy", role: "Professional Service Chair", color: "bg-slate-700" }
          ].map((leader) => (
            <div class="space-y-8 group">
              <div class="relative overflow-hidden rounded-[2.5rem] aspect-[3/4] bg-surface-container-lowest fluid-shadow group-hover:translate-y-[-8px] transition-all duration-500">
                <img src={`https://ui-avatars.com/api/?name=${leader.name.split(' ').join('+')}&background=174174&color=fff&size=512`} class="w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity" />
                <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-end p-8">
                  <span class="material-symbols-outlined text-white text-3xl">contact_page</span>
                </div>
              </div>
              <div class="space-y-1">
                <h3 class="text-2xl font-black text-primary font-headline tracking-tight">{leader.name}</h3>
                <p class="text-[10px] font-black uppercase tracking-[0.2em] text-on-surface-variant opacity-50">{leader.role}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- LEGACY (Editorial layout) -->
    <section class="py-40 px-6 lg:px-12 bg-surface">
      <div class="max-w-4xl mx-auto space-y-16">
        <div class="space-y-6 text-center">
          <h2 class="text-6xl font-black text-primary tracking-tighter font-headline leading-none">Our History</h2>
          <div class="w-20 h-1 bg-primary/10 mx-auto rounded-full"></div>
        </div>
        
        <div class="space-y-10 font-body text-xl text-on-surface-variant font-medium leading-relaxed opacity-80 first-letter:text-7xl first-letter:font-black first-letter:text-primary first-letter:float-left first-letter:mr-4 first-letter:mt-2">
          <p>
            Rotaract originally began as a Rotary International youth program in 1968 at Charlotte North Rotary Club in Charlotte, North Carolina, USA. Today, Rotaract operates globally with over 10,000 clubs in 180 countries.
          </p>
          <p>
            District 3192 has a rich legacy of vibrant youth action in South India. Formed to concentrate impact within key urban and rural demographics, 3192 acts as a catalyst for professional development and massive community service projects.
          </p>
        </div>

        <div class="bg-surface-container-low p-16 rounded-[3rem] space-y-10 border border-outline-variant/30 flex flex-col items-center text-center">
          <img src="https://images.unsplash.com/photo-1594122230689-45899d9e6f69?auto=format&fit=crop&q=80&w=300" class="w-32 h-32 rounded-full fluid-shadow" />
          <div class="space-y-4">
            <h3 class="text-3xl font-black text-primary font-headline tracking-tight">Proud Partner of Rotary</h3>
            <p class="text-on-surface-variant font-medium max-w-lg opacity-70">
              Rotaract clubs bring together people ages 18 and older to exchange ideas with leaders in the community and develop leadership skills.
            </p>
          </div>
          <a href="https://www.rotary.org" class="text-primary font-black text-xs uppercase tracking-[0.2em] border-b-2 border-primary/20 pb-2 hover:border-primary transition-all">
            Explore Rotary International
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 48px -12px rgba(23, 65, 116, 0.08);
  }
</style>

