---
import Layout from '../layouts/Layout.astro';
import membersData from '../mock/members.json';

// Use a mock member for phase 1
const user = membersData[0];
---

<Layout title="Member Command Center">
  <main class="pt-20 bg-surface min-h-screen">
    <!-- DASHBOARD HEADER -->
    <header class="bg-primary text-white pt-24 pb-48 relative overflow-hidden px-6 lg:px-12 border-b border-white/5">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-20 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-surface/5 rounded-tr-[15rem] blur-2xl"></div>
      </div>
      
      <div class="max-w-screen-2xl mx-auto flex flex-col md:flex-row items-center justify-between gap-12 relative z-10 text-center md:text-left">
        <div class="flex flex-col md:flex-row items-center gap-10">
          <div class="relative group">
            <div class="absolute inset-[-10%] bg-white/10 rounded-[2.5rem] blur-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <img src={user.profile_pic_url} alt={user.name} class="w-24 h-24 md:w-32 md:h-32 rounded-[2.5rem] border-4 border-white/20 shadow-2xl relative z-10" />
            <div class="absolute -bottom-2 -right-2 w-10 h-10 bg-green-500 rounded-2xl border-4 border-primary flex items-center justify-center shadow-xl relative z-20">
               <span class="material-symbols-outlined text-white text-base">verified_user</span>
            </div>
          </div>
          <div class="space-y-3">
             <span class="inline-block px-4 py-1 rounded-full bg-white/10 text-white text-[9px] font-black tracking-[.2em] uppercase font-headline border border-white/10">Active Session</span>
             <h1 class="text-4xl md:text-6xl font-black tracking-tighter font-headline uppercase leading-none italic">Greetings, {user.name.split(' ')[0]}</h1>
             <p class="text-sm md:text-lg text-white/50 font-black uppercase tracking-[0.3em] font-headline">{user.role.replace('_', ' ')} • <span class="italic underline decoration-white/20">RC Chennai</span></p>
          </div>
        </div>
        
        <div class="shrink-0 space-y-2 group">
          <p class="text-[10px] font-black uppercase tracking-[0.4em] text-white/30 group-hover:text-white/60 transition-colors">Protocol Status</p>
          <div class="bg-white/5 backdrop-blur-xl p-6 rounded-[2rem] border border-white/10 flex items-center gap-8 fluid-shadow">
            <div class="text-center">
              <p class="text-4xl font-black font-headline tracking-tighter leading-none italic">{user.points}</p>
              <p class="text-[8px] font-black uppercase tracking-widest opacity-40 mt-1">Pulse Score</p>
            </div>
            <div class="w-px h-12 bg-white/10"></div>
            <div class="text-center">
               <p class="text-4xl font-black font-headline tracking-tighter leading-none italic">#04</p>
               <p class="text-[8px] font-black uppercase tracking-widest opacity-40 mt-1">Global Rank</p>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- CONTENT GRID -->
    <div class="max-w-screen-2xl mx-auto px-6 lg:px-12 -mt-32 relative z-20 pb-32 space-y-12">
      
      <!-- Stats Architecture -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { label: 'Network Points', val: user.points, icon: 'analytics' },
          { label: 'Event Attendance', val: '14/20', icon: 'stadium' },
          { label: 'LMS Certifications', val: '02', icon: 'workspace_premium' },
          { label: 'Active Tasks', val: '05', icon: 'token' }
        ].map(stat => (
          <div class="bg-surface-container-low p-8 rounded-[2.5rem] border border-outline-variant/30 fluid-shadow flex flex-col justify-between h-48 group hover:bg-surface-container-lowest transition-all">
            <div class="w-12 h-12 rounded-2xl bg-primary/5 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-2xl">{stat.icon}</span>
            </div>
            <div>
              <p class="text-4xl font-black text-primary font-headline tracking-tighter leading-none uppercase italic">{stat.val}</p>
              <p class="text-[9px] font-black text-on-surface-variant uppercase tracking-[0.3em] opacity-40 mt-2">{stat.label}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-12 gap-12">
        
        <!-- Action Terminal -->
        <div class="xl:col-span-4 space-y-8">
          <div class="space-y-4">
            <span class="text-primary font-black text-[10px] tracking-[.4em] uppercase opacity-40 leading-none">System Ops</span>
            <h2 class="text-3xl font-black text-primary font-headline tracking-tighter uppercase flex items-center gap-6">Action Terminal <span class="h-0.5 flex-grow bg-primary/5 rounded-full"></span></h2>
          </div>
          
          <div class="bg-surface-container-low rounded-[3rem] p-10 border border-outline-variant/30 fluid-shadow space-y-4">
            {[
              { label: 'Learning Center', path: '/lms', icon: 'school', color: 'bg-blue-500/5 text-blue-600', desc: 'Sync knowledge protocols' },
              { label: 'MOM Recorder', path: '/mom', icon: 'graphic_eq', color: 'bg-green-500/5 text-green-600', desc: 'Transcribe meeting reality' },
              { label: 'Mentorship Hub', path: '/mentorship', icon: 'diversity_3', color: 'bg-purple-500/5 text-purple-600', desc: 'Connect with core nodes' },
              { label: 'Profile Settings', path: '/profile', icon: 'settings_inner', color: 'bg-orange-500/5 text-orange-600', desc: 'Modify identity parameters' }
            ].map(link => (
              <a href={link.path} class="flex items-center gap-6 p-6 rounded-[2rem] hover:bg-surface-container-lowest transition-all group border border-transparent hover:border-outline-variant/30">
                <div class={`w-16 h-16 rounded-[1.5rem] ${link.color} flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform`}>
                  <span class="material-symbols-outlined text-3xl">{link.icon}</span>
                </div>
                <div class="space-y-1">
                  <h4 class="text-lg font-black text-primary font-headline uppercase tracking-tight">{link.label}</h4>
                  <p class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest opacity-40 italic">{link.desc} →</p>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Registered Signals -->
        <div class="xl:col-span-8 space-y-8">
          <div class="flex items-center justify-between px-4">
             <div class="space-y-2">
                <span class="text-primary font-black text-[10px] tracking-[.4em] uppercase opacity-40 leading-none">Imminent Realities</span>
                <h2 class="text-3xl font-black text-primary font-headline tracking-tighter uppercase italic self-start">Active Registrations</h2>
             </div>
             <a href="/events" class="text-[10px] font-black text-primary uppercase tracking-[0.3em] px-8 py-4 bg-primary/5 rounded-2xl hover:bg-primary hover:text-white transition-all">Scan All Horizon →</a>
          </div>

          <!-- Active Event Component -->
          <div class="bg-surface-container-low rounded-[3.5rem] p-12 border border-outline-variant/30 fluid-shadow flex flex-col lg:flex-row gap-12 items-center group overflow-hidden relative">
            <div class="absolute inset-0 aqueous-gradient opacity-0 group-hover:opacity-5 transition-opacity pointer-events-none"></div>
            
            <div class="w-full lg:w-2/5 aspect-video overflow-hidden rounded-[2.5rem] relative shrink-0 fluid-shadow grayscale group-hover:grayscale-0 transition-all duration-700">
               <img src="https://placehold.co/1200x600/0D4174/FFFFFF?text=Coastal+Cleanup" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000" />
               <div class="absolute top-6 left-6 bg-white/40 backdrop-blur-xl text-primary text-[10px] font-black px-4 py-2 rounded-full border border-white/20 uppercase tracking-widest">Reality: Confirmed</div>
            </div>

            <div class="w-full lg:w-3/5 space-y-8">
               <div class="space-y-4">
                  <div class="flex items-center gap-3">
                     <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                     <span class="text-[10px] font-black uppercase tracking-[0.4em] text-primary/40">Sequence: Coastal Cleanup Drive</span>
                  </div>
                  <h3 class="text-5xl font-black text-primary font-headline tracking-tighter uppercase leading-none italic">Impact Logistics</h3>
                  <p class="text-on-surface-variant text-base font-medium leading-relaxed opacity-70 italic font-body max-w-lg">
                    Collective cleanup efforts at Marina Signal Terminal. Ensure protective gear is synchronized.
                  </p>
               </div>
               
               <div class="flex flex-col sm:flex-row items-center gap-6 justify-between pt-8 border-t border-primary/5">
                  <div class="space-y-1 text-center sm:text-left">
                     <p class="text-[10px] font-black text-primary uppercase tracking-[0.3em]">Temporal Frame</p>
                     <p class="text-sm font-black text-primary/40 uppercase tracking-widest">June 15, 2026 • 06:00 AM</p>
                  </div>
                  <button class="bg-primary text-on-primary font-black px-12 py-5 rounded-2xl uppercase tracking-widest text-[10px] shadow-2xl hover:translate-y-[-4px] active:translate-y-0 transition-all flex items-center gap-3">
                    <span class="material-symbols-outlined text-lg">qr_code_2</span>
                    Retrieve Access Ticket
                  </button>
               </div>
            </div>
          </div>

          <!-- Network Signals -->
          <div class="pt-8 space-y-8">
            <h2 class="text-3xl font-black text-primary font-headline tracking-tighter uppercase flex items-center gap-6 italic">Network Intel <span class="h-0.5 flex-grow bg-primary/5 rounded-full"></span></h2>
            
            <div class="bg-surface-container-low rounded-[2.5rem] p-10 border border-outline-variant/30 fluid-shadow flex gap-8 items-start hover:bg-surface-container-lowest transition-all">
              <div class="w-16 h-16 rounded-[1.5rem] bg-primary/5 flex items-center justify-center shrink-0">
                 <img src="https://ui-avatars.com/api/?name=CP&background=0D4174&color=fff" class="w-full h-full object-cover rounded-[1.5rem]" />
              </div>
              <div class="space-y-4">
                <div class="space-y-1">
                   <p class="text-[10px] font-black text-primary uppercase tracking-[.4em] opacity-40 italic">Signal from Terminal Controller</p>
                   <p class="text-xl font-black text-primary font-headline tracking-tighter uppercase leading-none italic truncate">Intel: General body meeting protocol complete</p>
                </div>
                <p class="text-on-surface-variant font-medium text-sm leading-relaxed italic opacity-70 border-l-4 border-primary/10 pl-6 py-1">
                   "All protocols established during the Chennai sequence are now archived. Review action tokens in the command center terminal immediately."
                </p>
              </div>
            </div>
          </div>
          
        </div>

      </div>
    </div>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>
