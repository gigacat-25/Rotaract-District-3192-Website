---
import Layout from '../layouts/Layout.astro';
import eventsData from '../mock/events.json';
import feedsData from '../mock/feeds.json';
import clubsData from '../mock/clubs.json';

const upcomingEvents = eventsData.filter((e: any) => e.status === 'published' && e.start_at > new Date().toISOString()).slice(0, 3);
const recentFeeds = feedsData.slice(0, 3);
const stats = {
  clubsCount: clubsData.filter((c: any) => c.status === 'active').length,
  membersCount: 4500, // mock aggregated district logic
  eventsYear: 184
};
---

<Layout title="The Fluid Authority">
  <main class="pt-20">
    <!-- HERO SECTION -->
    <section class="relative min-h-[90vh] flex items-center overflow-hidden px-6 lg:px-12">
      <!-- Background Fluidity -->
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-5 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-primary/5 opacity-20 rounded-tr-[15rem] blur-2xl"></div>
        <div class="absolute inset-0 opacity-[0.02]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'100\' height=\'100\' viewBox=\'0 0 100 100\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cpath d=\'M0 50 Q 25 25, 50 50 T 100 50\' stroke=\'%23174174\' fill=\'none\'/%3E%3C/svg%3E'); background-repeat: repeat;"></div>
      </div>

      <div class="relative z-10 max-w-screen-2xl mx-auto w-full grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-10 fade-in-up">
          <span class="inline-block px-5 py-2 rounded-full bg-primary/10 text-primary text-[10px] font-black tracking-[0.3em] uppercase font-headline">
            The Fluid Authority
          </span>
          <h1 class="text-7xl md:text-8xl xl:text-[9rem] font-black text-primary leading-[0.85] tracking-tighter font-headline">
            Rotaract <br/>District <span class="text-primary-container">3192</span>
          </h1>
          <p class="text-xl text-on-surface-variant max-w-md leading-relaxed font-body font-medium opacity-80">
            Harnessing the power of youth leadership and service to create ripples of positive change across our global community.
          </p>
          <div class="flex flex-wrap gap-6 pt-4">
            <a href="/clubs" class="aqueous-gradient text-on-primary px-10 py-5 rounded-2xl font-black flex items-center gap-3 hover:translate-y-[-2px] transition-all shadow-2xl shadow-primary/30 uppercase tracking-widest text-xs">
              Explore Clubs
              <span class="material-symbols-outlined">arrow_forward</span>
            </a>
            <a href="/events" class="bg-surface-container-highest text-primary px-10 py-5 rounded-2xl font-black hover:bg-surface-container-high transition-all uppercase tracking-widest text-xs">
              Upcoming Events
            </a>
          </div>
        </div>
        <div class="relative hidden lg:block fade-in-up" style="animation-delay: 0.2s">
          <div class="relative rounded-[4rem] overflow-hidden aspect-[4/5] fluid-shadow rotate-3 scale-95 border-[12px] border-white bg-surface-container-low">
            <img class="w-full h-full object-cover grayscale-[20%] hover:grayscale-0 transition-all duration-1000" alt="District Collaboration" src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?auto=format&fit=crop&q=80&w=1000"/>
          </div>
          <div class="absolute -bottom-12 -left-12 w-72 h-72 aqueous-gradient rounded-[3rem] -z-10 opacity-10 blur-2xl animate-pulse"></div>
        </div>
      </div>
    </section>

    <!-- Stats Bar (Floating Card) -->
    <section class="relative z-20 px-6 lg:px-12 -mt-24 md:-mt-32">
      <div class="max-w-screen-xl mx-auto">
        <div class="bg-surface-container-lowest/90 backdrop-blur-2xl rounded-[3rem] p-10 md:p-16 fluid-shadow flex flex-col md:flex-row justify-around gap-12 text-center items-center">
          <div class="space-y-2">
            <p class="text-5xl font-black text-primary font-headline tracking-tighter">{stats.clubsCount}+</p>
            <p class="text-[10px] uppercase tracking-[0.2em] text-on-surface-variant font-black opacity-60">Active Clubs</p>
          </div>
          <div class="hidden md:block w-px h-20 bg-primary/5"></div>
          <div class="space-y-2">
            <p class="text-5xl font-black text-primary font-headline tracking-tighter">{stats.membersCount.toLocaleString()}+</p>
            <p class="text-[10px] uppercase tracking-[0.2em] text-on-surface-variant font-black opacity-60">Youth Leaders</p>
          </div>
          <div class="hidden md:block w-px h-20 bg-primary/5"></div>
          <div class="space-y-2">
            <p class="text-5xl font-black text-primary font-headline tracking-tighter">{stats.eventsYear}+</p>
            <p class="text-[10px] uppercase tracking-[0.2em] text-on-surface-variant font-black opacity-60">Impact Projects</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Upcoming Events Strip -->
    <section class="py-40 px-6 lg:px-12 bg-surface-container-low">
      <div class="max-w-screen-2xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-8 mb-20 px-4">
          <div class="space-y-4">
            <span class="text-primary font-black text-xs tracking-[.4em] uppercase opacity-60">The Calendar</span>
            <h2 class="text-6xl md:text-7xl font-black text-primary tracking-tighter font-headline">Waves of Action</h2>
          </div>
          <a class="text-primary font-black flex items-center gap-3 group text-xs uppercase tracking-widest bg-surface-container-lowest px-8 py-4 rounded-2xl shadow-sm hover:shadow-md transition-all" href="/events">
            View All Calendar 
            <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span>
          </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
          {upcomingEvents.map((event: any, idx: number) => (
            <div class={`bg-surface-container-lowest rounded-[2.5rem] overflow-hidden hover:translate-y-[-8px] transition-all duration-500 group fade-in-up`} style={`animation-delay: ${0.1 * idx}s`}>
              <div class="h-72 overflow-hidden relative">
                <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" src={event.banner_url} alt={event.title} />
                <div class="absolute top-6 left-6 bg-surface-container-lowest/90 backdrop-blur-md px-5 py-3 rounded-2xl text-center shadow-xl">
                  <span class="block text-2xl font-black text-primary font-headline leading-none">{new Date(event.start_at).getDate()}</span>
                  <span class="block text-[10px] uppercase font-black text-on-surface-variant tracking-widest mt-1 opacity-60">{new Date(event.start_at).toLocaleString('default', { month: 'short' })}</span>
                </div>
                <div class="absolute bottom-6 right-6">
                  <span class="px-4 py-2 bg-primary text-on-primary text-[10px] font-black uppercase tracking-widest rounded-xl shadow-lg">
                    {event.is_free ? 'Complimentary' : 'Reserved Ticket'}
                  </span>
                </div>
              </div>
              <div class="p-10 space-y-6">
                <div class="space-y-2">
                  <p class="text-[10px] font-black uppercase tracking-[0.2em] text-primary opacity-50">{event.club_name}</p>
                  <h3 class="text-3xl font-black text-primary leading-tight font-headline group-hover:text-primary-container transition-colors line-clamp-2">{event.title}</h3>
                </div>
                <div class="pt-4 flex items-center gap-3 text-on-surface-variant text-sm font-bold opacity-70">
                  <span class="material-symbols-outlined text-lg">location_on</span>
                  <span>{event.venue}</span>
                </div>
                <div class="pt-6">
                  <a href={`/events/${event.slug}`} class="flex items-center text-primary font-black text-[10px] uppercase tracking-widest gap-2 group/btn">
                    Details
                    <span class="w-8 h-[2px] bg-primary group-hover/btn:w-12 transition-all"></span>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- District Stories/Feed (Bento/Asymmetrical) -->
    <section class="py-40 px-6 lg:px-12 bg-surface">
      <div class="max-w-screen-2xl mx-auto">
        <div class="text-center mb-28 max-w-2xl mx-auto space-y-6">
          <h2 class="text-6xl md:text-7xl font-black text-primary tracking-tighter font-headline">Stories of Impact</h2>
          <p class="text-on-surface-variant font-medium text-lg leading-relaxed opacity-70">The human element of our mission. Real people, real service, real change.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 auto-rows-[350px]">
          {recentFeeds.length > 0 && (
            <a href="/news" class="md:col-span-8 md:row-span-2 relative group overflow-hidden rounded-[3.5rem] bg-slate-200 block">
              <img class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" src={recentFeeds[0].media_url} alt="Impact" />
              <div class="absolute inset-0 bg-gradient-to-t from-primary/95 via-primary/40 to-transparent"></div>
              <div class="absolute bottom-16 left-16 right-16 text-white space-y-6">
                <span class="bg-white/20 backdrop-blur-md px-6 py-2 rounded-full text-[10px] uppercase tracking-[0.2em] font-black mb-4 inline-block border border-white/10">District Update</span>
                <h3 class="text-5xl font-black leading-tight font-headline tracking-tighter">{recentFeeds[0].caption}</h3>
                <div class="flex items-center gap-4 pt-4">
                  <img src={recentFeeds[0].author_pic} class="w-12 h-12 rounded-full border-2 border-white/30" />
                  <div>
                    <p class="font-black text-xs uppercase tracking-widest">{recentFeeds[0].club_name}</p>
                    <p class="text-white/60 text-[10px] font-bold uppercase tracking-widest mt-1">{new Date(recentFeeds[0].posted_at).toLocaleDateString()}</p>
                  </div>
                </div>
              </div>
            </a>
          )}
          
          {recentFeeds.slice(1, 3).map((post: any, idx: number) => (
            <a href="/news" class={`md:col-span-4 md:row-span-1 relative group overflow-hidden rounded-[3rem] block ${idx === 1 ? 'bg-surface-container-high' : 'bg-primary'}`}>
              {post.content_type === 'photo' ? (
                <>
                  <img class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 opacity-60" src={post.media_url} alt="Snap" />
                  <div class="absolute inset-0 flex items-center justify-center p-8">
                    <span class="text-white font-black text-center text-xl font-headline tracking-tight group-hover:scale-110 transition-transform">{post.caption}</span>
                  </div>
                </>
              ) : (
                <div class="p-10 flex flex-col justify-center h-full space-y-6">
                  <span class="text-primary font-black text-[10px] uppercase tracking-widest opacity-40">Member Spotlight</span>
                  <p class="text-on-surface-variant font-bold text-xl leading-relaxed">{post.caption}</p>
                  <div class="flex items-center gap-2 group/link">
                    <span class="text-primary text-[10px] font-black uppercase tracking-widest">Full Story</span>
                    <span class="material-symbols-outlined text-primary text-sm transform group-hover/link:translate-x-1 transition-transform">arrow_forward</span>
                  </div>
                </div>
              )}
            </a>
          ))}
          <div class="md:col-span-4 md:row-span-1 bg-primary text-on-primary rounded-[3rem] p-10 flex flex-col justify-center gap-6 relative overflow-hidden group">
            <span class="material-symbols-outlined text-6xl opacity-10 absolute-right-4 top-4 transform group-hover:rotate-12 transition-transform">water_drop</span>
            <h4 class="text-3xl font-black font-headline tracking-tighter">Become the Ripple.</h4>
            <p class="text-white/70 font-medium leading-relaxed">Join thousands of youth leaders in making an impact that lasts.</p>
            <a href="/clubs" class="bg-white text-primary self-start px-8 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-slate-50 transition-all">Find a club</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Join CTA Section -->
    <section class="relative py-48 px-6 lg:px-12 aqueous-gradient overflow-hidden">
      <div class="absolute top-0 left-0 w-full overflow-hidden leading-[0]">
        <svg class="relative block w-[calc(100%+1.3px)] h-[100px] fill-surface" preserveAspectRatio="none" viewBox="0 0 1200 120">
          <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z"></path>
        </svg>
      </div>
      <div class="max-w-screen-xl mx-auto text-center relative z-10">
        <div class="space-y-10 fade-in-up">
          <h2 class="text-7xl md:text-[9rem] font-black text-white tracking-[0.02em] leading-[0.8] font-headline mb-12">Ready to make <br/>your ripple?</h2>
          <p class="text-white/80 text-xl font-medium max-w-2xl mx-auto opacity-90 leading-relaxed">Join a community of doers, dreamers, and leaders. Find your club and start your service journey today.</p>
          <div class="flex flex-col md:flex-row justify-center gap-8 pt-8">
            <a href="/clubs" class="bg-white text-primary px-16 py-6 rounded-[2rem] font-black text-sm uppercase tracking-widest hover:translate-y-[-4px] transition-all hover:shadow-[0_20px_50px_rgba(255,255,255,0.2)]">
              Find a Club Near Me
            </a>
            <a href="/about" class="bg-white/10 backdrop-blur-xl border border-white/20 text-white px-16 py-6 rounded-[2rem] font-black text-sm uppercase tracking-widest hover:bg-white/20 transition-all">
              Our Vision
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .aqueous-gradient {
    background: linear-gradient(135deg, #174174 0%, #33588d 100%);
  }
  .fluid-shadow {
    box-shadow: 0 32px 48px -12px rgba(23, 65, 116, 0.08);
  }
  .absolute-right-4 {
    right: -1rem;
  }
</style>

