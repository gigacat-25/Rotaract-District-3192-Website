---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Secure Access">
  <div class="min-h-screen bg-surface flex items-center justify-center p-6 lg:p-12 relative overflow-hidden">
    <!-- Abstract Background Elements -->
    <div class="absolute inset-0 z-0 opacity-10 pointer-events-none">
      <div class="absolute top-0 right-0 w-[50vw] h-[50vw] aqueous-gradient rounded-full blur-[10rem] -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-[40vw] h-[40vw] bg-primary rounded-full blur-[8rem] translate-y-1/3 -translate-x-1/4"></div>
    </div>

    <div class="w-full max-w-xl relative z-10">
      <!-- Logo Header -->
      <div class="text-center mb-16 fade-in-up">
        <a href="/" class="inline-block space-y-4">
          <div class="w-20 h-20 bg-primary rounded-[1.5rem] mx-auto flex items-center justify-center rotate-[-4deg] fluid-shadow">
            <span class="material-symbols-outlined text-white text-4xl">water_drop</span>
          </div>
          <div class="space-y-1">
            <span class="block font-black text-4xl tracking-tighter text-primary font-headline uppercase leading-none">Rotaract</span>
            <span class="block text-[10px] uppercase tracking-[0.5em] text-primary/40 font-black">District 3192</span>
          </div>
        </a>
      </div>

      <!-- Auth Portal Card -->
      <div class="bg-surface-container-low rounded-[3rem] p-12 lg:p-16 fluid-shadow border border-outline-variant/30 fade-in-up stagger-1">
        
        <!-- Step 1: Email -->
        <div id="step-1" class="space-y-12">
          <div class="space-y-4 text-center">
            <h1 class="text-4xl font-black text-primary tracking-tighter font-headline">The Portal</h1>
            <p class="text-on-surface-variant text-sm font-medium leading-relaxed opacity-60 italic">Enter your registered identity to receive a secure access token.</p>
          </div>
          
          <form class="space-y-10" onsubmit="event.preventDefault(); document.getElementById('step-1').classList.add('hidden'); document.getElementById('step-2').classList.remove('hidden');">
            <div class="space-y-4">
              <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-primary/50 ml-2">Digital Address</label>
              <div class="relative group">
                <div class="absolute inset-y-0 left-6 flex items-center pointer-events-none transition-transform group-focus-within:scale-110">
                  <span class="material-symbols-outlined text-primary/30">alternate_email</span>
                </div>
                <input type="email" required class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-2xl py-6 pl-16 pr-8 text-primary font-bold placeholder:text-primary/10 focus:outline-none focus:ring-4 focus:ring-primary/5 focus:border-primary transition-all text-lg" placeholder="yourname@domain.org" />
              </div>
            </div>
            
            <button type="submit" class="w-full aqueous-gradient text-on-primary font-black py-6 rounded-2xl transition-all flex items-center justify-center gap-4 group shadow-2xl shadow-primary/20 hover:translate-y-[-2px]">
              <span class="uppercase tracking-[0.2em] text-xs">Request Access Token</span>
              <span class="material-symbols-outlined text-xl transition-transform group-hover:translate-x-2">arrow_forward</span>
            </button>
          </form>
        </div>

        <!-- Step 2: Verification (Hidden) -->
        <div id="step-2" class="hidden space-y-12">
          <div class="space-y-6 text-center">
            <div class="w-20 h-20 bg-green-500/10 rounded-[1.5rem] mx-auto flex items-center justify-center text-green-600 border border-green-500/10">
              <span class="material-symbols-outlined text-4xl">mark_email_read</span>
            </div>
            <div class="space-y-2">
              <h1 class="text-4xl font-black text-primary tracking-tighter font-headline">Verify Identity</h1>
              <p class="text-on-surface-variant text-sm font-medium leading-relaxed opacity-60 italic">A 6-digit pulse has been sent to your inbox.</p>
            </div>
          </div>
          
          <form action="/dashboard" class="space-y-10">
            <div class="space-y-4 text-center">
              <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-primary/50 mb-6">Verification Sequence</label>
              <div class="flex justify-center gap-3">
                {[1,2,3,4,5,6].map(i => (
                  <input type="text" maxlength="1" class="w-12 h-16 text-center text-3xl font-black text-primary bg-surface-container-lowest border border-outline-variant/30 rounded-xl focus:outline-none focus:ring-4 focus:ring-primary/5 focus:border-primary transition-all placeholder:opacity-20" placeholder="0" />
                ))}
              </div>
            </div>
            
            <button type="submit" class="w-full aqueous-gradient text-on-primary font-black py-6 rounded-2xl transition-all shadow-2xl shadow-primary/20 hover:translate-y-[-2px] uppercase tracking-[0.2em] text-xs">
              Establish Session
            </button>
            
            <div class="text-center pt-4">
              <button type="button" onclick="document.getElementById('step-2').classList.add('hidden'); document.getElementById('step-1').classList.remove('hidden');" class="text-[10px] font-black text-primary/40 uppercase tracking-widest hover:text-primary transition-colors border-b border-primary/10 pb-1">
                Rectify input address
              </button>
            </div>
          </form>
        </div>

      </div>
      
      <div class="mt-16 text-center max-w-sm mx-auto">
        <p class="text-[10px] text-on-surface-variant/40 font-black uppercase tracking-widest leading-relaxed">
          Access implies agreement with the <a href="#" class="text-primary hover:border-b-2 border-primary/20 transition-all">Consented Terms</a> and <a href="#" class="text-primary hover:border-b-2 border-primary/20 transition-all">Privacy Framework</a>.
        </p>
      </div>

    </div>
  </div>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>

