---
import Layout from '../layouts/Layout.astro';
import membersData from '../mock/members.json';

const user = membersData[0];
---

<Layout title="My Profile">
  
  <header class="bg-gray-50 py-12 border-b border-gray-200">
    <div class="container mx-auto px-4 max-w-4xl">
      <h1 class="text-3xl font-bold text-gray-900 tracking-tight">Profile Settings</h1>
    </div>
  </header>

  <section class="py-12 bg-white min-h-[60vh]">
    <div class="container mx-auto px-4 max-w-4xl flex flex-col md:flex-row gap-12">
      
      <!-- Settings Nav -->
      <div class="md:w-64 shrink-0">
        <nav class="space-y-1">
          <a href="#" class="block px-4 py-2.5 rounded-lg bg-[#003F8A] text-white font-semibold text-sm">Personal Info</a>
          <a href="#" class="block px-4 py-2.5 rounded-lg text-gray-600 hover:bg-gray-100 font-semibold text-sm transition-colors">Membership Details</a>
          <a href="#" class="block px-4 py-2.5 rounded-lg text-gray-600 hover:bg-gray-100 font-semibold text-sm transition-colors">Badges & Points</a>
          <a href="#" class="block px-4 py-2.5 rounded-lg text-red-600 hover:bg-red-50 font-semibold text-sm transition-colors mt-8">Log Out</a>
        </nav>
      </div>

      <!-- Content -->
      <div class="flex-grow">
        
        <div class="bg-white rounded-3xl p-8 border border-gray-100 card-shadow mb-8">
          <h2 class="text-xl font-bold text-gray-900 mb-8 border-b border-gray-100 pb-4">Personal Information</h2>
          
          <div class="flex items-center mb-10">
            <div class="relative">
              <img src={user.profile_pic_url} alt="Profile" class="w-24 h-24 rounded-full border border-gray-200" />
              <button class="absolute bottom-0 right-0 bg-white p-1.5 rounded-full border border-gray-200 shadow-sm text-gray-600 hover:text-[#003F8A]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </button>
            </div>
            <div class="ml-6">
              <h3 class="font-bold text-gray-900">{user.name}</h3>
              <p class="text-sm text-gray-500">JPG or PNG. Max size 5MB.</p>
            </div>
          </div>

          <form class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="block text-sm font-semibold text-gray-700">Full Name</label>
                <input type="text" value={user.name} class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm focus:ring-[#003F8A]">
              </div>
              <div class="space-y-2">
                <label class="block text-sm font-semibold text-gray-700">Email Address (Read-only)</label>
                <input type="email" value={user.email} disabled class="w-full bg-gray-100 border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-500 cursor-not-allowed">
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="block text-sm font-semibold text-gray-700">Phone</label>
                <input type="tel" value={user.phone} class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm focus:ring-[#003F8A]">
              </div>
              <div class="space-y-2">
                <label class="block text-sm font-semibold text-gray-700">WhatsApp Number</label>
                <input type="tel" value={user.whatsapp_number} class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm focus:ring-[#003F8A]">
              </div>
            </div>

            <div class="pt-6 text-right">
              <button type="button" class="bg-[#003F8A] hover:bg-[#002f6c] text-white font-bold px-8 py-3 rounded-xl transition-all shadow-sm">Save Changes</button>
            </div>
          </form>

        </div>

      </div>

    </div>
  </section>

</Layout>
