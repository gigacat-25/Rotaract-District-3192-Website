---
import Layout from '../layouts/Layout.astro';
import membersData from '../mock/members.json';

const user = membersData[0];
---

<Layout title="Identity Parameters">
  <main class="pt-20 bg-surface min-h-screen">
    <header class="bg-primary text-white pt-24 pb-16 relative overflow-hidden px-6 lg:px-12 border-b border-white/5">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-20 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-surface/5 rounded-tr-[15rem] blur-2xl"></div>
      </div>
      <div class="max-w-screen-2xl mx-auto relative z-10 space-y-4">
        <span class="inline-block px-4 py-1 rounded-full bg-white/10 text-white text-[9px] font-black tracking-[.3em] uppercase font-headline border border-white/10">Configuration</span>
        <h1 class="text-4xl md:text-6xl font-black text-white tracking-tighter font-headline uppercase leading-none italic">Identity Hub</h1>
        <p class="text-lg text-white/50 font-black uppercase tracking-[0.2em] font-headline max-w-xl italic">Modify core parameters and synchronize security protocols for session: {user.name}</p>
      </div>
    </header>

    <section class="py-24 px-6 lg:px-12">
      <div class="max-w-screen-2xl mx-auto flex flex-col xl:flex-row gap-20">
        
        <!-- Sidebar Navigation -->
        <div class="xl:w-80 shrink-0">
          <nav class="space-y-4 sticky top-32">
            {[
              { label: 'Core Parameters', active: true, icon: 'fingerprint' },
              { label: 'Security Protocols', active: false, icon: 'shield_lock' },
              { label: 'Pulse Analytics', active: false, icon: 'monitoring' },
              { label: 'Terminate Session', active: false, icon: 'logout', danger: true }
            ].map(item => (
              <a href="#" class={`flex items-center gap-4 px-8 py-5 rounded-2xl font-black uppercase tracking-widest text-[10px] transition-all group border
                ${item.active 
                  ? 'bg-primary text-on-primary border-primary shadow-2xl' 
                  : 'bg-surface-container-low text-primary/40 border-outline-variant/30 hover:bg-surface-container-lowest hover:text-primary'}
                ${item.danger ? 'mt-12 text-red-500 hover:bg-red-500/5 hover:border-red-500/20' : ''}`}>
                <span class="material-symbols-outlined text-xl">{item.icon}</span>
                {item.label}
              </a>
            ))}
          </nav>
        </div>

        <!-- Configuration Terminal -->
        <div class="flex-grow space-y-12">
          
          <div class="bg-surface-container-low rounded-[3rem] p-12 lg:p-16 border border-outline-variant/30 fluid-shadow relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 aqueous-gradient opacity-10 blur-3xl pointer-events-none"></div>
            
            <div class="flex flex-col md:flex-row items-center gap-10 mb-16 pb-12 border-b border-primary/5">
              <div class="relative group">
                <div class="absolute inset-[-10%] bg-primary/20 rounded-[2.5rem] blur-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <img src={user.profile_pic_url} alt="Profile" class="w-32 h-32 rounded-[2.5rem] border-4 border-white shadow-2xl relative z-10 object-cover" />
                <button class="absolute -bottom-2 -right-2 w-12 h-12 bg-white text-primary rounded-2xl border-4 border-surface-container-low flex items-center justify-center shadow-xl z-20 hover:scale-110 active:scale-95 transition-all">
                  <span class="material-symbols-outlined text-xl">camera_enhance</span>
                </button>
              </div>
              <div class="text-center md:text-left space-y-2">
                <h3 class="text-3xl font-black text-primary font-headline tracking-tighter uppercase italic leading-none">{user.name}</h3>
                <p class="text-[10px] font-black font-headline text-primary/40 uppercase tracking-[0.4em]">Node ID: 3192-ALPHA-08</p>
                <p class="text-on-surface-variant font-medium text-xs opacity-60 italic">Supported formats: JPEG, PNG, WEBP (Max 8000KB)</p>
              </div>
            </div>

            <form class="space-y-12">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                <div class="space-y-3">
                  <label class="block text-[10px] font-black uppercase tracking-[0.4em] text-primary/40 px-4">Full Identity Token</label>
                  <input type="text" value={user.name} class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-2xl px-6 py-5 text-sm font-bold text-primary focus:outline-none focus:ring-4 focus:ring-primary/5 transition-all shadow-inner">
                </div>
                <div class="space-y-3">
                  <label class="block text-[10px] font-black uppercase tracking-[0.4em] text-primary/40 px-4">System Signal (Read-Only)</label>
                  <input type="email" value={user.email} disabled class="w-full bg-surface/50 border border-primary/5 rounded-2xl px-6 py-5 text-sm font-black text-primary/30 cursor-not-allowed italic font-headline uppercase tracking-widest">
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                <div class="space-y-3">
                  <label class="block text-[10px] font-black uppercase tracking-[0.4em] text-primary/40 px-4">Voice Primary String</label>
                  <input type="tel" value={user.phone} class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-2xl px-6 py-5 text-sm font-bold text-primary focus:outline-none focus:ring-4 focus:ring-primary/5 transition-all shadow-inner">
                </div>
                <div class="space-y-3">
                  <label class="block text-[10px] font-black uppercase tracking-[0.4em] text-primary/40 px-4">Network Encryption Stream</label>
                  <input type="tel" value={user.whatsapp_number} class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-2xl px-6 py-5 text-sm font-bold text-primary focus:outline-none focus:ring-4 focus:ring-primary/5 transition-all shadow-inner">
                </div>
              </div>

              <div class="pt-8 flex justify-end">
                <button type="button" class="group relative bg-primary text-on-primary font-black px-16 py-6 rounded-2xl uppercase tracking-[0.3em] text-[10px] shadow-2xl hover:translate-y-[-4px] active:translate-y-0 transition-all overflow-hidden flex items-center gap-4">
                  <span class="relative z-10 flex items-center gap-3 italic">Synchronize Baseline <span class="material-symbols-outlined text-lg">sync_saved_locally</span></span>
                  <div class="absolute inset-0 aqueous-gradient opacity-0 group-hover:opacity-20 transition-opacity"></div>
                </button>
              </div>
            </form>
          </div>

          <div class="bg-red-500/5 rounded-[2.5rem] p-10 border border-red-500/10 flex flex-col md:flex-row items-center justify-between gap-8 italic">
             <div class="space-y-2 text-center md:text-left">
                <p class="text-red-500 font-black uppercase tracking-[0.4em] text-[10px]">Critical Override</p>
                <p class="text-on-surface-variant font-medium text-sm opacity-70">Proceeding with account deactivation will permanently terminate your network signal.</p>
             </div>
             <button class="px-8 py-4 rounded-xl border border-red-500/30 text-red-500 font-black text-[10px] uppercase tracking-widest hover:bg-red-500 hover:text-white transition-all whitespace-nowrap">Execute Deactivation</button>
          </div>

        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>

