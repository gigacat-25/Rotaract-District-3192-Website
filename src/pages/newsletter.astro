---
import Layout from '../layouts/Layout.astro';
import newslettersData from '../mock/newsletters.json';

const newsletters = newslettersData;
---

<Layout title="Newsletters">
  
  <!-- HEADER -->
  <header class="bg-[#F5A623] pt-24 pb-20 relative overflow-hidden">
    <div class="absolute -right-20 -top-20 text-[#003F8A]/10 transform rotate-12 pointer-events-none scale-150">
      <svg width="400" height="400" viewBox="0 0 24 24" fill="currentColor"><path d="M12.01 2.01v4.71a.63.63 0 0 0 .53.6h9.34A10.02 10.02 0 0 1 22 12.01h-4.71a.63.63 0 0 0-.6.53v9.34a10.02 10.02 0 0 1-4.68.12v-4.72a.63.63 0 0 0-.54-.6H2.02A10.02 10.02 0 0 1 2 11.99h4.72c.31 0 .58-.23.6-.54V2.02a10.02 10.02 0 0 1 4.69-.01z"/></svg>
    </div>
    
    <div class="container mx-auto px-4 lg:px-8 relative z-10 text-center">
      <h1 class="text-5xl md:text-6xl font-extrabold text-[#003F8A] mb-4 tracking-tighter">The Golden Wheel</h1>
      <p class="text-xl text-[#003F8A]/80 max-w-2xl mx-auto font-medium">
        District 3192's Official Monthly Newsletter
      </p>
    </div>
  </header>

  <!-- MAGAZINE GRID -->
  <section class="py-20 bg-gray-50 min-h-[50vh]">
    <div class="container mx-auto px-4 lg:px-8">
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10">
        {newsletters.map((nl, index) => (
          <div class={`group relative fade-in-up stagger-${(index % 4) + 1}`}>
            <!-- Issue Cover -->
            <div class="relative bg-white rounded-xl overflow-hidden card-shadow mb-6 aspect-[1/1.4] transform transition-transform duration-500 origin-bottom group-hover:-translate-y-4 group-hover:rotate-1">
              <img src={nl.thumbnail_url} alt={nl.title} class="w-full h-full object-cover" />
              
              <!-- Download Overlay -->
              <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center backdrop-blur-sm">
                <a href={nl.file_url} class="bg-white text-[#003F8A] font-bold px-6 py-3 rounded-full transform translate-y-4 group-hover:translate-y-0 transition-all flex items-center shadow-lg hover:scale-105">
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                  Read PDF
                </a>
              </div>
            </div>
            
            <!-- Issue Info -->
            <div class="text-center px-2 border-t border-gray-200 pt-4">
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">{nl.club_name}</p>
              <h3 class="text-lg font-bold text-gray-900 leading-tight">{nl.title}</h3>
              <p class="text-sm text-gray-500 mt-1">{new Date(nl.published_at).toLocaleDateString('en-IN', {month: 'long', year: 'numeric'})}</p>
            </div>
          </div>
        ))}
      </div>
      
    </div>
  </section>

</Layout>
