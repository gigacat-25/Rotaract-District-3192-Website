---
import Layout from '../layouts/Layout.astro';
import newslettersData from '../mock/newsletters.json';

const newsletters = newslettersData;
---

<Layout title="Distict Publications">
  <main class="pt-20">
    <header class="bg-primary text-white pt-32 pb-24 relative overflow-hidden px-6 lg:px-12">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-20 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-surface/5 rounded-tr-[15rem] blur-2xl"></div>
      </div>
      <div class="container mx-auto max-w-screen-2xl relative z-10 text-center space-y-6">
        <span class="inline-block px-5 py-2 rounded-full bg-white/10 text-white text-[10px] font-black tracking-[0.3em] uppercase font-headline border border-white/10">
          The Archive
        </span>
        <h1 class="text-6xl md:text-8xl font-black mb-4 tracking-tighter font-headline uppercase leading-none">The Golden Wheel</h1>
        <p class="text-xl text-white/70 max-w-2xl mx-auto font-body font-medium italic">Official monthly chronicles and impact reports of District 3192.</p>
      </div>
    </header>

    <!-- MAGAZINE GRID -->
    <section class="py-24 bg-surface px-6 lg:px-12 min-h-screen border-t border-outline-variant/30">
      <div class="max-w-screen-2xl mx-auto">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-12">
          {newsletters.map((nl, index) => (
            <div class={`group space-y-8 fade-in-up stagger-${(index % 4) + 1}`}>
              <!-- Issue Cover -->
              <div class="relative bg-surface-container-low rounded-[2rem] overflow-hidden fluid-shadow aspect-[3/4] transition-all duration-700 group-hover:translate-y-[-12px] group-hover:rotate-[-2deg] border border-outline-variant/30">
                <img src={nl.thumbnail_url} alt={nl.title} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000" />
                
                <!-- Download Overlay -->
                <div class="absolute inset-0 bg-primary/80 opacity-0 group-hover:opacity-100 transition-all duration-500 flex flex-col items-center justify-center backdrop-blur-xl p-8 text-center space-y-6">
                  <div class="w-16 h-16 rounded-full bg-white/20 flex items-center justify-center backdrop-blur-md border border-white/20">
                    <span class="material-symbols-outlined text-white text-3xl">menu_book</span>
                  </div>
                  <div class="space-y-2">
                    <p class="text-white text-xs font-black uppercase tracking-widest leading-none">Access Edition</p>
                    <p class="text-white/60 text-[10px] font-medium leading-relaxed italic">Download encrypted PDF version of this monthly chronicle.</p>
                  </div>
                  <a href={nl.file_url} class="bg-white text-primary font-black px-8 py-4 rounded-xl uppercase tracking-widest text-[10px] shadow-2xl hover:scale-105 active:scale-95 transition-all flex items-center gap-3">
                    <span class="material-symbols-outlined text-lg">download</span>
                    Retrieve PDF
                  </a>
                </div>
              </div>
              
              <!-- Issue Info -->
              <div class="space-y-3 px-4">
                <div class="flex items-center gap-3">
                  <span class="w-2 h-2 rounded-full bg-primary/20"></span>
                  <p class="text-[10px] font-black text-primary/40 uppercase tracking-[0.3em] leading-none">{nl.club_name}</p>
                </div>
                <h3 class="text-2xl font-black text-primary font-headline tracking-tighter uppercase leading-tight group-hover:text-primary-container transition-colors">{nl.title}</h3>
                <div class="flex items-center justify-between pt-4 border-t border-primary/5">
                  <p class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest opacity-30">{new Date(nl.published_at).toLocaleDateString('en-IN', {month: 'long', year: 'numeric'})}</p>
                  <span class="material-symbols-outlined text-primary/20 group-hover:text-primary transition-colors">arrow_forward</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>
