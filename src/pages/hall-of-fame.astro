---
import Layout from '../layouts/Layout.astro';
import leaderboardData from '../mock/leaderboard.json';

const leaderboard = leaderboardData.sort((a: any, b: any) => a.rank - b.rank);
---

<Layout title="Hall of Fame">
  <!-- HERO HEADER -->
  <header class="bg-[#003F8A] text-white pt-24 pb-32 relative overflow-hidden text-center rounded-b-[40px] md:rounded-b-[80px]">
    <!-- Decorative aura -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-3xl aspect-square bg-[#F5A623] rounded-full blur-[120px] opacity-20 pointer-events-none"></div>
    
    <div class="container mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-6xl font-extrabold mb-4 tracking-tighter">Hall of Fame</h1>
      <p class="text-lg md:text-xl text-blue-100 max-w-2xl mx-auto font-light">
        Celebrating the most dedicated, active, and impactful members of District 3192.
      </p>
    </div>
  </header>

  <!-- LEADERBOARD COMPONENT -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 -mt-20 relative z-20 pb-24">
    
    <!-- Top 3 Podium (Desktop) -->
    <div class="hidden md:flex items-end justify-center gap-6 mb-12">
      {/* 2nd Place */}
      <div class="flex flex-col items-center pb-8 transform translate-y-8">
        <div class="text-2xl font-bold text-gray-400 mb-2">#2</div>
        <img src={leaderboard[1].profile_pic_url} alt={leaderboard[1].name} class="w-24 h-24 rounded-full border-4 border-gray-300 shadow-xl mb-4 bg-white" />
        <h3 class="font-bold text-lg text-white mb-1 drop-shadow-md">{leaderboard[1].name}</h3>
        <p class="text-xs text-white/80 font-medium mb-3 backdrop-blur-md bg-black/20 px-3 py-1 rounded-full">{leaderboard[1].points} pts</p>
        <div class="w-32 h-32 bg-gray-200 rounded-t-xl shadow-inner border-t-2 border-x-2 border-gray-300"></div>
      </div>
      
      {/* 1st Place */}
      <div class="flex flex-col items-center">
        <div class="relative mb-3">
          <svg class="absolute -top-6 left-1/2 -translate-x-1/2 w-8 h-8 text-[#F5A623] animate-bounce" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
        </div>
        <img src={leaderboard[0].profile_pic_url} alt={leaderboard[0].name} class="w-32 h-32 rounded-full border-4 border-[#F5A623] shadow-[0_0_30px_rgba(245,166,35,0.4)] mb-4 bg-white relative z-10" />
        <h3 class="font-bold text-xl text-white mb-1 drop-shadow-md">{leaderboard[0].name}</h3>
        <p class="text-sm font-bold text-[#F5A623] mb-4 bg-white/10 backdrop-blur-md px-4 py-1 rounded-full shadow-lg">{leaderboard[0].points} points</p>
        <div class="w-40 h-40 bg-gradient-to-b from-[#F5A623]/20 to-[#F5A623]/5 rounded-t-xl border-t-2 border-x-2 border-[#F5A623]/40 backdrop-blur-sm self-end"></div>
      </div>
      
      {/* 3rd Place */}
      <div class="flex flex-col items-center pb-8 transform translate-y-12">
        <div class="text-2xl font-bold text-[#CD7F32] mb-2">#3</div>
        <img src={leaderboard[2].profile_pic_url} alt={leaderboard[2].name} class="w-20 h-20 rounded-full border-4 border-[#CD7F32] shadow-xl mb-4 bg-white" />
        <h3 class="font-bold text-lg text-white mb-1 drop-shadow-md">{leaderboard[2].name}</h3>
        <p class="text-xs text-white/80 font-medium mb-3 backdrop-blur-md bg-black/20 px-3 py-1 rounded-full">{leaderboard[2].points} pts</p>
        <div class="w-28 h-24 bg-[#CD7F32]/10 rounded-t-xl border-t-2 border-x-2 border-[#CD7F32]/40 backdrop-blur-sm"></div>
      </div>
    </div>

    <!-- MAIN TABLE -->
    <div class="bg-white rounded-2xl card-shadow border border-gray-100 overflow-hidden">
      
      <!-- Filters header -->
      <div class="p-6 border-b border-gray-100 flex flex-col sm:flex-row justify-between items-center gap-4 bg-gray-50/50">
        <h2 class="text-xl font-bold text-gray-900">May Rankings</h2>
        <div class="flex items-center space-x-3 bg-white p-1 rounded-full border border-gray-200">
          <button class="bg-gray-100 text-gray-900 font-semibold text-sm px-4 py-1.5 rounded-full shadow-sm">District</button>
          <button class="text-gray-500 hover:text-gray-900 font-medium text-sm px-4 py-1.5 rounded-full transition-colors">My Club</button>
        </div>
      </div>

      <!-- List -->
      <ul class="divide-y divide-gray-100">
        {leaderboard.map((member, index) => (
          <li class="p-4 sm:p-6 hover:bg-gray-50 transition-colors flex items-center group">
            
            <div class="w-12 text-center text-lg font-bold text-gray-400 group-hover:text-[#003F8A] transition-colors shrink-0">
              #{member.rank}
            </div>
            
            <div class="flex items-center flex-1 min-w-0 mr-4">
              <img src={member.profile_pic_url} alt="" class="w-12 h-12 rounded-full hidden sm:block border border-gray-200 shadow-sm shrink-0" />
              <div class="ml-0 sm:ml-4 flex-1 min-w-0">
                <h4 class="text-base font-bold text-gray-900 truncate">{member.name}</h4>
                <p class="text-sm text-gray-500 truncate">{member.club_name}</p>
                {/* Badges - Mobile Only */}
                {member.badges.length > 0 && (
                  <div class="flex sm:hidden gap-2 mt-1 overflow-x-auto scrollbar-hide py-1">
                    {member.badges.map(b => (
                      <span class="inline-block bg-[#003F8A]/10 text-[#003F8A] text-[10px] font-bold px-2.5 py-0.5 rounded shadow-sm whitespace-nowrap">{b}</span>
                    ))}
                  </div>
                )}
              </div>
            </div>
            
            {/* Badges - Desktop Only */}
            <div class="hidden sm:flex items-center justify-end space-x-2 mr-6 shrink-0 w-48 overflow-hidden">
              {member.badges.map(b => (
                <span class="bg-[#003F8A]/10 text-[#003F8A] text-xs font-bold px-2.5 py-1 rounded shadow-sm whitespace-nowrap">{b}</span>
              ))}
            </div>
            
            <div class="text-right shrink-0">
              <div class="text-xl sm:text-2xl font-extrabold text-[#F5A623]">{member.points}</div>
              <div class="text-[10px] sm:text-xs text-gray-400 font-medium uppercase tracking-wider">Points</div>
            </div>
            
          </li>
        ))}
      </ul>
      
    </div>
  </section>
</Layout>
