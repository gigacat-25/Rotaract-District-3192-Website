---
import Layout from '../layouts/Layout.astro';
import leaderboardData from '../mock/leaderboard.json';

const leaderboard = leaderboardData.sort((a: any, b: any) => a.rank - b.rank);

const top1 = leaderboard[0];
const top2 = leaderboard[1];
const top3 = leaderboard[2];
---

<Layout title="Hall of Fame">
  <main class="pt-20">
    <header class="bg-primary text-white pt-32 pb-48 relative overflow-hidden text-center">
      <!-- Abstract Liquid Aura -->
      <div class="absolute inset-0 z-0 opacity-20">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-5xl aspect-square aqueous-gradient rounded-full blur-[10rem] animate-pulse"></div>
        <div class="absolute bottom-0 left-0 w-full h-1/2 bg-surface/10 rounded-t-[20rem] blur-3xl"></div>
      </div>
      
      <div class="container mx-auto px-6 relative z-10 space-y-6">
        <span class="inline-block px-5 py-2 rounded-full bg-white/10 text-white text-[10px] font-black tracking-[0.3em] uppercase font-headline border border-white/10">
          The Pantheon
        </span>
        <h1 class="text-6xl md:text-8xl font-black mb-4 tracking-tighter font-headline uppercase leading-none">Hall of Fame</h1>
        <p class="text-xl text-white/70 max-w-2xl mx-auto font-body font-medium italic">
          Celebrating the most dedicated, impactful identities within District 3192.
        </p>
      </div>
    </header>

    <!-- PODIUM & TABLE SECTION -->
    <section class="max-w-screen-2xl mx-auto px-6 lg:px-12 -mt-32 relative z-20 pb-32">
      
      <!-- Fluid Podium (Desktop) -->
      <div class="hidden md:flex items-end justify-center gap-12 mb-24">
        {/* 2nd Place */}
        <div class="flex flex-col items-center pb-12 transition-transform hover:translate-y-[-10px] group">
          <div class="text-[10px] font-black text-white/40 uppercase tracking-[0.5em] mb-4">Rank 02</div>
          <div class="relative mb-6">
            <div class="absolute inset-0 bg-white/10 rounded-full blur-2xl scale-150"></div>
            <img src={top2.profile_pic_url} alt={top2.name} class="w-32 h-32 rounded-[2rem] border-4 border-white/20 shadow-2xl relative z-10 grayscale group-hover:grayscale-0 transition-all duration-700 rotate-[-4deg]" />
          </div>
          <h3 class="font-black text-2xl text-white mb-2 font-headline tracking-tighter uppercase">{top2.name}</h3>
          <span class="text-[10px] font-black text-white px-4 py-1.5 rounded-full bg-white/10 border border-white/10 uppercase tracking-widest mb-8">{top2.points} pts</span>
          <div class="w-40 h-48 bg-surface-container-low/40 backdrop-blur-3xl rounded-t-[3rem] border-t border-x border-white/10 fluid-shadow"></div>
        </div>
        
        {/* 1st Place */}
        <div class="flex flex-col items-center group transition-transform hover:translate-y-[-15px]">
          <div class="relative mb-6">
            <div class="absolute -top-12 left-1/2 -translate-x-1/2 w-12 h-12 aqueous-gradient rounded-full flex items-center justify-center shadow-2xl animate-bounce">
              <span class="material-symbols-outlined text-white">workspace_premium</span>
            </div>
            <div class="absolute inset-x-[-20%] inset-y-[-20%] aqueous-gradient rounded-full blur-[4rem] opacity-30 animate-pulse"></div>
            <img src={top1.profile_pic_url} alt={top1.name} class="w-48 h-48 rounded-[3rem] border-8 border-white shadow-2xl relative z-10 group-hover:rotate-[2deg] transition-all duration-1000" />
          </div>
          <h3 class="font-black text-4xl text-white mb-3 font-headline tracking-tighter uppercase">{top1.name}</h3>
          <span class="text-xs font-black text-primary px-6 py-2 rounded-full bg-white shadow-2xl uppercase tracking-[0.2em] mb-10 transition-all group-hover:scale-110">{top1.points} points</span>
          <div class="w-56 h-64 bg-surface-container-low/80 backdrop-blur-3xl rounded-t-[4rem] border-t border-x border-white/20 fluid-shadow-large"></div>
        </div>
        
        {/* 3rd Place */}
        <div class="flex flex-col items-center pb-8 transition-transform hover:translate-y-[-8px] group">
          <div class="text-[10px] font-black text-white/40 uppercase tracking-[0.5em] mb-4">Rank 03</div>
          <div class="relative mb-6">
            <div class="absolute inset-0 bg-white/10 rounded-full blur-2xl scale-150"></div>
            <img src={top3.profile_pic_url} alt={top3.name} class="w-28 h-28 rounded-[1.8rem] border-4 border-white/20 shadow-2xl relative z-10 grayscale group-hover:grayscale-0 transition-all duration-700 rotate-[4deg]" />
          </div>
          <h3 class="font-black text-xl text-white mb-2 font-headline tracking-tighter uppercase">{top3.name}</h3>
          <span class="text-[10px] font-black text-white px-4 py-1.5 rounded-full bg-white/10 border border-white/10 uppercase tracking-widest mb-8">{top3.points} pts</span>
          <div class="w-36 h-32 bg-surface-container-low/30 backdrop-blur-3xl rounded-t-[2.5rem] border-t border-x border-white/10 fluid-shadow"></div>
        </div>
      </div>

      <!-- MAIN TABLE -->
      <div class="bg-surface-container-low rounded-[3rem] fluid-shadow border border-outline-variant/30 overflow-hidden">
        
        <!-- Filters header -->
        <div class="p-10 border-b border-primary/5 flex flex-col md:flex-row justify-between items-center gap-10 bg-surface-container-lowest/50">
          <div class="space-y-1 text-center md:text-left">
            <h2 class="text-3xl font-black text-primary font-headline tracking-tighter uppercase leading-none">Global Sequence</h2>
            <p class="text-[10px] font-black text-on-surface-variant uppercase tracking-[.4em] opacity-40">Operating Period: May 2026</p>
          </div>
          <div class="flex items-center gap-2 bg-primary/5 p-2 rounded-2xl border border-primary/5">
            <button class="bg-primary text-on-primary font-black text-[10px] uppercase tracking-widest px-8 py-3 rounded-xl shadow-xl transition-all">District</button>
            <button class="text-primary/40 hover:text-primary font-black text-[10px] uppercase tracking-widest px-8 py-3 rounded-xl transition-all">My Core</button>
          </div>
        </div>

        <!-- List -->
        <div class="grid divide-y divide-primary/5">
          {leaderboard.map((member, index) => (
            <div class="p-10 hover:bg-surface-container-lowest transition-all flex items-center gap-10 group">
              
              <div class="w-16 text-center shrink-0">
                <span class="text-2xl font-black text-primary/20 font-headline group-hover:text-primary transition-colors">
                  {member.rank.toString().padStart(2, '0')}
                </span>
              </div>
              
              <div class="flex items-center flex-1 min-w-0 gap-8">
                <div class="w-16 h-16 rounded-2xl overflow-hidden fluid-shadow border-2 border-primary/5 grayscale group-hover:grayscale-0 transition-all duration-700 hidden sm:block">
                  <img src={member.profile_pic_url} alt="" class="w-full h-full object-cover" />
                </div>
                <div class="flex-1 min-w-0 space-y-1">
                  <h4 class="text-2xl font-black text-primary font-headline tracking-tighter uppercase leading-none truncate">{member.name}</h4>
                  <p class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest opacity-40 leading-none">{member.club_name}</p>
                  
                  {/* Badges - Mobile Only */}
                  <div class="flex md:hidden gap-3 mt-4 overflow-x-auto scrollbar-hide">
                    {member.badges.map(b => (
                      <span class="inline-block bg-primary/5 text-primary text-[8px] font-black uppercase tracking-[0.2em] px-3 py-1 rounded-full border border-primary/10 whitespace-nowrap">{b}</span>
                    ))}
                  </div>
                </div>
              </div>
              
              {/* Badges - Desktop Only */}
              <div class="hidden md:flex items-center justify-end gap-3 shrink-0">
                {member.badges.map(b => (
                  <span class="bg-primary/5 text-primary text-[9px] font-black uppercase tracking-[0.2em] px-4 py-2 rounded-full border border-primary/10 whitespace-nowrap shadow-sm group-hover:bg-primary group-hover:text-white group-hover:border-primary transition-all duration-500">{b}</span>
                ))}
              </div>
              
              <div class="text-right shrink-0 min-w-[100px]">
                <div class="text-4xl font-black text-primary font-headline tracking-tighter leading-none">{member.points}</div>
                <div class="text-[9px] font-black text-on-surface-variant uppercase tracking-[.3em] opacity-30 mt-1">Pulse Points</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
  .fluid-shadow-large {
    box-shadow: 0 48px 96px -24px rgba(13, 65, 116, 0.12);
  }
</style>

