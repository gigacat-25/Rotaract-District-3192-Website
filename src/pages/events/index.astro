---
import Layout from '../../layouts/Layout.astro';
import eventsData from '../../mock/events.json';
import clubsData from '../../mock/clubs.json';

const events = eventsData;
const publishedEvents = events.filter((e: any) => e.status === 'published');
const upcomingEvents = publishedEvents.filter((e: any) => e.start_at > new Date().toISOString());
const clubs = clubsData.filter((c: any) => c.status === 'active');
---

<Layout title="District Events Calendar">
  
  <header class="bg-[#003F8A] text-white pt-24 pb-20 relative overflow-hidden">
    <div class="absolute -left-10 top-0 w-64 h-64 bg-[#F5A623] rounded-full blur-[100px] opacity-30 pointer-events-none"></div>
    <div class="container mx-auto px-4 lg:px-8 max-w-6xl relative z-10">
      <h1 class="text-4xl md:text-6xl font-extrabold mb-4 tracking-tight">Events Calendar</h1>
      <p class="text-xl text-blue-100 max-w-2xl font-light">Join initiatives across District 3192. Filter by club, category, or ticket type.</p>
    </div>
  </header>

  <section class="py-8 bg-white border-b border-gray-200 sticky top-16 z-40 shadow-sm">
    <div class="container mx-auto px-4 lg:px-8 max-w-6xl">
      <!-- Desktop Filters -->
      <form class="hidden lg:flex items-center space-x-4">
        <div class="flex-grow relative">
          <input type="text" placeholder="Search events..." class="w-full bg-gray-50 border border-gray-200 text-gray-900 text-sm rounded-xl focus:ring-[#003F8A] focus:border-[#003F8A] py-2.5 pl-10 pr-4 shadow-sm" />
          <svg class="w-4 h-4 text-gray-400 absolute left-4 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
        
        <select class="w-48 bg-gray-50 border border-gray-200 text-gray-700 text-sm rounded-xl focus:ring-[#003F8A] focus:border-[#003F8A] py-2.5 px-4 shadow-sm">
          <option value="">Any Club</option>
          {clubs.map(c => <option value={c.id}>{c.name}</option>)}
        </select>
        
        <select class="w-40 bg-gray-50 border border-gray-200 text-gray-700 text-sm rounded-xl focus:ring-[#003F8A] focus:border-[#003F8A] py-2.5 px-4 shadow-sm">
          <option value="">Any Category</option>
          <option value="service">Community Service</option>
          <option value="professional">Professional</option>
          <option value="social">Social/Fellowship</option>
        </select>
        
        <select class="w-36 bg-gray-50 border border-gray-200 text-gray-700 text-sm rounded-xl focus:ring-[#003F8A] focus:border-[#003F8A] py-2.5 px-4 shadow-sm">
          <option value="">Any Ticket</option>
          <option value="free">Free</option>
          <option value="paid">Paid</option>
        </select>
      </form>

      <!-- Mobile Filters Toggle -->
      <div class="lg:hidden flex items-center justify-between">
        <div class="relative flex-grow mr-4">
          <input type="text" placeholder="Search events..." class="w-full bg-gray-50 border border-gray-200 text-gray-900 text-sm rounded-xl focus:ring-[#003F8A] focus:border-[#003F8A] py-2.5 pl-10 pr-4 shadow-sm" />
          <svg class="w-4 h-4 text-gray-400 absolute left-4 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
        <button class="bg-gray-100 p-2.5 rounded-xl text-gray-600 border border-gray-200 shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
        </button>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50 min-h-screen">
    <div class="container mx-auto px-4 lg:px-8 max-w-6xl">
      
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-gray-900">Upcoming ({upcomingEvents.length})</h2>
        <div class="flex bg-white p-1 rounded-lg border border-gray-200 shadow-sm">
          <button class="bg-gray-100 text-gray-900 px-3 py-1.5 rounded-md text-sm font-medium shadow-sm">Grid</button>
          <button class="text-gray-500 hover:text-gray-900 px-3 py-1.5 rounded-md text-sm font-medium transition-colors">List</button>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {upcomingEvents.map((event, index) => (
          <div class={`bg-white rounded-2xl overflow-hidden card-shadow border border-gray-100 group flex flex-col fade-in-up stagger-${(index % 4) + 1}`}>
            
            <!-- Contextual Image + Badges -->
            <div class="h-48 bg-gray-200 relative overflow-hidden shrink-0">
              <img src={event.banner_url} alt={event.title} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent"></div>
              
              <div class="absolute top-4 left-4 flex gap-2">
                <span class={`text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded shadow-sm text-white backdrop-blur-md
                  ${event.type ==='service' ? 'bg-green-500/80' : event.type==='professional' ? 'bg-[#003F8A]/80' : 'bg-pink-500/80'}`}>
                  {event.type}
                </span>
                <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded shadow-sm bg-white/90 text-gray-900 backdrop-blur-md">
                  {event.is_free ? 'Free' : 'Paid'}
                </span>
              </div>
              
              <div class="absolute bottom-4 left-4 text-white">
                <p class="text-2xl font-bold leading-none drop-shadow-md">{new Date(event.start_at).getDate()}</p>
                <p class="text-xs font-bold uppercase tracking-wide drop-shadow-md">{new Date(event.start_at).toLocaleDateString('en-US', {month: 'short'})}</p>
              </div>
            </div>
            
            <!-- Event Data -->
            <div class="p-6 flex-grow flex flex-col">
              <div class="text-xs font-bold text-gray-400 mb-2 uppercase tracking-wide flex items-center gap-1.5">
                <img src={`https://ui-avatars.com/api/?name=${event.club_name.replace(/ /g, '+')}?background=random`} class="w-4 h-4 rounded-full" />
                <span class="truncate">{event.club_name}</span>
              </div>
              
              <h3 class="text-xl font-bold text-gray-900 mb-3 leading-tight group-hover:text-[#003F8A] transition-colors">{event.title}</h3>
              
              <div class="flex items-start text-sm text-gray-500 mb-6">
                <svg class="w-4 h-4 mr-2 mt-0.5 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                <span class="line-clamp-2 leading-snug">{event.venue}</span>
              </div>
              
              <a href={`/events/${event.slug}`} class="mt-auto block w-full text-center bg-gray-50 hover:bg-[#F5A623] hover:text-[#003F8A] hover:border-[#F5A623] text-[#003F8A] border border-gray-200 font-bold py-3 rounded-xl transition-all shadow-sm">
                Register Details
              </a>
            </div>
            
          </div>
        ))}
      </div>

    </div>
  </section>

</Layout>
