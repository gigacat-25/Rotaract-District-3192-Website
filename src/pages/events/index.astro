---
import Layout from '../../layouts/Layout.astro';
import eventsData from '../../mock/events.json';
import clubsData from '../../mock/clubs.json';

const events = eventsData;
const publishedEvents = events.filter((e: any) => e.status === 'published');
const upcomingEvents = publishedEvents.filter((e: any) => e.start_at > new Date().toISOString());
const clubs = clubsData.filter((c: any) => c.status === 'active');
---

<Layout title="District Events Calendar">
  <main class="pt-20">
    <header class="bg-primary text-white pt-32 pb-24 relative overflow-hidden px-6 lg:px-12">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-20 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-surface/5 rounded-tr-[15rem] blur-2xl"></div>
      </div>
      <div class="container mx-auto max-w-screen-2xl relative z-10 text-center space-y-6">
        <span class="inline-block px-5 py-2 rounded-full bg-white/10 text-white text-[10px] font-black tracking-[0.3em] uppercase font-headline border border-white/10">
          The Calendar
        </span>
        <h1 class="text-6xl md:text-8xl font-black mb-4 tracking-tighter font-headline">Waves of Action</h1>
        <p class="text-xl text-white/70 max-w-2xl mx-auto font-body font-medium italic">Join initiatives across District 3192. Filter by club, category, or ticket type.</p>
      </div>
    </header>

    <!-- Filters Section (Tonal Layering) -->
    <section class="py-12 bg-surface-container-low border-b border-outline-variant/30 sticky top-20 z-30 shadow-sm px-6 lg:px-12">
      <div class="max-w-screen-2xl mx-auto">
        <!-- Desktop Filters -->
        <form class="hidden lg:flex items-center gap-6">
          <div class="flex-grow relative">
            <input type="text" placeholder="Search events..." class="w-full pl-14 pr-6 py-4 bg-surface-container-lowest rounded-2xl text-sm font-bold focus:outline-none focus:ring-4 focus:ring-primary/5 transition-all fluid-shadow" />
            <span class="material-symbols-outlined absolute left-5 top-1/2 -translate-y-1/2 text-primary opacity-40">search</span>
          </div>
          
          <div class="relative flex-shrink-0">
            <select class="appearance-none w-56 bg-surface-container-lowest py-4 pl-6 pr-12 rounded-2xl text-xs font-black uppercase tracking-widest text-primary focus:outline-none fluid-shadow">
              <option value="">Any Club</option>
              {clubs.map((c: any) => <option value={c.id}>{c.name}</option>)}
            </select>
            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-primary pointer-events-none text-xl">expand_more</span>
          </div>
          
          <div class="relative flex-shrink-0">
            <select class="appearance-none w-48 bg-surface-container-lowest py-4 pl-6 pr-12 rounded-2xl text-xs font-black uppercase tracking-widest text-primary focus:outline-none fluid-shadow">
              <option value="">Any Category</option>
              <option value="service">Service</option>
              <option value="professional">Professional</option>
              <option value="social">Social</option>
            </select>
            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-primary pointer-events-none text-xl">expand_more</span>
          </div>

          <div class="flex bg-surface-container-high p-1.5 rounded-2xl">
            <button type="button" class="bg-surface-container-lowest text-primary shadow-lg px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest flex items-center gap-2">
              <span class="material-symbols-outlined text-lg">grid_view</span>
              Grid
            </button>
            <button type="button" class="text-on-surface-variant hover:text-primary px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all flex items-center gap-2">
              <span class="material-symbols-outlined text-lg">list</span>
              List
            </button>
          </div>
        </form>

        <!-- Mobile Filters (Simplified) -->
        <div class="lg:hidden flex items-center gap-4">
          <div class="flex-grow relative">
            <input type="text" placeholder="Search..." class="w-full pl-12 pr-4 py-3.5 bg-surface-container-lowest rounded-xl text-sm font-bold focus:outline-none fluid-shadow" />
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-primary opacity-40">search</span>
          </div>
          <button class="bg-surface-container-high p-3.5 rounded-xl text-primary shrink-0">
            <span class="material-symbols-outlined">tune</span>
          </button>
        </div>
      </div>
    </section>

    <section class="py-24 bg-surface px-6 lg:px-12 min-h-screen">
      <div class="max-w-screen-2xl mx-auto">
        <div class="flex items-center justify-between mb-16">
          <div class="space-y-1">
            <h2 class="text-4xl font-black text-primary font-headline tracking-tighter">Upcoming Initiatives</h2>
            <p class="text-on-surface-variant font-medium opacity-50 uppercase tracking-widest text-[10px]">{upcomingEvents.length} Events on Horizon</p>
          </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
          {upcomingEvents.map((event: any, index: number) => (
            <div class={`bg-surface-container-lowest rounded-[2.5rem] overflow-hidden fluid-shadow hover:translate-y-[-8px] transition-all duration-500 group flex flex-col fade-in-up`} style={`animation-delay: ${0.05 * index}s`}>
              
              <div class="h-64 overflow-hidden relative">
                <img src={event.banner_url} alt={event.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" />
                <div class="absolute inset-0 bg-gradient-to-t from-primary/60 to-transparent mix-blend-multiply"></div>
                
                <div class="absolute top-6 left-6 flex gap-3">
                  <span class={`text-[9px] font-black uppercase tracking-[0.2em] px-4 py-2 rounded-xl text-white backdrop-blur-xl border border-white/20
                    ${event.type ==='service' ? 'bg-green-500/40' : event.type==='professional' ? 'bg-primary/40' : 'bg-pink-500/40'}`}>
                    {event.type}
                  </span>
                </div>
                
                <div class="absolute bottom-6 left-8 text-white">
                  <p class="text-5xl font-black leading-none font-headline tracking-tighter drop-shadow-md">{new Date(event.start_at).getDate()}</p>
                  <p class="text-[10px] font-black uppercase tracking-[0.4em] drop-shadow-md opacity-80">{new Date(event.start_at).toLocaleDateString('en-US', {month: 'short'})}</p>
                </div>

                <div class="absolute bottom-6 right-8">
                  <div class="bg-surface-container-lowest/90 backdrop-blur-md px-4 py-2 rounded-xl shadow-2xl">
                    <span class="text-[8px] font-black uppercase tracking-widest text-primary">
                      {event.is_free ? 'Complimentary' : 'Reserved Access'}
                    </span>
                  </div>
                </div>
              </div>
              
              <div class="p-10 flex-grow flex flex-col space-y-6">
                <div class="space-y-4">
                  <div class="flex items-center gap-3">
                    <img src={`https://ui-avatars.com/api/?name=${event.club_name.replace(/ /g, '+')}&background=174174&color=fff`} class="w-6 h-6 rounded-full border border-primary/10" />
                    <span class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest opacity-40">{event.club_name}</span>
                  </div>
                  
                  <h3 class="text-3xl font-black text-primary group-hover:text-primary-container transition-colors font-headline tracking-tighter line-clamp-2">{event.title}</h3>
                  
                  <div class="flex items-start gap-3 pt-2">
                    <span class="material-symbols-outlined text-primary opacity-30 text-xl">location_on</span>
                    <span class="text-on-surface-variant font-bold text-sm opacity-70 line-clamp-2 leading-relaxed">{event.venue}</span>
                  </div>
                </div>
                
                <div class="mt-auto pt-8">
                  <a href={`/events/${event.slug}`} class="block w-full text-center bg-surface-container-high hover:bg-primary text-primary hover:text-white font-black py-5 rounded-2xl transition-all shadow-sm text-xs uppercase tracking-widest">
                    Secure Spot
                  </a>
                </div>
              </div>
              
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 48px -12px rgba(13, 65, 116, 0.06);
  }
</style>


</Layout>
