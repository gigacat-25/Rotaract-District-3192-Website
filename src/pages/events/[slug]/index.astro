---
import Layout from '../../../layouts/Layout.astro';
import eventsData from '../../../mock/events.json';

export async function getStaticPaths() {
  const events = eventsData;
  return events.map((event: any) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
---

<Layout title={event.title}>
  
  <header class="relative bg-black pt-32 pb-24 md:pb-32 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={event.banner_url} alt="" class="w-full h-full object-cover opacity-40 blur-sm transform scale-105" />
      <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/80 to-black/60"></div>
    </div>
    
    <div class="container mx-auto px-4 lg:px-8 max-w-4xl relative z-10">
      <a href="/events" class="inline-flex items-center text-sm font-semibold text-gray-300 hover:text-white mb-6 transition-colors bg-gray-800/50 backdrop-blur-md px-4 py-1.5 rounded-full border border-gray-700">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to Events
      </a>
      
      <div class="flex gap-2 mb-4">
        <span class="bg-[#F5A623] text-[#003F8A] text-xs font-black uppercase tracking-widest px-3 py-1 rounded shadow-lg">{event.type}</span>
        {event.status === 'past' && <span class="bg-gray-700 text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded shadow-lg">Past Event</span>}
      </div>
      
      <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6 tracking-tight leading-[1.1]">{event.title}</h1>
      
      <div class="flex flex-wrap items-center gap-6 text-base text-gray-300 font-medium">
        <div class="flex items-center">
          <div class="w-10 h-10 rounded-full bg-[#003F8A] flex items-center justify-center mr-3 border-2 border-white/20">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          </div>
          <div>
            <p class="text-white font-bold">{new Date(event.start_at).toLocaleDateString('en-IN', {weekday:'short', month: 'long', day: 'numeric', year: 'numeric'})}</p>
            <p class="text-sm">{new Date(event.start_at).toLocaleTimeString('en-IN', {hour: '2-digit', minute: '2-digit'})} IST</p>
          </div>
        </div>
        
        <div class="flex items-center">
          <div class="w-10 h-10 rounded-full bg-[#003F8A] flex items-center justify-center mr-3 border-2 border-white/20">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <div>
            <p class="text-white font-bold max-w-[200px] truncate">{event.venue}</p>
            {event.maps_url && <a href={event.maps_url} target="_blank" class="text-[#F5A623] hover:text-white text-sm transition-colors border-b border-[#F5A623]/50 pb-0.5">View Map</a>}
          </div>
        </div>
      </div>
      
    </div>
  </header>

  <section class="py-12 bg-white relative z-20">
    <div class="container mx-auto px-4 lg:px-8 max-w-4xl -mt-20 md:-mt-28">
      
      <div class="bg-white rounded-3xl p-6 md:p-10 card-shadow border border-gray-100 flex flex-col md:flex-row gap-10">
        
        <!-- Description -->
        <div class="md:w-2/3">
          <h2 class="text-xl font-bold text-gray-900 mb-4 border-b border-gray-200 pb-3">About the Event</h2>
          <div class="prose prose-lg text-gray-600 leading-relaxed font-light mb-8">
            <p>{event.description}</p>
          </div>
          
          <div class="bg-gray-50 rounded-2xl p-4 border border-gray-200 flex items-center mt-8">
            <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm border border-gray-100 mr-4">
              <svg class="w-6 h-6 text-[#003F8A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <div>
              <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Hosted By</p>
              <h4 class="font-bold text-gray-900">{event.club_name}</h4>
            </div>
          </div>
        </div>

        <!-- Registration Card -->
        <div class="md:w-1/3">
          <div class="bg-[#003F8A] text-white rounded-2xl p-6 shadow-xl sticky top-24">
            <h3 class="text-lg font-bold mb-4">Tickets & Registration</h3>
            
            <div class="space-y-3 mb-6">
              {event.ticket_tiers.map((tier: any) => (
                <div class="bg-white/10 rounded-xl p-3 border border-white/20 flex justify-between items-center">
                  <div>
                    <h4 class="font-bold text-sm text-white">{tier.name}</h4>
                    <p class="text-xs text-blue-200">{tier.capacity} Available</p>
                  </div>
                  <div class="text-right">
                    <span class="font-black text-[#F5A623]">{tier.price === 0 ? 'FREE' : `₹${tier.price}`}</span>
                  </div>
                </div>
              ))}
            </div>
            
            {event.status === 'published' ? (
              <a href={`/events/${event.slug}/register`} class="block w-full text-center bg-[#F5A623] hover:bg-white text-[#003F8A] font-extrabold py-3.5 rounded-xl transition-all hover:scale-105 shadow-md">
                Register Now
              </a>
            ) : (
              <button disabled class="w-full text-center bg-gray-700 text-gray-400 font-bold py-3.5 rounded-xl cursor-not-allowed">
                Event Closed
              </button>
            )}
            
            <div class="mt-6 pt-4 border-t border-white/20 flex justify-center space-x-3">
              <span class="text-xs text-blue-200 font-medium">Share:</span>
              <a href="#" class="text-white hover:text-[#F5A623]"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg></a>
              <a href="#" class="text-white hover:text-[#F5A623]"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg></a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
