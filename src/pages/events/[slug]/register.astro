---
// Mock data import
import Layout from '../../../layouts/Layout.astro';
import eventsData from '../../../mock/events.json';

export async function getStaticPaths() {
  const events = eventsData;
  return events.map((event: any) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
---

<Layout title={`Register - ${event.title}`}>
  
  <main class="pt-20">
    <header class="bg-surface-container-low border-b border-outline-variant/30 py-20 px-6 lg:px-12">
      <div class="container mx-auto max-w-screen-2xl flex flex-col md:flex-row md:items-center justify-between gap-8">
        <div class="space-y-4">
          <a href={`/events/${event.slug}`} class="inline-flex items-center gap-3 text-[10px] font-black text-primary uppercase tracking-widest bg-white/50 backdrop-blur-md px-5 py-2.5 rounded-full border border-primary/5 hover:bg-primary hover:text-white transition-all">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            Return to Event
          </a>
          <h1 class="text-4xl md:text-6xl font-black text-primary font-headline tracking-tighter uppercase leading-none">Admission Checkout</h1>
        </div>
        <div class="hidden md:block text-right">
          <p class="text-[10px] font-black text-primary uppercase tracking-[0.4em] opacity-40">System Timestamp</p>
          <p class="text-xl font-black text-primary font-headline tracking-tight uppercase leading-none">{new Date().toLocaleDateString('en-IN')}</p>
        </div>
      </div>
    </header>

    <section class="py-24 bg-surface px-6 lg:px-12 min-h-screen">
      <div class="max-w-screen-2xl mx-auto flex flex-col lg:grid lg:grid-cols-12 gap-20">
        
        <!-- Registration Form -->
        <div class="lg:col-span-8 space-y-12">
          <form class="space-y-16">
            <div class="space-y-10">
              <div class="space-y-2">
                <span class="text-primary font-black text-[10px] tracking-[.4em] uppercase opacity-40">Verification</span>
                <h2 class="text-4xl font-black text-primary tracking-tighter font-headline uppercase leading-none">Identity Capture</h2>
              </div>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
                <div class="space-y-4">
                  <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-primary/50 ml-2">Family Name</label>
                  <input type="text" class="w-full bg-surface-container-low border border-outline-variant/30 rounded-2xl p-6 text-primary font-bold focus:outline-none focus:ring-4 focus:ring-primary/5 transition-all" placeholder="Enter first name">
                </div>
                <div class="space-y-4">
                  <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-primary/50 ml-2">Given Name</label>
                  <input type="text" class="w-full bg-surface-container-low border border-outline-variant/30 rounded-2xl p-6 text-primary font-bold focus:outline-none focus:ring-4 focus:ring-primary/5 transition-all" placeholder="Enter last name">
                </div>
              </div>
              
              <div class="space-y-4">
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-primary/50 ml-2">Digital Address</label>
                <input type="email" class="w-full bg-surface-container-low border border-outline-variant/30 rounded-2xl p-6 text-primary font-bold focus:outline-none focus:ring-4 focus:ring-primary/5 transition-all" placeholder="name@domain.com">
              </div>
              
              <div class="space-y-4">
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-primary/50 ml-2">Pulse Contact</label>
                <input type="tel" class="w-full bg-surface-container-low border border-outline-variant/30 rounded-2xl p-6 text-primary font-bold focus:outline-none focus:ring-4 focus:ring-primary/5 transition-all" placeholder="+91 00000 00000">
              </div>
            </div>
            
            <div class="space-y-10 pt-10 border-t border-primary/5">
              <div class="space-y-2">
                <span class="text-primary font-black text-[10px] tracking-[.4em] uppercase opacity-40">Selection</span>
                <h2 class="text-4xl font-black text-primary tracking-tighter font-headline uppercase leading-none">Select Radius</h2>
              </div>

              <div class="grid gap-6">
                {event.ticket_tiers.map((tier: any, idx: number) => (
                  <label class={`flex items-center justify-between p-8 rounded-[2rem] cursor-pointer transition-all border ${idx === 0 ? 'bg-primary text-on-primary border-primary fluid-shadow' : 'bg-surface-container-low border-outline-variant/30 hover:bg-surface-container-lowest'}`}>
                    <div class="flex items-center gap-6">
                      <div class={`w-6 h-6 rounded-full border-2 flex items-center justify-center transition-all ${idx === 0 ? 'bg-white border-white text-primary' : 'border-primary/20'}`}>
                        {idx === 0 && <span class="material-symbols-outlined text-sm font-black">check</span>}
                        <input type="radio" name="ticket_tier" value={tier.id} checked={idx === 0} class="hidden">
                      </div>
                      <div class="space-y-1">
                        <span class="block font-black text-xl font-headline tracking-tight uppercase leading-none">{tier.name}</span>
                        <span class={`text-[9px] font-black uppercase tracking-widest opacity-60 ${idx === 0 ? 'text-white' : 'text-primary'}`}>Access Guaranteed</span>
                      </div>
                    </div>
                    <span class="text-2xl font-black font-headline tracking-tighter">{tier.price === 0 ? 'Free' : `₹${tier.price}`}</span>
                  </label>
                ))}
              </div>
            </div>

          </form>
        </div>
        
        <!-- Order Summary -->
        <div class="lg:col-span-4">
          <div class="bg-surface-container-low rounded-[3rem] p-12 space-y-10 fluid-shadow border border-outline-variant/30 sticky top-32">
            <div class="space-y-2 text-center">
              <h3 class="text-[10px] font-black text-primary uppercase tracking-[0.3em] opacity-40">Manifest</h3>
              <p class="text-3xl font-black text-primary font-headline tracking-tighter uppercase leading-none">Admission List</p>
            </div>
            
            <div class="flex items-center gap-6 p-6 bg-surface-container-lowest rounded-[2rem] fluid-shadow">
              <img src={event.banner_url} class="w-20 h-20 rounded-2xl object-cover shrink-0 grayscale hover:grayscale-0 transition-all duration-700" />
              <div class="space-y-1 overflow-hidden">
                <h4 class="font-black text-primary font-headline tracking-tight truncate leading-none">{event.title}</h4>
                <p class="text-[10px] font-black text-primary/40 uppercase tracking-widest">{new Date(event.start_at).toLocaleDateString('en-IN')}</p>
              </div>
            </div>
            
            <div class="space-y-6 font-bold text-xs text-primary uppercase tracking-widest opacity-80">
              <div class="flex justify-between items-center">
                <span>Base Tier</span>
                <span class="font-black text-base font-headline tracking-tighter">{event.ticket_tiers[0].price === 0 ? '₹0' : `₹${event.ticket_tiers[0].price}`}</span>
              </div>
              <div class="flex justify-between items-center text-primary/30">
                <span>Infrastructure Levy</span>
                <span class="font-black">₹0</span>
              </div>
              <div class="pt-6 border-t border-primary/5 flex justify-between items-center">
                <span class="text-primary font-black">Final Grant</span>
                <span class="text-4xl font-black text-primary font-headline tracking-tighter">{event.ticket_tiers[0].price === 0 ? 'Free' : `₹${event.ticket_tiers[0].price}`}</span>
              </div>
            </div>
            
            <div class="pt-4">
              <button class="w-full aqueous-gradient text-on-primary px-10 py-6 rounded-2xl font-black uppercase tracking-[0.2em] text-[11px] shadow-2xl shadow-primary/30 hover:translate-y-[-2px] transition-all">
                {event.is_free ? 'Confirm Identity' : 'Process Grant (Razorpay)'}
              </button>
            </div>
            
            <p class="text-[9px] text-primary font-black uppercase tracking-[0.25em] text-center opacity-30 leading-relaxed px-4">
              Authorization imply full acceptance of Protocol 3192 Governance.
            </p>
          </div>
        </div>
        
      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>

