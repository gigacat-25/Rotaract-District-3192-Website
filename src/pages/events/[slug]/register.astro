---
// Mock data import
import Layout from '../../../layouts/Layout.astro';
import eventsData from '../../../mock/events.json';

export async function getStaticPaths() {
  const events = eventsData;
  return events.map((event: any) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
---

<Layout title={`Register - ${event.title}`}>
  
  <header class="bg-gray-50 border-b border-gray-200 py-12">
    <div class="container mx-auto px-4 max-w-4xl flex items-center">
      <a href={`/events/${event.slug}`} class="text-sm font-semibold text-gray-500 hover:text-[#003F8A] mr-4 transition-colors">
        ← Back
      </a>
      <h1 class="text-2xl font-bold text-gray-900 border-l border-gray-300 pl-4">{event.title} - Checkout</h1>
    </div>
  </header>

  <section class="py-12 bg-white min-h-[60vh]">
    <div class="container mx-auto px-4 max-w-4xl flex flex-col md:flex-row gap-8">
      
      <!-- Registration Form -->
      <div class="md:w-2/3">
        <form class="space-y-6 bg-white p-8 rounded-3xl border border-gray-200 card-shadow">
          <h2 class="text-xl font-bold text-gray-900 mb-6">Attendee Details</h2>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="block text-sm font-semibold text-gray-700">First Name</label>
              <input type="text" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#003F8A]/50 focus:border-[#003F8A] transition-colors" placeholder="John">
            </div>
            <div class="space-y-2">
              <label class="block text-sm font-semibold text-gray-700">Last Name</label>
              <input type="text" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#003F8A]/50 focus:border-[#003F8A] transition-colors" placeholder="Doe">
            </div>
          </div>
          
          <div class="space-y-2">
            <label class="block text-sm font-semibold text-gray-700">Email Address</label>
            <input type="email" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#003F8A]/50 focus:border-[#003F8A] transition-colors" placeholder="john@example.com">
          </div>
          
          <div class="space-y-2">
            <label class="block text-sm font-semibold text-gray-700">Phone / WhatsApp</label>
            <input type="tel" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#003F8A]/50 focus:border-[#003F8A] transition-colors" placeholder="+91 90000 00000">
          </div>
          
          <div class="space-y-3 pt-6">
            <label class="block text-sm font-semibold text-gray-700">Select Ticket Tier</label>
            {event.ticket_tiers.map((tier: any, idx: number) => (
              <label class={`flex items-center justify-between p-4 border rounded-xl cursor-pointer transition-all ${idx === 0 ? 'border-[#003F8A] bg-blue-50 ring-1 ring-[#003F8A]' : 'border-gray-200 hover:border-gray-300'}`}>
                <div class="flex items-center">
                  <input type="radio" name="ticket_tier" value={tier.id} checked={idx === 0} class="w-5 h-5 text-[#003F8A] border-gray-300 focus:ring-[#003F8A]">
                  <div class="ml-3">
                    <span class="block font-bold text-gray-900">{tier.name}</span>
                  </div>
                </div>
                <span class="font-bold text-gray-900">{tier.price === 0 ? 'FREE' : `₹${tier.price}`}</span>
              </label>
            ))}
          </div>

        </form>
      </div>
      
      <!-- Order Summary -->
      <div class="md:w-1/3">
        <div class="bg-gray-50 rounded-3xl p-6 border border-gray-200 sticky top-24">
          <h3 class="text-xl font-bold text-gray-900 mb-6">Order Summary</h3>
          
          <div class="flex items-start mb-6 pb-6 border-b border-gray-200">
            <img src={event.banner_url} class="w-16 h-16 rounded-xl object-cover mr-4 shadow-sm" />
            <div>
              <h4 class="font-bold text-gray-900 text-sm leading-tight mb-1">{event.title}</h4>
              <p class="text-xs text-gray-500">{new Date(event.start_at).toLocaleDateString('en-IN')}</p>
            </div>
          </div>
          
          <div class="space-y-3 mb-6 font-medium text-sm text-gray-600">
            <div class="flex justify-between">
              <span>{event.ticket_tiers[0].name}</span>
              <span>{event.ticket_tiers[0].price === 0 ? '₹0' : `₹${event.ticket_tiers[0].price}`}</span>
            </div>
            <div class="flex justify-between">
              <span>Taxes & Fees</span>
              <span>₹0</span>
            </div>
            <div class="flex justify-between text-lg font-bold text-gray-900 pt-3 border-t border-gray-200">
              <span>Total</span>
              <span>{event.ticket_tiers[0].price === 0 ? 'FREE' : `₹${event.ticket_tiers[0].price}`}</span>
            </div>
          </div>
          
          <a href="#" class="block w-full text-center bg-[#003F8A] hover:bg-[#002f6c] text-white font-bold py-3.5 rounded-xl transition-all shadow-md hover:shadow-lg">
            {event.is_free ? 'Confirm Registration' : 'Pay Now (Razorpay)'}
          </a>
          <p class="text-[10px] text-gray-400 text-center mt-4">By registering, you agree to our Terms of Service & Privacy Policy.</p>
        </div>
      </div>
      
    </div>
  </section>

</Layout>
