---
import Layout from '../../../layouts/Layout.astro';
import eventsData from '../../../mock/events.json';

export async function getStaticPaths() {
  const events = eventsData;
  return events.map((event: any) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;

// Mock data for check-in lists
const checkedIn = [
  { name: "Priya Sharma", time: "08:45 AM", method: "SIG-QR" },
  { name: "Arjun Kumar", time: "08:52 AM", method: "SIG-QR" },
  { name: "Vikram Singh", time: "09:05 AM", method: "MANUAL-O" },
];

const stats = {
  total: 150,
  checked: 34,
  percent: Math.round((34/150)*100)
};
---

<Layout title={`Verification Node - ${event.title}`}>
  <main class="min-h-screen bg-surface flex flex-col xl:flex-row overflow-hidden pt-20">
    
    <!-- LEFT: SCANNER NODE (CORE) -->
    <div class="w-full xl:w-3/5 bg-primary relative flex flex-col items-center justify-center p-12 lg:p-24 min-h-[60vh] xl:min-h-screen border-r border-white/5 overflow-hidden">
      
      <!-- Ambient effects -->
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 left-0 w-full h-full aqueous-gradient opacity-10 blur-3xl rounded-full scale-150"></div>
        <div class="absolute -bottom-1/2 -right-1/4 w-full h-full bg-white/5 blur-3xl rounded-full"></div>
      </div>

      <div class="absolute top-12 left-12 z-20">
        <a href={`/events/${event.slug}`} class="flex items-center gap-4 text-[10px] font-black uppercase tracking-[0.4em] text-white/40 hover:text-white transition-all group">
          <span class="material-symbols-outlined text-lg group-hover:translate-x-[-4px] transition-transform">arrow_back</span>
          Terminate / Node Exit
        </a>
      </div>

      <div class="text-center space-y-4 mb-16 relative z-10">
        <span class="inline-block px-5 py-2 rounded-full bg-white/10 text-white text-[9px] font-black tracking-[0.3em] uppercase border border-white/10">Active Authorization</span>
        <h1 class="text-4xl md:text-6xl font-black text-white tracking-tighter font-headline uppercase italic leading-none">{event.title}</h1>
        <p class="text-[11px] text-white/40 font-medium uppercase tracking-[0.4em] italic">Optical verification protocol initialized.</p>
      </div>

      <!-- High-Tech Scanner Frame -->
      <div class="relative w-full max-w-md aspect-square bg-black/40 backdrop-blur-2xl border-4 border-white/10 rounded-[4rem] overflow-hidden shadow-[0_0_100px_rgba(0,0,0,0.5)] group/scanner">
        <!-- Laser protocol -->
        <div class="absolute top-0 left-0 w-full h-1.5 bg-white shadow-[0_0_30px_rgba(255,255,255,0.8)] animate-[laser_3s_infinite_alternate] z-20"></div>
        
        <!-- Frame Markers -->
        <div class="absolute top-10 left-10 w-12 h-12 border-t-2 border-l-2 border-white/40 rounded-tl-3xl"></div>
        <div class="absolute top-10 right-10 w-12 h-12 border-t-2 border-r-2 border-white/40 rounded-tr-3xl"></div>
        <div class="absolute bottom-10 left-10 w-12 h-12 border-b-2 border-l-2 border-white/40 rounded-bl-3xl"></div>
        <div class="absolute bottom-10 right-10 w-12 h-12 border-b-2 border-r-2 border-white/40 rounded-br-3xl"></div>

        <div class="flex flex-col items-center justify-center w-full h-full space-y-6">
          <div class="w-32 h-32 rounded-full bg-white/5 border border-white/10 flex items-center justify-center animate-pulse">
             <span class="material-symbols-outlined text-6xl text-white/20">qr_code_scanner</span>
          </div>
          <p class="text-[10px] font-black text-white/30 uppercase tracking-[0.5em] italic">Awaiting Digital Signal...</p>
        </div>
        
        <div class="absolute inset-0 aqueous-gradient opacity-0 group-hover/scanner:opacity-5 transition-opacity duration-1000"></div>
      </div>
      
      <button class="mt-12 w-16 h-16 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white hover:bg-white/10 active:scale-95 transition-all shadow-xl backdrop-blur-md">
        <span class="material-symbols-outlined text-2xl">flip_camera_ios</span>
      </button>

    </div>

    <!-- RIGHT: MANIFEST & ANALYTICS -->
    <div class="w-full xl:w-2/5 p-10 lg:p-16 flex flex-col max-h-screen overflow-y-auto custom-scrollbar space-y-12">
      
      <div class="space-y-10">
        <div class="space-y-4">
           <h2 class="text-3xl font-black text-primary font-headline tracking-tighter uppercase italic leading-none">Manual Ingress</h2>
           <div class="relative group">
             <input type="text" placeholder="Identify Node (Name, UID, Email)..." class="w-full bg-surface-container-low border border-outline-variant/30 text-primary rounded-2xl py-6 pl-16 pr-6 font-bold focus:ring-4 focus:ring-primary/5 focus:outline-none transition-all placeholder-primary/20 uppercase text-xs tracking-widest">
             <span class="material-symbols-outlined absolute left-6 top-1/2 -translate-y-1/2 text-primary opacity-30 group-focus-within:opacity-100 transition-opacity">search</span>
           </div>
        </div>

        <div class="grid grid-cols-2 gap-8">
          <div class="bg-surface-container-low rounded-[2rem] p-8 border border-outline-variant/30 fluid-shadow space-y-2">
            <p class="text-[9px] font-black text-on-surface-variant/40 uppercase tracking-[.4em] italic">Current Load</p>
            <p class="text-5xl font-black text-primary font-headline tracking-tighter leading-none italic">{stats.checked}<span class="text-xl text-primary/20 ml-2">/ {stats.total}</span></p>
          </div>
          <div class="aqueous-gradient rounded-[2rem] p-8 border border-primary/10 shadow-2xl space-y-2">
            <p class="text-[9px] font-black text-on-primary/60 uppercase tracking-[.4em] italic">Efficiency</p>
            <p class="text-5xl font-black text-on-primary font-headline tracking-tighter leading-none italic">{stats.percent}%</p>
          </div>
        </div>
      </div>

      <div class="space-y-8 flex-grow">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-black text-primary font-headline tracking-tighter uppercase italic">Recent Transmissions</h2>
          <div class="flex items-center gap-2">
             <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
             <span class="text-[8px] font-black text-green-600 uppercase tracking-widest italic">Live Sync Active</span>
          </div>
        </div>
        
        <div class="space-y-4">
          {checkedIn.map(record => (
            <div class="bg-surface-container-low rounded-[2rem] p-8 border border-outline-variant/30 flex justify-between items-center hover:bg-surface-container-lowest transition-all group cursor-default">
              <div class="flex items-center gap-6">
                <div class="w-14 h-14 rounded-2xl bg-green-500/5 border border-green-500/10 text-green-500 flex items-center justify-center group-hover:scale-110 transition-transform">
                  <span class="material-symbols-outlined text-2xl">verified_user</span>
                </div>
                <div class="space-y-1">
                  <p class="text-lg font-black text-primary font-headline uppercase leading-none tracking-tight">{record.name}</p>
                  <div class="flex items-center gap-4 text-[9px] font-black text-on-surface-variant/40 uppercase tracking-widest italic">
                    <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-xs">schedule</span> {record.time}</span>
                    <span class="px-2 py-0.5 rounded bg-primary/5 text-primary/40 border border-primary/10">{record.method}</span>
                  </div>
                </div>
              </div>
              <span class="material-symbols-outlined text-primary/10 group-hover:opacity-100 transition-opacity">more_vert</span>
            </div>
          ))}
        </div>
      </div>
      
    </div>
  </main>

  <style>
    @keyframes laser {
      0% { top: 0; }
      100% { top: 100%; }
    }
    .fluid-shadow {
      box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
    }
    .custom-scrollbar::-webkit-scrollbar {
      width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: rgba(13, 65, 116, 0.1);
      border-radius: 10px;
    }
  </style>
</Layout>

