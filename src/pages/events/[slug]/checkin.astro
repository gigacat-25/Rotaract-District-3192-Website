---
import Layout from '../../../layouts/Layout.astro';
import eventsData from '../../../mock/events.json';

export async function getStaticPaths() {
  const events = eventsData;
  return events.map((event: any) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;

// Mock data for check-in lists
const checkedIn = [
  { name: "Priya Sharma", time: "08:45 AM", method: "qr" },
  { name: "Arjun Kumar", time: "08:52 AM", method: "qr" },
  { name: "Vikram Singh", time: "09:05 AM", method: "manual" },
];

const stats = {
  total: 150,
  checked: 34,
  percent: Math.round((34/150)*100)
};
---

<Layout title={`Scanner - ${event.title}`}>
  
  <div class="min-h-screen bg-gray-900 text-white flex flex-col md:flex-row">
    
    <!-- Left Column: Scanner -->
    <div class="w-full md:w-1/2 lg:w-3/5 bg-black relative flex flex-col items-center justify-center p-8 min-h-[50vh] md:min-h-screen border-b md:border-b-0 md:border-r border-gray-800">
      
      <div class="absolute top-8 left-8">
        <a href={`/events/${event.slug}`} class="text-sm font-bold uppercase tracking-widest text-[#F5A623] hover:text-white transition-colors">
          &larr; Exit Scanner
        </a>
      </div>

      <div class="text-center mb-8 mt-16 md:mt-0">
        <span class="bg-[#003F8A] text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest mb-4 inline-block">Organiser View</span>
        <h1 class="text-3xl font-bold mb-2">{event.title}</h1>
        <p class="text-gray-400 text-sm font-medium">Verify tickets by scanning QR codes</p>
      </div>

      <!-- Scanner Mock UI -->
      <div class="relative w-72 h-72 sm:w-96 sm:h-96 md:w-[400px] md:h-[400px] bg-gray-900 border-2 border-gray-700 rounded-3xl overflow-hidden shadow-2xl">
        <!-- Scanning animation bar -->
        <div class="absolute top-0 left-0 w-full h-1 bg-[#F5A623] shadow-[0_0_15px_#F5A623] animate-[scan_2s_ease-in-out_infinite]"></div>
        
        <!-- Corner markers -->
        <div class="absolute top-4 left-4 w-8 h-8 border-t-4 border-l-4 border-white/50 rounded-tl-lg"></div>
        <div class="absolute top-4 right-4 w-8 h-8 border-t-4 border-r-4 border-white/50 rounded-tr-lg"></div>
        <div class="absolute bottom-4 left-4 w-8 h-8 border-b-4 border-l-4 border-white/50 rounded-bl-lg"></div>
        <div class="absolute bottom-4 right-4 w-8 h-8 border-b-4 border-r-4 border-white/50 rounded-br-lg"></div>

        <div class="flex flex-col items-center justify-center w-full h-full text-gray-500 opacity-60">
          <svg class="w-16 h-16 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          <p class="font-medium text-sm">Camera Feed Placeholder</p>
        </div>
      </div>
      
      <div class="mt-8 flex space-x-4">
        <button class="bg-white/10 hover:bg-white/20 border border-white/20 text-white p-3 rounded-full transition-colors" title="Switch Camera">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
        </button>
      </div>

    </div>

    <!-- Right Column: List & Manual -->
    <div class="w-full md:w-1/2 lg:w-2/5 p-6 md:p-8 flex flex-col max-h-screen overflow-y-auto">
      
      <div class="mb-8">
        <h2 class="text-xl font-bold mb-4">Manual Look-up</h2>
        <div class="relative">
          <input type="text" placeholder="Search by Name, Email, or Ticket ID..." class="w-full bg-gray-800 border border-gray-700 text-white rounded-xl py-3 pl-10 pr-4 focus:ring-2 focus:ring-[#F5A623] focus:border-[#F5A623] focus:outline-none transition-all placeholder-gray-500">
          <svg class="w-5 h-5 text-gray-500 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-8">
        <div class="bg-gray-800 rounded-2xl p-4 border border-gray-700">
          <p class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">Checked In</p>
          <p class="text-3xl font-black text-white">{stats.checked} <span class="text-lg font-medium text-gray-500">/ {stats.total}</span></p>
        </div>
        <div class="bg-[#003F8A] rounded-2xl p-4 border border-[#0056b3]">
          <p class="text-xs text-blue-200 font-bold uppercase tracking-widest mb-1">Fill Rate</p>
          <p class="text-3xl font-black text-white">{stats.percent}%</p>
        </div>
      </div>

      <div class="flex-grow">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold">Recent Scans</h2>
          <span class="text-xs font-semibold text-green-400 bg-green-400/10 px-2 py-1 rounded">Live Sync</span>
        </div>
        
        <ul class="space-y-3">
          {checkedIn.map(record => (
            <li class="bg-gray-800 rounded-xl p-4 border border-gray-700 flex justify-between items-center hover:border-gray-600 transition-colors cursor-default">
              <div class="flex items-center">
                <div class="w-10 h-10 rounded-full bg-green-500/20 text-green-500 flex items-center justify-center mr-3">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <div>
                  <p class="font-bold text-sm text-white">{record.name}</p>
                  <div class="flex items-center text-xs text-gray-400 mt-0.5">
                    <span>{record.time}</span>
                    <span class="mx-1.5">•</span>
                    <span class="uppercase text-[9px] font-bold tracking-wider">{record.method}</span>
                  </div>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>
      
    </div>
  </div>
  
  <style>
    @keyframes scan {
      0% { transform: translateY(0); opacity: 0; }
      5% { opacity: 1; }
      95% { opacity: 1; }
      100% { transform: translateY(396px); opacity: 0; } /* Matches container height roughly */
    }
  </style>

</Layout>
