---
import Layout from '../../../layouts/Layout.astro';
import clubsData from '../../../mock/clubs.json';
import eventsData from '../../../mock/events.json';

export async function getStaticPaths() {
  const clubs = clubsData;
  return clubs.map((club: any) => ({
    params: { slug: club.slug },
    props: { club },
  }));
}

const { club } = Astro.props;
const clubEvents = eventsData.filter((e: any) => e.club_id === club.id && e.status === 'published').slice(0,3);
---

<Layout title={club.name} clubColor={club.theme_color}>
  
  <!-- DYNAMIC CLUB HERO -->
  <header class="relative bg-gray-900 text-white pb-12 pt-32 md:pt-48 overflow-hidden rounded-b-3xl">
    <div class="absolute inset-0 z-0">
      <img src={club.cover_url} alt="" class="w-full h-full object-cover opacity-40 mix-blend-overlay" />
      <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/60 to-transparent"></div>
    </div>
    
    <div class="container mx-auto px-4 lg:px-8 max-w-5xl relative z-10 flex flex-col md:flex-row md:items-end gap-6 md:gap-10">
      <div class="w-32 h-32 md:w-40 md:h-40 bg-white rounded-3xl p-2 shadow-2xl border-4 border-white shrink-0 -mb-20 md:-mb-16 z-20">
        <img src={club.logo_url} alt={club.name} class="w-full h-full object-contain rounded-2xl" />
      </div>
      
      <div class="flex-grow pb-4 md:pb-0 pt-16 md:pt-0">
        <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-2 flex items-center flex-wrap gap-3">
          {club.name}
          {club.status === 'inactive' && <span class="text-xs bg-red-500/20 text-red-200 border border-red-500/30 px-3 py-1 rounded-full uppercase tracking-widest font-bold">Inactive</span>}
        </h1>
        <div class="flex flex-wrap items-center gap-4 text-sm font-medium text-gray-300">
          <span class="flex items-center"><svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>{club.city}</span>
          <span class="w-1 h-1 rounded-full bg-gray-500"></span>
          <span>Chartered: {new Date(club.charter_date).toLocaleDateString('en-IN', {year: 'numeric', month: 'short'})}</span>
          <span class="w-1 h-1 rounded-full bg-gray-500"></span>
          <span class="flex items-center"><svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>{club.member_count} Active Members</span>
        </div>
      </div>
      
      <div class="flex gap-3 pb-4 md:pb-0 shrink-0">
        <a href="#contact" class="bg-white text-gray-900 font-bold px-6 py-2.5 rounded-full hover:bg-gray-100 transition-colors shadow-lg">Contact Us</a>
      </div>
    </div>
  </header>

  <!-- CONTENT -->
  <section class="py-24 bg-white relative z-10 pt-32 md:pt-24">
    <div class="container mx-auto px-4 lg:px-8 max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        
        <!-- Main Column -->
        <div class="lg:col-span-2 space-y-12">
          
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center">
              <span class="w-8 h-1 mr-4 rounded-full" style={`background-color: ${club.theme_color}`}></span>
              About the Club
            </h2>
            <div class="prose prose-lg text-gray-600 leading-relaxed font-light">
              <p>{club.about}</p>
            </div>
          </div>

          <!-- Upcoming Events -->
          {clubEvents.length > 0 && (
            <div>
              <div class="flex items-center justify-between mb-6 border-b border-gray-100 pb-4">
                <h2 class="text-2xl font-bold text-gray-900">Upcoming Events</h2>
                <a href={`/clubs/${club.slug}/events`} class="text-sm font-bold uppercase tracking-wider hover:underline" style={`color: ${club.theme_color}`}>View All</a>
              </div>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                {clubEvents.map((event: any) => (
                  <div class="bg-gray-50 rounded-2xl overflow-hidden border border-gray-200 hover:border-gray-300 transition-colors group">
                    <div class="h-32 overflow-hidden relative">
                      <img src={event.banner_url} class="w-full h-full object-cover transform group-hover:scale-105 transition-transform" />
                    </div>
                    <div class="p-5">
                      <h3 class="font-bold text-gray-900 mb-1 leading-tight">{event.title}</h3>
                      <p class="text-xs text-gray-500 mb-4">{new Date(event.start_at).toLocaleDateString('en-IN')}</p>
                      <a href={`/events/${event.slug}`} class="block text-center border border-gray-300 text-gray-700 hover:bg-gray-900 hover:text-white hover:border-gray-900 font-medium text-sm py-2 rounded-lg transition-colors">Details</a>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
          
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1 border-t lg:border-t-0 lg:border-l border-gray-100 pt-12 lg:pt-0 lg:pl-12">
          
          <div class="bg-gray-50 rounded-3xl p-8 border border-gray-100 mb-8 card-shadow sticky top-24">
            <h3 class="text-sm font-bold text-gray-900 uppercase tracking-widest mb-6">Connect with Us</h3>
            
            <div class="space-y-4">
              {club.instagram_url && (
                <a href={club.instagram_url} target="_blank" rel="noopener noreferrer" class="flex items-center px-4 py-3 bg-white rounded-xl border border-gray-200 hover:border-pink-500 hover:shadow-md transition-all group">
                  <div class="w-8 h-8 rounded-full bg-pink-50 text-pink-500 flex items-center justify-center mr-3 group-hover:scale-110 transition-transform">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                  </div>
                  <span class="font-semibold text-gray-700 text-sm">Instagram</span>
                </a>
              )}

              {club.linkedin_url && (
                <a href={club.linkedin_url} target="_blank" rel="noopener noreferrer" class="flex items-center px-4 py-3 bg-white rounded-xl border border-gray-200 hover:border-blue-500 hover:shadow-md transition-all group">
                  <div class="w-8 h-8 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center mr-3 group-hover:scale-110 transition-transform">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  </div>
                  <span class="font-semibold text-gray-700 text-sm">LinkedIn</span>
                </a>
              )}
              
              {club.whatsapp_group_url && (
                <a href={club.whatsapp_group_url} target="_blank" rel="noopener noreferrer" class="flex items-center px-4 py-3 bg-white rounded-xl border border-gray-200 hover:border-green-500 hover:shadow-md transition-all group">
                  <div class="w-8 h-8 rounded-full bg-green-50 text-green-500 flex items-center justify-center mr-3 group-hover:scale-110 transition-transform">
                    {/* SVG placeholder for whatsapp */}
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  </div>
                  <span class="font-semibold text-gray-700 text-sm">WhatsApp Group</span>
                </a>
              )}
            </div>

          </div>

        </div>

      </div>
    </div>
  </section>

</Layout>
