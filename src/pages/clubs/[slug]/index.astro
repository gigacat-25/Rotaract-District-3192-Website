---
import Layout from '../../../layouts/Layout.astro';
import clubsData from '../../../mock/clubs.json';
import eventsData from '../../../mock/events.json';

export async function getStaticPaths() {
  const clubs = clubsData;
  return clubs.map((club: any) => ({
    params: { slug: club.slug },
    props: { club },
  }));
}

const { club } = Astro.props;
const clubEvents = eventsData.filter((e: any) => e.club_id === club.id && e.status === 'published').slice(0,3);
---

<Layout title={club.name}>
  <main class="pt-20">
    <!-- DYNAMIC CLUB HERO -->
    <header class="relative min-h-[60vh] flex items-end overflow-hidden px-6 lg:px-12 bg-primary">
      <div class="absolute inset-0 z-0">
        <img src={club.cover_url} alt="" class="w-full h-full object-cover opacity-30 mix-blend-luminosity" />
        <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/40 to-transparent"></div>
        <div class="absolute top-0 right-0 w-1/2 h-full aqueous-gradient opacity-10 blur-3xl"></div>
      </div>
      
      <div class="container mx-auto max-w-screen-2xl relative z-10 w-full mb-20">
        <div class="flex flex-col md:flex-row items-start md:items-end gap-12">
          <div class="w-48 h-48 bg-white rounded-[3rem] p-3 shadow-2xl shrink-0 rotate-[-2deg] border-[8px] border-surface-container-lowest">
            <img src={club.logo_url} alt={club.name} class="w-full h-full object-contain rounded-[2rem]" />
          </div>
          
          <div class="space-y-6 flex-grow">
            <div class="flex flex-wrap gap-3">
               <span class="px-4 py-1.5 rounded-full bg-white/10 text-white text-[9px] font-black uppercase tracking-widest border border-white/10 backdrop-blur-md">
                Chartered {new Date(club.charter_date).getFullYear()}
              </span>
              {club.status === 'active' ? (
                <span class="px-4 py-1.5 rounded-full bg-green-500/20 text-green-300 text-[9px] font-black uppercase tracking-widest border border-green-500/20 backdrop-blur-md">Active Body</span>
              ) : (
                <span class="px-4 py-1.5 rounded-full bg-red-500/20 text-red-300 text-[9px] font-black uppercase tracking-widest border border-red-500/20 backdrop-blur-md">Inactive</span>
              )}
            </div>
            <h1 class="text-6xl md:text-8xl font-black text-white leading-[0.85] tracking-tighter font-headline">{club.name}</h1>
            <div class="flex flex-wrap items-center gap-8 text-on-primary font-bold opacity-70 text-sm italic">
              <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">location_on</span>{club.city}</span>
              <span class="flex items-center gap-2"><span class="material-symbols-outlined text-lg">groups</span>{club.member_count} Members</span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- CONTENT -->
    <section class="py-32 px-6 lg:px-12 bg-surface">
      <div class="max-w-screen-2xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
          
          <!-- Main Column -->
          <div class="lg:col-span-8 space-y-24">
            <div class="space-y-10">
              <div class="space-y-4">
                <span class="text-primary font-black text-[10px] tracking-[.4em] uppercase opacity-40">The Narrative</span>
                <h2 class="text-5xl font-black text-primary tracking-tighter font-headline">About the Club</h2>
              </div>
              <div class="font-body text-xl text-on-surface-variant font-medium leading-relaxed opacity-80 max-w-3xl first-letter:text-7xl first-letter:font-black first-letter:text-primary first-letter:float-left first-letter:mr-4 first-letter:mt-2">
                <p>{club.about}</p>
              </div>
            </div>

            <!-- Upcoming Events -->
            {clubEvents.length > 0 && (
              <div class="space-y-12">
                <div class="flex items-center justify-between border-b-2 border-primary/5 pb-8">
                  <h2 class="text-4xl font-black text-primary tracking-tighter font-headline">Upcoming Waves</h2>
                  <a href={`/clubs/${club.slug}/events`} class="text-primary font-black text-[10px] uppercase tracking-widest border-b-2 border-primary/20 pb-1 hover:border-primary transition-all">View All Events</a>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                  {clubEvents.map((event: any) => (
                    <a href={`/events/${event.slug}`} class="group bg-surface-container-low rounded-[2.5rem] overflow-hidden fluid-shadow hover:translate-y-[-4px] transition-all duration-500 block">
                      <div class="h-48 overflow-hidden relative">
                        <img src={event.banner_url} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" />
                        <div class="absolute bottom-4 left-6 bg-surface-container-lowest/90 backdrop-blur-md px-4 py-2 rounded-xl">
                          <span class="text-[10px] font-black text-primary uppercase tracking-widest">{new Date(event.start_at).toLocaleDateString()}</span>
                        </div>
                      </div>
                      <div class="p-8">
                        <h3 class="text-2xl font-black text-primary font-headline tracking-tight group-hover:text-primary-container transition-colors line-clamp-1">{event.title}</h3>
                        <p class="mt-4 text-on-surface-variant font-bold text-[10px] uppercase tracking-widest opacity-40">Click for details</p>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>

          <!-- Sidebar -->
          <div class="lg:col-span-4 space-y-12">
            <div class="bg-surface-container-low rounded-[3rem] p-12 space-y-10 fluid-shadow sticky top-32">
              <div class="space-y-2">
                <h3 class="text-[10px] font-black text-primary uppercase tracking-[0.3em] opacity-40 text-center">Social Radius</h3>
                <p class="text-3xl font-black text-primary font-headline tracking-tighter text-center">Get Connected</p>
              </div>
              
              <div class="space-y-6">
                {club.instagram_url && (
                  <a href={club.instagram_url} target="_blank" class="flex items-center justify-between p-6 bg-surface-container-lowest rounded-2xl group transition-all hover:bg-primary hover:text-on-primary">
                    <div class="flex items-center gap-4">
                      <span class="material-symbols-outlined text-2xl opacity-40 group-hover:opacity-100">travel_explore</span>
                      <span class="font-black uppercase tracking-widest text-[10px]">Instagram</span>
                    </div>
                    <span class="material-symbols-outlined text-sm">open_in_new</span>
                  </a>
                )}

                {club.linkedin_url && (
                  <a href={club.linkedin_url} target="_blank" class="flex items-center justify-between p-6 bg-surface-container-lowest rounded-2xl group transition-all hover:bg-primary hover:text-on-primary">
                    <div class="flex items-center gap-4">
                      <span class="material-symbols-outlined text-2xl opacity-40 group-hover:opacity-100">business_center</span>
                      <span class="font-black uppercase tracking-widest text-[10px]">LinkedIn</span>
                    </div>
                    <span class="material-symbols-outlined text-sm">open_in_new</span>
                  </a>
                )}
                
                {club.whatsapp_group_url && (
                  <a href={club.whatsapp_group_url} target="_blank" class="flex items-center justify-between p-6 bg-surface-container-lowest rounded-2xl group transition-all hover:bg-primary hover:text-on-primary">
                    <div class="flex items-center gap-4">
                      <span class="material-symbols-outlined text-2xl opacity-40 group-hover:opacity-100">chat</span>
                      <span class="font-black uppercase tracking-widest text-[10px]">WhatsApp Group</span>
                    </div>
                    <span class="material-symbols-outlined text-sm">open_in_new</span>
                  </a>
                )}
              </div>

              <div class="pt-10 text-center border-t border-primary/5">
                 <button class="aqueous-gradient text-on-primary px-10 py-5 rounded-2xl font-black uppercase tracking-widest text-[10px] w-full shadow-2xl shadow-primary/20">
                  Enquire Membership
                </button>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 48px -12px rgba(13, 65, 116, 0.06);
  }
</style>

