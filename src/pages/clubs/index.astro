---
import Layout from '../../layouts/Layout.astro';
import clubsData from '../../mock/clubs.json';

const clubs = clubsData;
const activeClubs = clubs.filter((c: any) => c.status === 'active');
---

<Layout title="Club Directory">
  <main class="pt-20">
    <header class="bg-primary text-white pt-32 pb-24 relative overflow-hidden px-6 lg:px-12">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-20 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-surface/5 rounded-tr-[15rem] blur-2xl"></div>
      </div>
      <div class="container mx-auto max-w-screen-2xl relative z-10 text-center space-y-6">
        <span class="inline-block px-5 py-2 rounded-full bg-white/10 text-white text-[10px] font-black tracking-[0.3em] uppercase font-headline border border-white/10">
          Connectivity
        </span>
        <h1 class="text-6xl md:text-8xl font-black mb-4 tracking-tighter font-headline">Club Directory</h1>
        <p class="text-xl text-white/70 max-w-2xl mx-auto font-body font-medium italic">Explore the {activeClubs.length} active Rotaract clubs shaping communities across District 3192.</p>
      </div>
    </header>

    <!-- Filters Section (Tonal Layering) -->
    <section class="py-12 bg-surface-container-low border-b border-outline-variant/30 sticky top-20 z-30 shadow-sm px-6 lg:px-12">
      <div class="max-w-screen-2xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="w-full md:w-[400px] relative">
          <input type="text" placeholder="Search clubs by name or city..." class="w-full pl-14 pr-6 py-4 bg-surface-container-lowest rounded-2xl text-sm font-bold focus:outline-none focus:ring-4 focus:ring-primary/5 transition-all fluid-shadow">
          <span class="material-symbols-outlined absolute left-5 top-1/2 -translate-y-1/2 text-primary opacity-40">search</span>
        </div>

        <div class="flex items-center gap-4 w-full md:w-auto">
          <div class="relative flex-grow md:flex-grow-0">
            <select class="w-full md:w-56 appearance-none bg-surface-container-lowest py-4 pl-6 pr-12 rounded-2xl text-xs font-black uppercase tracking-widest text-primary focus:outline-none fluid-shadow">
              <option value="all">All Regions</option>
              <option value="bengaluru">Bengaluru</option>
              <option value="central">Central</option>
            </select>
            <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-primary pointer-events-none text-xl">expand_more</span>
          </div>
          
          <div class="flex bg-surface-container-high p-1.5 rounded-2xl">
            <button class="bg-surface-container-lowest text-primary shadow-lg px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest flex items-center gap-2">
              <span class="material-symbols-outlined text-lg">grid_view</span>
              Grid
            </button>
            <button class="text-on-surface-variant hover:text-primary px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all flex items-center gap-2">
              <span class="material-symbols-outlined text-lg">map</span>
              Map
            </button>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-surface px-6 lg:px-12 min-h-[50vh]">
      <div class="max-w-screen-2xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-10">
          
          {activeClubs.map((club: any, index: number) => (
            <a href={`/clubs/${club.slug}`} class={`group bg-surface-container-lowest rounded-[2.5rem] overflow-hidden fluid-shadow hover:translate-y-[-8px] transition-all duration-500 flex flex-col h-full fade-in-up`} style={`animation-delay: ${0.05 * index}s`}>
              
              <!-- Abstract Header -->
              <div class="h-32 opacity-10 transition-opacity group-hover:opacity-20" style={`background: linear-gradient(135deg, ${club.theme_color || '#174174'} 0%, transparent 100%)`}></div>
              
              <div class="flex-grow p-10 pt-0 relative flex flex-col">
                <!-- Logo overlapping -->
                <div class="-mt-12 mb-8 w-24 h-24 rounded-[2rem] bg-white p-2 shadow-2xl border-4 border-surface-container-lowest">
                  <img src={club.logo_url} alt={club.name} class="w-full h-full object-contain rounded-2xl" />
                </div>
                
                <div class="space-y-4 mb-8">
                  <h3 class="text-2xl font-black text-primary group-hover:text-primary-container transition-colors leading-tight font-headline tracking-tighter">{club.name}</h3>
                  <div class="flex items-center gap-2 text-[10px] font-black text-on-surface-variant uppercase tracking-widest opacity-50">
                    <span class="material-symbols-outlined text-sm">location_on</span>
                    {club.city}
                  </div>
                </div>
                
                <div class="mt-auto pt-8 border-t border-primary/5 flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="flex -space-x-3">
                      {[...Array(3)].map((_, i) => (
                        <div class="w-8 h-8 rounded-full border-2 border-surface-container-lowest aqueous-gradient opacity-80 ring-2 ring-transparent group-hover:ring-primary/10 transition-all flex items-center justify-center text-[8px] font-bold text-white">R</div>
                      ))}
                    </div>
                    <span class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant opacity-40">{club.member_count} Members</span>
                  </div>
                  
                  <span class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-on-primary transition-all">
                    <span class="material-symbols-outlined text-lg">arrow_forward</span>
                  </span>
                </div>
              </div>
            </a>
          ))}

        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>
