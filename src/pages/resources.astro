---
import Layout from '../layouts/Layout.astro';

const categories = [
  {
    name: "Club Administration",
    docs: [
      { title: "Standard Club Constitution", type: "PDF", size: "1.2 MB", date: "Jul 2025" },
      { title: "Bylaws Template", type: "DOCX", size: "450 KB", date: "Jul 2025" },
      { title: "Meeting Agenda Template", type: "XLSX", size: "150 KB", date: "Aug 2025" }
    ]
  },
  {
    name: "Branding & PR",
    docs: [
      { title: "Rotaract Brand Guidelines", type: "PDF", size: "5.4 MB", date: "Jul 2025" },
      { title: "Social Media End Card", type: "PNG", size: "2.1 MB", date: "Jul 2025" },
      { title: "Letterhead Template", type: "DOCX", size: "300 KB", date: "Aug 2025" }
    ]
  },
  {
    name: "District Forms",
    docs: [
      { title: "District Dues Payment Form", type: "PDF", size: "800 KB", date: "Aug 2025" },
      { title: "Award Nomination Form", type: "DOCX", size: "250 KB", date: "Feb 2026" },
      { title: "Expense Reimbursement", type: "XLSX", size: "400 KB", date: "Aug 2025" }
    ]
  }
];
---

<Layout title="Document Resources">
  <main class="pt-20">
    <header class="bg-primary text-white pt-32 pb-24 relative overflow-hidden px-6 lg:px-12">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-20 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-surface/5 rounded-tr-[15rem] blur-2xl"></div>
      </div>
      <div class="container mx-auto max-w-screen-2xl relative z-10 text-center space-y-6">
        <span class="inline-block px-5 py-2 rounded-full bg-white/10 text-white text-[10px] font-black tracking-[0.3em] uppercase font-headline border border-white/10">
          The Vault
        </span>
        <h1 class="text-6xl md:text-8xl font-black mb-4 tracking-tighter font-headline uppercase leading-none">Resource Central</h1>
        <p class="text-xl text-white/70 max-w-2xl mx-auto font-body font-medium italic">Official documents, templates, and guidelines for District 3192 clubs.</p>
      </div>
    </header>

    <section class="py-24 bg-surface px-6 lg:px-12 min-h-screen border-t border-outline-variant/30">
      <div class="max-w-screen-2xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
          
          <!-- Sidebar Navigation -->
          <div class="lg:col-span-3 hidden lg:block">
            <div class="sticky top-32 bg-surface-container-low rounded-[2rem] p-10 fluid-shadow border border-outline-variant/30">
              <h3 class="text-[10px] font-black text-primary uppercase tracking-[.4em] mb-8 opacity-40">Categories</h3>
              <ul class="space-y-6">
                {categories.map((cat, i) => (
                  <li>
                    <a href={`#cat-${i}`} class="group flex items-center gap-4 text-sm font-black text-primary/60 hover:text-primary transition-all">
                      <span class="w-2 h-2 rounded-full bg-primary/20 group-hover:bg-primary transition-all"></span>
                      {cat.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Documents List -->
          <div class="lg:col-span-9 space-y-24">
            {categories.map((cat, i) => (
              <div id={`cat-${i}`} class="scroll-mt-32 space-y-10">
                <div class="space-y-2">
                  <span class="text-primary font-black text-[10px] tracking-[.4em] uppercase opacity-40">Section {i + 1}</span>
                  <h2 class="text-4xl font-black text-primary tracking-tighter font-headline flex items-center gap-6 uppercase">
                    {cat.name}
                    <span class="h-0.5 flex-grow bg-primary/5 rounded-full"></span>
                  </h2>
                </div>
                
                <div class="grid gap-6">
                  {cat.docs.map(doc => (
                    <div class="p-8 bg-surface-container-low rounded-[2.5rem] hover:bg-surface-container-lowest transition-all group border border-outline-variant/30 flex flex-col md:flex-row items-start md:items-center justify-between gap-8 fluid-shadow">
                      <div class="flex items-center gap-6">
                        <div class={`w-16 h-16 rounded-[1.2rem] flex items-center justify-center shrink-0 fluid-shadow transition-transform group-hover:rotate-[-4deg]
                          ${doc.type === 'PDF' ? 'bg-red-500/10 text-red-600' : 
                            doc.type === 'DOCX' ? 'bg-blue-500/10 text-blue-600' : 
                            doc.type === 'XLSX' ? 'bg-green-500/10 text-green-600' : 'bg-primary/10 text-primary'}`}>
                          <span class="text-xs font-black uppercase tracking-widest">{doc.type}</span>
                        </div>
                        <div class="space-y-1">
                          <h4 class="text-2xl font-black text-primary font-headline tracking-tighter group-hover:text-primary-container transition-colors leading-tight">{doc.title}</h4>
                          <div class="flex items-center gap-4 text-[10px] font-black text-on-surface-variant uppercase tracking-widest opacity-40">
                            <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-sm">database</span> {doc.size}</span>
                            <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-sm">history</span> {doc.date}</span>
                          </div>
                        </div>
                      </div>
                      
                      <button class="px-8 py-4 bg-primary text-on-primary rounded-2xl font-black uppercase tracking-widest text-[10px] hover:translate-y-[-2px] transition-all fluid-shadow flex items-center gap-3">
                        <span class="material-symbols-outlined text-lg">download</span>
                        Download Asset
                      </button>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
          
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 48px -12px rgba(13, 65, 116, 0.06);
  }
</style>


</Layout>
