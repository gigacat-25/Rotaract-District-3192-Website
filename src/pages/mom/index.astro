---
import Layout from '../../layouts/Layout.astro';
import momsData from '../../mock/moms.json';

const moms = momsData;
---

<Layout title="Transcription Terminal">
  <main class="pt-20 bg-surface min-h-screen">
    <!-- MOM HEADER -->
    <header class="bg-primary text-white pt-32 pb-24 relative overflow-hidden px-6 lg:px-12 border-b border-white/5">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-2/3 h-full aqueous-gradient opacity-20 rounded-bl-[10rem] blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-1/2 h-1/2 bg-surface/5 rounded-tr-[15rem] blur-2xl"></div>
      </div>
      
      <div class="max-w-screen-2xl mx-auto flex flex-col md:flex-row items-center justify-between gap-12 relative z-10">
        <div class="space-y-6 text-center md:text-left">
          <span class="inline-block px-5 py-2 rounded-full bg-white/10 text-white text-[10px] font-black tracking-[0.3em] uppercase font-headline border border-white/10">
            Intelligence Feed
          </span>
          <h1 class="text-6xl md:text-8xl font-black mb-4 tracking-tighter font-headline uppercase leading-none italic">Echo Protocol</h1>
          <p class="text-xl text-white/70 max-w-2xl font-body font-medium italic">Autonomous meeting transcription and action token extraction system.</p>
        </div>
        
        <a href="/mom/new" class="group relative bg-white text-primary font-black px-12 py-6 rounded-2xl uppercase tracking-[0.3em] text-[10px] shadow-2xl hover:translate-y-[-4px] active:translate-y-0 transition-all overflow-hidden flex items-center gap-4">
          <span class="relative z-10 flex items-center gap-3">Initialize New Sequence <span class="material-symbols-outlined text-lg">mic</span></span>
          <div class="absolute inset-0 aqueous-gradient opacity-0 group-hover:opacity-10 transition-opacity"></div>
        </a>
      </div>
    </header>

    <section class="py-24 px-6 lg:px-12">
      <div class="max-w-screen-2xl mx-auto space-y-12">
        
        <!-- Productivity Analytics -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          {[
            { label: 'Total Sequences', val: moms.length, icon: 'history', color: 'text-primary' },
            { label: 'Pending Tokens', val: '12', icon: 'pending_actions', color: 'text-error' },
            { label: 'Temporal Gain', val: '4.5H', icon: 'auto_awesome', color: 'text-green-500' }
          ].map(stat => (
            <div class="bg-surface-container-low p-8 rounded-[2.5rem] border border-outline-variant/30 fluid-shadow flex items-center gap-8 group hover:bg-surface-container-lowest transition-all">
              <div class="w-16 h-16 rounded-[1.5rem] bg-primary/5 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-3xl">{stat.icon}</span>
              </div>
              <div class="space-y-1">
                <p class="text-4xl font-black font-headline tracking-tighter leading-none italic uppercase {stat.color}">{stat.val}</p>
                <p class="text-[9px] font-black text-on-surface-variant uppercase tracking-[.4em] opacity-40 italic">{stat.label}</p>
              </div>
            </div>
          ))}
        </div>
        
        <!-- Sequence Manifest -->
        <div class="bg-surface-container-low rounded-[3.5rem] border border-outline-variant/30 fluid-shadow overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-surface-container-lowest border-b border-primary/5">
                  <th class="py-10 px-10 text-[10px] font-black text-primary/40 uppercase tracking-[0.4em] leading-none italic">Session ID / Context</th>
                  <th class="py-10 px-10 text-[10px] font-black text-primary/40 uppercase tracking-[0.4em] leading-none italic">Temporal Frame</th>
                  <th class="py-10 px-10 text-[10px] font-black text-primary/40 uppercase tracking-[0.4em] leading-none italic">Origin Node</th>
                  <th class="py-10 px-10 text-[10px] font-black text-primary/40 uppercase tracking-[0.4em] leading-none italic text-right">Synchronization</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-primary/5">
                {moms.map((mom: any) => (
                  <tr class="hover:bg-surface-container-lowest transition-all group cursor-pointer" onclick={`window.location.href='/mom/${mom.id}'`}>
                    <td class="py-8 px-10">
                      <div class="space-y-2">
                        <p class="text-2xl font-black text-primary font-headline tracking-tighter group-hover:text-primary-container transition-colors uppercase italic">{mom.title}</p>
                        <p class="text-[10px] text-on-surface-variant font-medium italic opacity-50 max-w-sm truncate">"{mom.summary}"</p>
                      </div>
                    </td>
                    <td class="py-8 px-10 whitespace-nowrap">
                      <p class="text-[10px] font-black text-primary/60 uppercase tracking-widest leading-none">{new Date(mom.date).toLocaleDateString('en-IN', {month: 'short', day: 'numeric', year: 'numeric'})}</p>
                    </td>
                    <td class="py-8 px-10 whitespace-nowrap">
                      <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[9px] font-black uppercase tracking-[0.3em] bg-primary/5 text-primary border border-primary/10">
                        {mom.club_id}
                      </span>
                    </td>
                    <td class="py-8 px-10 whitespace-nowrap text-right">
                      <div class="flex items-center justify-end gap-3">
                         <span class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest opacity-30 italic">Details Retrievable</span>
                         <span class="material-symbols-outlined text-primary opacity-20 group-hover:opacity-100 group-hover:translate-x-2 transition-all">arrow_forward</span>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
        
      </div>
    </section>
  </main>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>

