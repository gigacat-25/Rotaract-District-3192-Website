---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Redirecting...">
  <main class="min-h-screen flex items-center justify-center bg-surface">
    <div class="text-center space-y-4">
      <div class="w-16 h-16 border-4 border-primary/20 border-t-primary rounded-full animate-spin mx-auto"></div>
      <p class="text-[10px] font-black uppercase tracking-[0.3em] text-primary/40">Synchronizing with Hall of Fame...</p>
    </div>
  </main>

  <script is:inline>
    window.location.href = '/hall-of-fame';
  </script>
</Layout>

