---
import Layout from '../../layouts/Layout.astro';
import clubsData from '../../mock/clubs.json';
import membersData from '../../mock/members.json';

const activeClubs = clubsData.filter(c => c.status === 'active');
const allMembers = membersData;

const metrics = {
  totalClubs: activeClubs.length,
  totalMembers: allMembers.length,
  totalDues: "₹1,45,000",
  activeEvents: 14
};
---

<Layout title="District Admin Dashboard">
  
  <div class="flex min-h-screen bg-gray-50">
    
    <!-- Admin Sidebar (Mocked for layout) -->
    <aside class="w-64 bg-gray-900 text-gray-400 flex flex-col fixed inset-y-0 z-50">
      <div class="p-6 border-b border-gray-800">
        <a href="/" class="flex flex-col">
          <span class="font-bold text-2xl tracking-tight text-white leading-tight">Rotaract<span class="text-[#F5A623]">3192</span></span>
          <span class="text-[10px] uppercase tracking-widest font-bold leading-none mt-1 text-gray-500">Access: District Admin</span>
        </a>
      </div>
      
      <nav class="flex-grow p-4 space-y-1">
        <a href="/admin" class="flex items-center px-4 py-3 bg-[#003F8A] text-white rounded-xl font-medium text-sm transition-colors">
          <svg class="w-5 h-5 mr-3 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
          Dashboard
        </a>
        <a href="/admin/members" class="flex items-center px-4 py-3 hover:bg-gray-800 hover:text-white rounded-xl font-medium text-sm transition-colors">
          <svg class="w-5 h-5 mr-3 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
          Members Directory
        </a>
        <a href="#" class="flex items-center px-4 py-3 hover:bg-gray-800 hover:text-white rounded-xl font-medium text-sm transition-colors">
          <svg class="w-5 h-5 mr-3 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          Events Approval
        </a>
        <a href="#" class="flex items-center px-4 py-3 hover:bg-gray-800 hover:text-white rounded-xl font-medium text-sm transition-colors">
          <svg class="w-5 h-5 mr-3 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
          District Dues
        </a>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-grow pl-64 flex flex-col min-h-screen">
      
      <header class="bg-white px-8 py-5 border-b border-gray-200 flex items-center justify-between sticky top-0 z-40">
        <h1 class="text-xl font-bold text-gray-900">Metrics Overview</h1>
        <div class="flex items-center gap-4">
          <button class="bg-[#F5A623] hover:bg-[#e0941a] text-[#003F8A] font-bold text-sm px-5 py-2 rounded-lg transition-colors shadow-sm">
            Generate Report
          </button>
        </div>
      </header>

      <div class="p-8 flex-grow">
        
        <!-- KPI Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
          <div class="bg-white rounded-2xl p-6 border border-gray-200 card-shadow">
            <h3 class="text-gray-500 text-xs font-bold uppercase tracking-wider mb-2">Total Clubs</h3>
            <p class="text-3xl font-black text-gray-900">{metrics.totalClubs}</p>
            <p class="text-xs font-semibold text-green-500 mt-2 flex items-center"><svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg> 2 New this year</p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-gray-200 card-shadow">
            <h3 class="text-gray-500 text-xs font-bold uppercase tracking-wider mb-2">Total Members</h3>
            <p class="text-3xl font-black text-gray-900">~ {metrics.totalMembers * 40}</p>
            <p class="text-xs font-semibold text-green-500 mt-2 flex items-center"><svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg> 14% Growth</p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-gray-200 card-shadow">
            <h3 class="text-gray-500 text-xs font-bold uppercase tracking-wider mb-2">Dues Collected</h3>
            <p class="text-3xl font-black text-[#003F8A]">{metrics.totalDues}</p>
            <p class="text-xs font-semibold text-gray-400 mt-2">60% of target</p>
          </div>
          <div class="bg-white rounded-2xl p-6 border border-gray-200 card-shadow">
            <h3 class="text-gray-500 text-xs font-bold uppercase tracking-wider mb-2">Active Events</h3>
            <p class="text-3xl font-black text-[#F5A623]">{metrics.activeEvents}</p>
            <p class="text-xs font-semibold text-red-500 mt-2 flex items-center"><svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg> 3 Pending Approval</p>
          </div>
        </div>

        <!-- Two column layout for charts/lists -->
        <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
          
          <div class="xl:col-span-2 bg-white rounded-3xl border border-gray-200 card-shadow overflow-hidden">
            <div class="px-6 py-5 border-b border-gray-200 flex justify-between items-center bg-gray-50">
              <h2 class="font-bold text-gray-900 text-lg">Recent Club Registrations</h2>
              <a href="#" class="text-sm font-semibold text-[#003F8A] hover:underline">View All</a>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-left">
                <thead class="bg-gray-50 border-b border-gray-100">
                  <tr>
                    <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Club Name</th>
                    <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">City</th>
                    <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Members</th>
                    <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  {activeClubs.slice(0, 4).map(club => (
                    <tr class="hover:bg-gray-50 transition-colors">
                      <td class="px-6 py-4 font-bold text-gray-900 text-sm flex items-center">
                        <img src={club.logo_url} class="w-6 h-6 mr-3 rounded" />
                        {club.name}
                      </td>
                      <td class="px-6 py-4 font-medium text-gray-600 text-sm">{club.city}</td>
                      <td class="px-6 py-4 font-bold text-gray-900 text-sm">{club.member_count}</td>
                      <td class="px-6 py-4">
                        <span class="bg-green-100 text-green-700 text-[10px] font-black px-2.5 py-1 uppercase tracking-widest rounded">Active</span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
          
          <div class="xl:col-span-1 bg-white rounded-3xl border border-gray-200 card-shadow overflow-hidden flex flex-col">
            <div class="px-6 py-5 border-b border-gray-200 bg-gray-50">
              <h2 class="font-bold text-gray-900 text-lg">System Actions</h2>
            </div>
            <div class="p-6 flex flex-col gap-3 flex-grow justify-center">
              <button class="w-full bg-[#003F8A] hover:bg-[#002f6c] text-white font-bold py-3.5 rounded-xl shadow-md transition-colors text-sm text-left px-5 flex items-center justify-between">
                Review Event Submissions
                <span class="bg-red-500 text-white text-xs px-2 py-0.5 rounded-full">3</span>
              </button>
              <button class="w-full bg-white border border-gray-200 hover:border-gray-300 text-gray-800 font-bold py-3.5 rounded-xl shadow-sm transition-colors text-sm text-left px-5 flex items-center justify-between">
                Issue District Certs
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </button>
              <button class="w-full bg-white border border-gray-200 hover:border-gray-300 text-gray-800 font-bold py-3.5 rounded-xl shadow-sm transition-colors text-sm text-left px-5 flex items-center justify-between">
                Send Bulk Email
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </button>
            </div>
          </div>

        </div>

      </div>

    </main>

  </div>

</Layout>
