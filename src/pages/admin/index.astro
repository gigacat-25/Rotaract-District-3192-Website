---
import Layout from '../../layouts/Layout.astro';
import clubsData from '../../mock/clubs.json';
import membersData from '../../mock/members.json';

const activeClubs = clubsData.filter(c => c.status === 'active');
const allMembers = membersData;

const metrics = {
  totalClubs: activeClubs.length,
  totalMembers: allMembers.length,
  totalDues: "₹1,45,000",
  activeEvents: 14
};
---

<Layout title="Command Center | District Admin">
  <div class="flex min-h-screen bg-surface">
    
    <!-- Cinematic Admin Sidebar -->
    <aside class="w-80 bg-primary text-white flex flex-col fixed inset-y-0 z-50 border-r border-white/5 shadow-2xl relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 left-0 w-full h-full aqueous-gradient opacity-10 blur-3xl"></div>
      </div>
      
      <div class="p-10 border-b border-white/5 relative z-10">
        <a href="/" class="flex flex-col group">
          <span class="font-black text-3xl tracking-tighter font-headline uppercase leading-tight italic">Terminal<span class="text-white/40">3192</span></span>
          <span class="text-[8px] font-black uppercase tracking-[0.4em] mt-2 text-white/40 italic">Hierarchy: District Controller</span>
        </a>
      </div>
      
      <nav class="flex-grow p-6 space-y-3 relative z-10">
        <a href="/admin" class="flex items-center px-6 py-4 bg-white/10 text-white rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all border border-white/10 fluid-shadow italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-60">space_dashboard</span>
          Core Dashboard
        </a>
        <a href="/admin/members" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">group</span>
          Node Directory
        </a>
        <a href="#" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">event</span>
          Signal Approval
        </a>
        <a href="#" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">account_balance_wallet</span>
          Capital Inflow
        </a>
      </nav>

      <div class="p-8 border-t border-white/5 relative z-10">
         <div class="bg-white/5 p-6 rounded-2xl border border-white/5">
            <p class="text-[8px] font-black uppercase tracking-[0.3em] text-white/30 italic">System Integrity</p>
            <p class="text-xs font-black text-white mt-1 italic tracking-widest uppercase">98.2% Nominal</p>
         </div>
      </div>
    </aside>

    <!-- Main Command Content -->
    <main class="flex-grow pl-80 flex flex-col min-h-screen">
      
      <header class="bg-surface/80 backdrop-blur-xl px-12 py-8 border-b border-outline-variant/30 flex items-center justify-between sticky top-0 z-40">
        <div class="space-y-1">
          <h1 class="text-2xl font-black text-primary font-headline tracking-tighter uppercase italic leading-none">Intelligence Metrics</h1>
          <p class="text-[9px] font-black text-primary/30 uppercase tracking-[0.4em] italic">Real-time data synchronization active</p>
        </div>
        <button class="bg-primary text-white font-black text-[10px] uppercase tracking-[0.3em] px-8 py-4 rounded-xl shadow-2xl hover:translate-y-[-2px] transition-all flex items-center gap-3">
          <span class="material-symbols-outlined text-lg">description</span>
          Extract Log Report
        </button>
      </header>

      <div class="p-12 space-y-12">
        
        <!-- Metrics Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-8">
          {[
            { label: 'Registered Nodes', val: metrics.totalClubs, icon: 'hub', trend: '+2 Adaptive' },
            { label: 'Active Signals', val: metrics.totalMembers * 40, icon: 'sensors', trend: '14% Incline' },
            { label: 'Retained Capital', val: metrics.totalDues, icon: 'currency_rupee', trend: '60% Quota' },
            { label: 'Deployment Ops', val: metrics.activeEvents, icon: 'terminal', trend: '3 Pending Auth' }
          ].map(stat => (
            <div class="bg-surface-container-low p-8 rounded-[2.5rem] border border-outline-variant/30 fluid-shadow space-y-6 group hover:bg-surface-container-lowest transition-all">
              <div class="flex items-center justify-between">
                <span class="material-symbols-outlined text-3xl text-primary opacity-20 group-hover:opacity-100 transition-all">{stat.icon}</span>
                <span class="text-[8px] font-black text-green-600 uppercase tracking-widest italic">{stat.trend}</span>
              </div>
              <div class="space-y-1">
                <p class="text-4xl font-black text-primary font-headline tracking-tighter leading-none italic uppercase">{stat.val}</p>
                <p class="text-[9px] font-black text-on-surface-variant uppercase tracking-[.4em] opacity-40 italic">{stat.label}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-3 gap-12">
          
          <!-- Recent Transmissions Table -->
          <div class="xl:col-span-2 bg-surface-container-low rounded-[3.5rem] border border-outline-variant/30 fluid-shadow overflow-hidden">
            <div class="px-10 py-8 border-b border-primary/5 flex justify-between items-center bg-surface-container-lowest">
              <h2 class="text-xl font-black text-primary font-headline tracking-tighter uppercase italic">Recent Node Ingress</h2>
              <a href="#" class="text-[9px] font-black text-primary uppercase tracking-[0.3em] hover:underline underline-offset-8">Manifest View →</a>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse">
                <thead>
                  <tr class="bg-surface-container-lowest border-b border-primary/5">
                    <th class="py-6 px-10 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic">Origin Node</th>
                    <th class="py-6 px-10 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic">Geography</th>
                    <th class="py-6 px-10 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic text-right">Synchronization</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-primary/5">
                  {activeClubs.slice(0, 4).map(club => (
                    <tr class="hover:bg-surface-container-lowest transition-all group">
                      <td class="py-6 px-10">
                        <div class="flex items-center gap-4">
                           <img src={club.logo_url} class="w-8 h-8 rounded-lg grayscale group-hover:grayscale-0 transition-all border border-primary/10" />
                           <p class="text-base font-black text-primary font-headline uppercase leading-none tracking-tight">{club.name}</p>
                        </div>
                      </td>
                      <td class="py-6 px-10 text-[10px] font-black text-on-surface-variant/50 uppercase tracking-widest italic">{club.city}</td>
                      <td class="py-6 px-10 text-right">
                        <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[8px] font-black uppercase tracking-[0.3em] bg-green-500/5 text-green-600 border border-green-500/10">Active Protocol</span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
          
          <!-- System Tactical Actions -->
          <div class="xl:col-span-1 bg-surface-container-low rounded-[3.5rem] border border-outline-variant/30 fluid-shadow overflow-hidden flex flex-col">
            <div class="px-10 py-8 border-b border-primary/5 bg-surface-container-lowest">
              <h2 class="text-xl font-black text-primary font-headline tracking-tighter uppercase italic leading-none">System Functions</h2>
            </div>
            <div class="p-10 flex flex-col gap-6 flex-grow">
              <button class="w-full bg-primary text-white font-black py-6 rounded-2xl shadow-2xl hover:translate-y-[-2px] transition-all text-left px-8 flex items-center justify-between group">
                <div class="space-y-0.5">
                   <p class="text-[10px] uppercase tracking-[0.2em] italic leading-none">Review Signals</p>
                   <p class="text-[8px] text-white/40 uppercase tracking-[0.3em] italic">Pending Auth: 3</p>
                </div>
                <span class="bg-white/20 text-white w-8 h-8 rounded-full flex items-center justify-center text-[10px] font-black">03</span>
              </button>
              
              <button class="w-full bg-white border border-outline-variant/30 text-primary font-black py-6 rounded-2xl shadow-sm hover:bg-primary/5 transition-all text-left px-8 flex items-center justify-between group">
                <span class="text-[10px] uppercase tracking-[0.2em] italic">Issue Certificates</span>
                <span class="material-symbols-outlined text-primary/20 group-hover:text-primary transition-colors">verified</span>
              </button>

              <button class="w-full bg-white border border-outline-variant/30 text-primary font-black py-6 rounded-2xl shadow-sm hover:bg-primary/5 transition-all text-left px-8 flex items-center justify-between group">
                <span class="text-[10px] uppercase tracking-[0.2em] italic">Initialize Broadcast</span>
                <span class="material-symbols-outlined text-primary/20 group-hover:text-primary transition-colors">campaign</span>
              </button>
            </div>
          </div>

        </div>

      </div>

    </main>

  </div>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>

