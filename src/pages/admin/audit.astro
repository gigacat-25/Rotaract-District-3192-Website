---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Protocol Audit | District Admin">
  <div class="flex min-h-screen bg-surface">
    
    <!-- Cinematic Admin Sidebar -->
    <aside class="w-80 bg-primary text-white flex flex-col fixed inset-y-0 z-50 border-r border-white/5 shadow-2xl relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 left-0 w-full h-full aqueous-gradient opacity-10 blur-3xl"></div>
      </div>
      
      <div class="p-10 border-b border-white/5 relative z-10">
        <a href="/" class="flex flex-col group">
          <span class="font-black text-3xl tracking-tighter font-headline uppercase leading-tight italic">Terminal<span class="text-white/40">3192</span></span>
          <span class="text-[8px] font-black uppercase tracking-[0.4em] mt-2 text-white/40 italic">Hierarchy: District Controller</span>
        </a>
      </div>
      
      <nav class="flex-grow p-6 space-y-3 relative z-10">
        <a href="/admin" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">space_dashboard</span>
          Core Dashboard
        </a>
        <a href="/admin/members" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">group</span>
          Node Directory
        </a>
        <a href="/admin/audit" class="flex items-center px-6 py-4 bg-white/10 text-white rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all border border-white/10 fluid-shadow italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-60">security</span>
          Process Audit
        </a>
      </nav>

      <div class="p-8 border-t border-white/5 relative z-10">
         <div class="bg-white/5 p-6 rounded-2xl border border-white/5">
            <p class="text-[8px] font-black uppercase tracking-[0.3em] text-white/30 italic">Security Status</p>
            <p class="text-xs font-black text-white mt-1 italic tracking-widest uppercase text-green-400">Encrypted / Secure</p>
         </div>
      </div>
    </aside>

    <!-- Main Command Content -->
    <main class="flex-grow pl-80 flex flex-col min-h-screen">
      
      <header class="bg-surface/80 backdrop-blur-xl px-12 py-8 border-b border-outline-variant/30 flex items-center justify-between sticky top-0 z-40">
        <div class="space-y-1">
          <h1 class="text-2xl font-black text-primary font-headline tracking-tighter uppercase italic leading-none">System Audit Log</h1>
          <p class="text-[9px] font-black text-primary/30 uppercase tracking-[0.4em] italic">Chronological Protocol Execution Feed</p>
        </div>
      </header>

      <div class="p-12">
        
        <div class="bg-surface-container-low rounded-[3.5rem] border border-outline-variant/30 fluid-shadow overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-surface-container-lowest border-b border-primary/5">
                  <th class="py-8 px-12 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic leading-none">Temporal Marker</th>
                  <th class="py-8 px-12 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic leading-none">Controller</th>
                  <th class="py-8 px-12 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic leading-none">Operation Segment</th>
                  <th class="py-8 px-12 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic leading-none text-right">Integrity</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-primary/5">
                {[
                  { time: '2026-06-01 10:45 AM', user: 'Jane Doe', action: 'Approved Event: Blood Donation Camp', id: 'EVT-AUTH-092' },
                  { time: '2026-06-01 09:12 AM', user: 'John Smith', action: 'Updated Club Status: RC Chennai', id: 'HUB-SYNC-012' },
                  { time: '2026-05-31 04:20 PM', user: 'Admin Core', action: 'Issued District Certification Batch 04', id: 'CERT-GEN-005' }
                ].map(log => (
                  <tr class="hover:bg-surface-container-lowest transition-all group">
                    <td class="py-10 px-12">
                       <p class="text-[10px] font-black text-on-surface-variant/40 uppercase tracking-widest italic">{log.time}</p>
                    </td>
                    <td class="py-10 px-12">
                       <div class="flex items-center gap-4">
                          <div class="w-10 h-10 rounded-full bg-primary/5 border border-primary/10 flex items-center justify-center">
                             <span class="material-symbols-outlined text-primary/30 text-lg">person</span>
                          </div>
                          <p class="text-base font-black text-primary font-headline uppercase leading-none tracking-tight">{log.user}</p>
                       </div>
                    </td>
                    <td class="py-10 px-12">
                       <div class="space-y-1">
                          <p class="text-sm font-black text-primary uppercase italic tracking-tight">{log.action}</p>
                          <p class="text-[8px] font-black text-primary/30 uppercase tracking-[0.3em]">{log.id}</p>
                       </div>
                    </td>
                    <td class="py-10 px-12 text-right">
                       <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[8px] font-black uppercase tracking-[0.3em] bg-green-500/5 text-green-600 border border-green-500/10">Verified</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          
          <div class="bg-surface-container-lowest border-t border-primary/5 px-12 py-10 text-center">
             <button class="text-[10px] font-black text-primary uppercase tracking-[0.4em] hover:tracking-[0.6em] transition-all italic opacity-40 hover:opacity-100">Load Older Sequence Data ↓</button>
          </div>

        </div>

      </div>

    </main>

  </div>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>
