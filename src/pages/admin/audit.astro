---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Audit Log - Admin">
  <div class="flex min-h-screen bg-gray-50">
    <aside class="w-64 bg-gray-900 fixed inset-y-0 z-50 text-gray-400 p-4 pt-20">
      <a href="/admin" class="flex flex-col mb-8 px-4"><span class="font-bold text-2xl text-white">Rotaract<span class="text-[#F5A623]">3192</span></span></a>
      <a href="/admin/clubs" class="block px-4 py-3 hover:bg-gray-800 rounded-xl mb-1">Clubs</a>
      <a href="/admin/events" class="block px-4 py-3 hover:bg-gray-800 rounded-xl mb-1">Events</a>
      <a href="/admin/feeds" class="block px-4 py-3 hover:bg-gray-800 rounded-xl mb-1">Feeds</a>
      <a href="/admin/campaigns" class="block px-4 py-3 hover:bg-gray-800 rounded-xl mb-1">Campaigns</a>
      <a href="/admin/announcements" class="block px-4 py-3 hover:bg-gray-800 rounded-xl mb-1">Announcements</a>
      <a href="/admin/audit" class="block px-4 py-3 bg-[#003F8A] text-white rounded-xl">Audit Log</a>
    </aside>
    <main class="flex-grow pl-64 p-8">
      <h1 class="text-2xl font-bold mb-6">System Audit Log</h1>
      <div class="bg-white rounded-3xl border border-gray-200 card-shadow overflow-hidden p-0">
        <table class="w-full text-left">
          <thead class="bg-gray-50 border-b border-gray-100">
            <tr>
              <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase">Timestamp</th>
              <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase">Admin</th>
              <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm text-gray-500">2026-06-01 10:45 AM</td>
              <td class="px-6 py-4 text-sm font-semibold">Jane Doe</td>
              <td class="px-6 py-4 text-sm">Approved Event: Blood Donation Camp</td>
            </tr>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm text-gray-500">2026-06-01 09:12 AM</td>
              <td class="px-6 py-4 text-sm font-semibold">John Smith</td>
              <td class="px-6 py-4 text-sm">Updated Club Status: Rotaract Club of Chennai</td>
            </tr>
          </tbody>
        </table>
      </div>
    </main>
  </div>
</Layout>
