---
import Layout from '../../layouts/Layout.astro';
import clubsData from '../../mock/clubs.json';
const clubs = clubsData;
---

<Layout title="Node Management | District Admin">
  <div class="flex min-h-screen bg-surface">
    
    <!-- Cinematic Admin Sidebar -->
    <aside class="w-80 bg-primary text-white flex flex-col fixed inset-y-0 z-50 border-r border-white/5 shadow-2xl relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 left-0 w-full h-full aqueous-gradient opacity-10 blur-3xl"></div>
      </div>
      
      <div class="p-10 border-b border-white/5 relative z-10">
        <a href="/" class="flex flex-col group">
          <span class="font-black text-3xl tracking-tighter font-headline uppercase leading-tight italic">Terminal<span class="text-white/40">3192</span></span>
          <span class="text-[8px] font-black uppercase tracking-[0.4em] mt-2 text-white/40 italic">Hierarchy: District Controller</span>
        </a>
      </div>
      
      <nav class="flex-grow p-6 space-y-3 relative z-10">
        <a href="/admin" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">space_dashboard</span>
          Core Dashboard
        </a>
        <a href="/admin/clubs" class="flex items-center px-6 py-4 bg-white/10 text-white rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all border border-white/10 fluid-shadow italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-60">hub</span>
          Node Management
        </a>
        <a href="/admin/members" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">group</span>
          Node Directory
        </a>
        <a href="/admin/audit" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">security</span>
          Process Audit
        </a>
      </nav>

      <div class="p-8 border-t border-white/5 relative z-10">
         <div class="bg-white/5 p-6 rounded-2xl border border-white/5">
            <p class="text-[8px] font-black uppercase tracking-[0.3em] text-white/30 italic">Network Status</p>
            <p class="text-xs font-black text-white mt-1 italic tracking-widest uppercase text-green-400">All Nodes Online</p>
         </div>
      </div>
    </aside>

    <!-- Main Command Content -->
    <main class="flex-grow pl-80 flex flex-col min-h-screen">
      
      <header class="bg-surface/80 backdrop-blur-xl px-12 py-8 border-b border-outline-variant/30 flex items-center justify-between sticky top-0 z-40">
        <div class="space-y-1">
          <h1 class="text-2xl font-black text-primary font-headline tracking-tighter uppercase italic leading-none">Club Clusters</h1>
          <p class="text-[9px] font-black text-primary/30 uppercase tracking-[0.4em] italic">Infrastructure & Node Deployment</p>
        </div>
      </header>

      <div class="p-12 space-y-12">
        
        <!-- Deployment Form -->
        <div class="bg-surface-container-low rounded-[3.5rem] border border-outline-variant/30 fluid-shadow overflow-hidden group">
          <div class="p-10 border-b border-primary/5 bg-surface-container-lowest">
            <h2 class="text-xl font-black text-primary font-headline tracking-tighter uppercase italic">Initialize New Node</h2>
          </div>
          <div class="p-10">
            <form class="grid grid-cols-2 gap-8">
              <div class="space-y-2">
                 <label class="block text-[8px] font-black uppercase tracking-[0.3em] text-primary/40 ml-4 italic">Cluster Designation</label>
                 <input type="text" placeholder="Club Name" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-2xl p-4 font-bold text-primary focus:ring-4 focus:ring-primary/5 focus:outline-none transition-all" />
              </div>
              <div class="space-y-2">
                 <label class="block text-[8px] font-black uppercase tracking-[0.3em] text-primary/40 ml-4 italic">Geography</label>
                 <input type="text" placeholder="City" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-2xl p-4 font-bold text-primary focus:ring-4 focus:ring-primary/5 focus:outline-none transition-all" />
              </div>
              <div class="space-y-2">
                 <label class="block text-[8px] font-black uppercase tracking-[0.3em] text-primary/40 ml-4 italic">Charter Signal</label>
                 <input type="date" class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-2xl p-4 font-bold text-primary focus:ring-4 focus:ring-primary/5 focus:outline-none transition-all" />
              </div>
              <div class="space-y-2">
                 <label class="block text-[8px] font-black uppercase tracking-[0.3em] text-primary/40 ml-4 italic">Identity Tint</label>
                 <input type="color" class="border border-outline-variant/20 rounded-2xl h-14 w-full cursor-pointer bg-surface-container-lowest p-2" value="#003F8A" />
              </div>
              <button class="col-span-2 aqueous-gradient text-white font-black py-5 rounded-2xl uppercase tracking-[0.4em] text-[10px] shadow-2xl hover:translate-y-[-2px] transition-all">Initialize Cluster</button>
            </form>
          </div>
        </div>

        <!-- Node List -->
        <div class="bg-surface-container-low rounded-[3.5rem] border border-outline-variant/30 fluid-shadow overflow-hidden">
          <div class="p-10 border-b border-primary/5 bg-surface-container-lowest">
            <h2 class="text-xl font-black text-primary font-headline tracking-tighter uppercase italic">Recognized Cluster Nodes</h2>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-surface-container-lowest border-b border-primary/5">
                   <th class="py-6 px-10 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic">Active Cluster</th>
                   <th class="py-6 px-10 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic text-right">Synchronization</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-primary/5">
                {clubs.map(c => (
                  <tr class="hover:bg-surface-container-lowest transition-all group">
                    <td class="py-6 px-10">
                       <div class="flex items-center gap-4">
                          <img src={c.logo_url} class="w-8 h-8 rounded-lg grayscale group-hover:grayscale-0 transition-all border border-primary/10" />
                          <p class="text-base font-black text-primary font-headline uppercase leading-none tracking-tight">{c.name}</p>
                       </div>
                    </td>
                    <td class="py-6 px-10 text-right">
                       <button class="text-[9px] font-black text-primary uppercase tracking-[0.3em] hover:underline underline-offset-8 italic opacity-40 hover:opacity-100 transition-all">Modify Node</button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

      </div>

    </main>

  </div>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>
