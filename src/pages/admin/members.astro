---
import Layout from '../../layouts/Layout.astro';
import membersData from '../../mock/members.json';

const members = membersData;
---

<Layout title="Member Directory - Admin">
  
  <div class="flex min-h-screen bg-gray-50">
    
    <!-- Admin Sidebar -->
    <aside class="w-64 bg-gray-900 text-gray-400 flex flex-col fixed inset-y-0 z-50">
      <div class="p-6 border-b border-gray-800">
        <a href="/" class="flex flex-col">
          <span class="font-bold text-2xl tracking-tight text-white leading-tight">Rotaract<span class="text-[#F5A623]">3192</span></span>
          <span class="text-[10px] uppercase tracking-widest font-bold leading-none mt-1 text-gray-500">Access: District Admin</span>
        </a>
      </div>
      
      <nav class="flex-grow p-4 space-y-1">
        <a href="/admin" class="flex items-center px-4 py-3 hover:bg-gray-800 hover:text-white rounded-xl font-medium text-sm transition-colors">
          <svg class="w-5 h-5 mr-3 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
          Dashboard
        </a>
        <a href="/admin/members" class="flex items-center px-4 py-3 bg-[#003F8A] text-white rounded-xl font-medium text-sm transition-colors">
          <svg class="w-5 h-5 mr-3 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
          Members Directory
        </a>
        <a href="#" class="flex items-center px-4 py-3 hover:bg-gray-800 hover:text-white rounded-xl font-medium text-sm transition-colors">
          <svg class="w-5 h-5 mr-3 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          Events Approval
        </a>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-grow pl-64 flex flex-col min-h-screen">
      
      <header class="bg-white px-8 py-5 border-b border-gray-200 flex items-center justify-between sticky top-0 z-40">
        <div>
          <h1 class="text-xl font-bold text-gray-900">Members Directory</h1>
          <p class="text-xs font-semibold text-gray-500 mt-1 uppercase tracking-widest">{members.length} Total Users</p>
        </div>
        <div class="flex items-center gap-4">
          <div class="relative w-64 hidden md:block">
            <input type="text" placeholder="Search members..." class="w-full bg-gray-50 border border-gray-200 text-gray-900 text-sm rounded-lg focus:ring-[#003F8A] focus:border-[#003F8A] py-2 pl-9 pr-3 shadow-sm" />
            <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
          <button class="bg-white border border-gray-200 text-gray-700 hover:bg-gray-50 hover:text-[#003F8A] font-bold text-sm px-4 py-2 rounded-lg transition-colors shadow-sm flex items-center">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
            Export CSV
          </button>
        </div>
      </header>

      <div class="p-8 flex-grow">
        
        <div class="bg-white rounded-3xl border border-gray-200 card-shadow overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                  <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest">Member</th>
                  <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest">Club</th>
                  <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest">Role</th>
                  <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest">Points/Auth</th>
                  <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {members.map(member => (
                  <tr class="hover:bg-blue-50/50 transition-colors group">
                    <td class="px-6 py-4">
                      <div class="flex items-center">
                        <img src={member.profile_pic_url} class="w-10 h-10 rounded-full mr-4 border border-gray-200" />
                        <div>
                          <p class="font-bold text-gray-900 text-sm group-hover:text-[#003F8A] transition-colors">{member.name}</p>
                          <p class="text-xs text-gray-500 font-medium">{member.email}</p>
                        </div>
                      </div>
                    </td>
                    <td class="px-6 py-4 font-semibold text-gray-700 text-sm">{member.club_id}</td>
                    <td class="px-6 py-4">
                      <span class={`inline-flex items-center px-2.5 py-1 rounded text-[10px] font-black uppercase tracking-widest
                        ${member.role === 'district_core' ? 'bg-[#F5A623]/20 text-[#003F8A] border border-[#F5A623]/50' :
                          member.role.includes('pres') ? 'bg-blue-100 text-[#003F8A]' : 'bg-gray-100 text-gray-600'}`}>
                        {member.role.replace('_', ' ')}
                      </span>
                    </td>
                    <td class="px-6 py-4 space-y-1">
                      <p class="font-bold text-gray-900 text-sm">{member.points} pts</p>
                      <p class="text-[10px] font-bold text-green-500 uppercase">Verified</p>
                    </td>
                    <td class="px-6 py-4 text-right">
                      <button class="bg-white border border-gray-200 text-gray-600 hover:text-[#003F8A] hover:border-[#003F8A] font-semibold text-xs px-3 py-1.5 rounded-lg transition-colors shadow-sm">
                        Edit
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          
          <div class="bg-gray-50 border-t border-gray-200 px-6 py-4 flex items-center justify-between text-sm text-gray-500 font-medium">
            <p>Showing 1 to {members.length} of {members.length} entries</p>
            <div class="flex space-x-2">
              <button disabled class="px-3 py-1 rounded border border-gray-200 bg-white text-gray-400 opacity-50 cursor-not-allowed">Previous</button>
              <button disabled class="px-3 py-1 rounded border border-gray-200 bg-white text-gray-400 opacity-50 cursor-not-allowed">Next</button>
            </div>
          </div>

        </div>

      </div>

    </main>

  </div>

</Layout>
