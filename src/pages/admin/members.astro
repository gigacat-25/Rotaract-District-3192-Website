---
import Layout from '../../layouts/Layout.astro';
import membersData from '../../mock/members.json';

const members = membersData;
---

<Layout title="Node Directory | District Admin">
  <div class="flex min-h-screen bg-surface">
    
    <!-- Cinematic Admin Sidebar -->
    <aside class="w-80 bg-primary text-white flex flex-col fixed inset-y-0 z-50 border-r border-white/5 shadow-2xl relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 left-0 w-full h-full aqueous-gradient opacity-10 blur-3xl"></div>
      </div>
      
      <div class="p-10 border-b border-white/5 relative z-10">
        <a href="/" class="flex flex-col group">
          <span class="font-black text-3xl tracking-tighter font-headline uppercase leading-tight italic">Terminal<span class="text-white/40">3192</span></span>
          <span class="text-[8px] font-black uppercase tracking-[0.4em] mt-2 text-white/40 italic">Hierarchy: District Controller</span>
        </a>
      </div>
      
      <nav class="flex-grow p-6 space-y-3 relative z-10">
        <a href="/admin" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">space_dashboard</span>
          Core Dashboard
        </a>
        <a href="/admin/members" class="flex items-center px-6 py-4 bg-white/10 text-white rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all border border-white/10 fluid-shadow italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-60">group</span>
          Node Directory
        </a>
        <a href="#" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">event</span>
          Signal Approval
        </a>
        <a href="#" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">account_balance_wallet</span>
          Capital Inflow
        </a>
      </nav>

      <div class="p-8 border-t border-white/5 relative z-10">
         <div class="bg-white/5 p-6 rounded-2xl border border-white/5">
            <p class="text-[8px] font-black uppercase tracking-[0.3em] text-white/30 italic">System Integrity</p>
            <p class="text-xs font-black text-white mt-1 italic tracking-widest uppercase">98.2% Nominal</p>
         </div>
      </div>
    </aside>

    <!-- Main Command Content -->
    <main class="flex-grow pl-80 flex flex-col min-h-screen">
      
      <header class="bg-surface/80 backdrop-blur-xl px-12 py-8 border-b border-outline-variant/30 flex items-center justify-between sticky top-0 z-40">
        <div class="space-y-1">
          <h1 class="text-2xl font-black text-primary font-headline tracking-tighter uppercase italic leading-none">Node Directory</h1>
          <p class="text-[9px] font-black text-primary/30 uppercase tracking-[0.4em] italic">{members.length} Unique Identifiers Recognized</p>
        </div>
        <div class="flex items-center gap-6">
          <div class="relative group">
            <input type="text" placeholder="Identify Node..." class="w-72 bg-surface-container-low border border-outline-variant/30 text-primary text-[10px] font-black uppercase tracking-[0.2em] rounded-xl py-3 pl-12 pr-4 focus:ring-4 focus:ring-primary/5 focus:outline-none transition-all placeholder-primary/20" />
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-primary opacity-30 group-focus-within:opacity-100 transition-opacity text-base">search</span>
          </div>
          <button class="bg-white border border-outline-variant/30 text-primary font-black text-[9px] uppercase tracking-[0.3em] px-6 py-3 rounded-xl shadow-sm hover:bg-primary/5 transition-all flex items-center gap-3">
            <span class="material-symbols-outlined text-base">cloud_download</span>
            Extract CSV
          </button>
        </div>
      </header>

      <div class="p-12">
        
        <div class="bg-surface-container-low rounded-[3.5rem] border border-outline-variant/30 fluid-shadow overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-surface-container-lowest border-b border-primary/5">
                  <th class="py-8 px-12 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic leading-none">Identity Header</th>
                  <th class="py-8 px-12 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic leading-none">Node Origin</th>
                  <th class="py-8 px-12 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic leading-none text-center">Protocol Role</th>
                  <th class="py-8 px-12 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic leading-none">Authentication</th>
                  <th class="py-8 px-12 text-[9px] font-black text-primary/40 uppercase tracking-[0.4em] italic leading-none text-right">Synchronization</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-primary/5">
                {members.map(member => (
                  <tr class="hover:bg-surface-container-lowest transition-all group">
                    <td class="py-8 px-12">
                      <div class="flex items-center gap-6">
                        <div class="relative">
                           <img src={member.profile_pic_url} class="w-14 h-14 rounded-2xl grayscale group-hover:grayscale-0 transition-all border-2 border-primary/5 shadow-xl" />
                           <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-green-500 rounded-full border-2 border-white"></div>
                        </div>
                        <div class="space-y-1">
                          <p class="text-lg font-black text-primary font-headline uppercase leading-none tracking-tight">{member.name}</p>
                          <p class="text-[10px] text-on-surface-variant font-black uppercase tracking-widest opacity-40 italic">{member.email}</p>
                        </div>
                      </div>
                    </td>
                    <td class="py-8 px-12">
                       <span class="text-[10px] font-black text-on-surface-variant/60 uppercase tracking-widest italic">{member.club_id}</span>
                    </td>
                    <td class="py-8 px-12 text-center">
                      <span class={`inline-flex items-center px-4 py-1.5 rounded-full text-[8px] font-black uppercase tracking-[0.2em] border
                        ${member.role === 'district_core' ? 'bg-primary/5 text-primary border-primary/20 shadow-lg shadow-primary/5' :
                          member.role.includes('pres') ? 'bg-secondary/5 text-secondary border-secondary/20' : 'bg-surface/50 text-on-surface-variant/40 border-outline-variant/10'}`}>
                        {member.role.replace('_', ' ')}
                      </span>
                    </td>
                    <td class="py-8 px-12 space-y-1.5">
                      <p class="text-base font-black text-primary font-headline tracking-tighter italic uppercase">{member.points}<span class="text-[9px] ml-1 opacity-30">PTX</span></p>
                      <div class="flex items-center gap-1.5">
                         <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
                         <span class="text-[8px] font-black text-green-600 uppercase tracking-widest italic">Auth-High</span>
                      </div>
                    </td>
                    <td class="py-8 px-12 text-right">
                      <button class="bg-white border border-outline-variant/30 text-primary font-black text-[9px] uppercase tracking-[0.3em] px-5 py-2.5 rounded-xl shadow-sm hover:translate-y-[-2px] hover:bg-primary hover:text-white transition-all">
                        Sync Node
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          
          <div class="bg-surface-container-lowest border-t border-primary/5 px-12 py-8 flex items-center justify-between">
            <p class="text-[9px] font-black text-primary/30 uppercase tracking-[0.4em] italic">Displaying active identifiers 1 - {members.length} / Total Clusters</p>
            <div class="flex items-center gap-3">
              <button disabled class="w-10 h-10 rounded-xl border border-outline-variant/30 bg-white text-primary/20 cursor-not-allowed flex items-center justify-center">
                <span class="material-symbols-outlined">navigate_before</span>
              </button>
              <button disabled class="w-10 h-10 rounded-xl border border-outline-variant/30 bg-white text-primary/20 cursor-not-allowed flex items-center justify-center">
                <span class="material-symbols-outlined">navigate_next</span>
              </button>
            </div>
          </div>

        </div>

      </div>

    </main>

  </div>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>
