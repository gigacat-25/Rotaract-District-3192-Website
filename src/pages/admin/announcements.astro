---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Signal Broadcast | District Admin">
  <div class="flex min-h-screen bg-surface">
    
    <!-- Cinematic Admin Sidebar -->
    <aside class="w-80 bg-primary text-white flex flex-col fixed inset-y-0 z-50 border-r border-white/5 shadow-2xl relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 left-0 w-full h-full aqueous-gradient opacity-10 blur-3xl"></div>
      </div>
      
      <div class="p-10 border-b border-white/5 relative z-10">
        <a href="/" class="flex flex-col group">
          <span class="font-black text-3xl tracking-tighter font-headline uppercase leading-tight italic">Terminal<span class="text-white/40">3192</span></span>
          <span class="text-[8px] font-black uppercase tracking-[0.4em] mt-2 text-white/40 italic">Hierarchy: District Controller</span>
        </a>
      </div>
      
      <nav class="flex-grow p-6 space-y-3 relative z-10">
        <a href="/admin" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">space_dashboard</span>
          Core Dashboard
        </a>
        <a href="/admin/announcements" class="flex items-center px-6 py-4 bg-white/10 text-white rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all border border-white/10 fluid-shadow italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-60">campaign</span>
          Broadcast Hub
        </a>
        <a href="/admin/members" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">group</span>
          Node Directory
        </a>
        <a href="/admin/audit" class="flex items-center px-6 py-4 text-white/50 hover:text-white hover:bg-white/5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all italic">
          <span class="material-symbols-outlined mr-4 text-xl opacity-40">security</span>
          Process Audit
        </a>
      </nav>
    </aside>

    <main class="flex-grow pl-80 flex flex-col min-h-screen">
      <header class="bg-surface/80 backdrop-blur-xl px-12 py-8 border-b border-outline-variant/30 flex items-center justify-between sticky top-0 z-40">
        <div class="space-y-1">
          <h1 class="text-2xl font-black text-primary font-headline tracking-tighter uppercase italic leading-none">Signal Hub</h1>
          <p class="text-[9px] font-black text-primary/30 uppercase tracking-[0.4em] italic">Omni-Channel Broadcast Terminal</p>
        </div>
      </header>

      <div class="p-12 space-y-12">
        <div class="bg-surface-container-low rounded-[3.5rem] border border-outline-variant/30 fluid-shadow overflow-hidden">
          <div class="p-10 border-b border-primary/5 bg-surface-container-lowest flex justify-between items-center">
            <h2 class="text-xl font-black text-primary font-headline tracking-tighter uppercase italic">Initialize Broadcast</h2>
            <div class="flex items-center gap-2">
               <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
               <span class="text-[8px] font-black uppercase tracking-[0.2em] text-green-600 italic">Network Ready</span>
            </div>
          </div>
          <div class="p-10">
            <form class="space-y-8">
              <div class="grid grid-cols-2 gap-8">
                <div class="space-y-2">
                   <label class="block text-[8px] font-black uppercase tracking-[0.3em] text-primary/40 ml-4 italic">Payload Template</label>
                   <select class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-2xl p-4 font-bold text-primary appearance-none focus:ring-4 focus:ring-primary/5 focus:outline-none transition-all">
                      <option>Select Message Template...</option>
                      <option>General Assembly Notice</option>
                      <option>Dues Reminder</option>
                   </select>
                </div>
                <div class="space-y-2">
                   <label class="block text-[8px] font-black uppercase tracking-[0.3em] text-primary/40 ml-4 italic">Target Clusters</label>
                   <select class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-2xl p-4 font-bold text-primary appearance-none focus:ring-4 focus:ring-primary/5 focus:outline-none transition-all">
                      <option>All Presidents and Secretaries</option>
                      <option>All Members</option>
                      <option>District Council</option>
                   </select>
                </div>
              </div>
              <div class="space-y-2">
                 <label class="block text-[8px] font-black uppercase tracking-[0.3em] text-primary/40 ml-4 italic">Dynamic Override (Optional)</label>
                 <textarea rows="4" placeholder="Inject custom payload parameters here..." class="w-full bg-surface-container-lowest border border-outline-variant/20 rounded-2xl p-6 font-bold text-primary focus:ring-4 focus:ring-primary/5 focus:outline-none transition-all placeholder-primary/10"></textarea>
              </div>
              <button type="button" class="w-full bg-primary text-white font-black py-6 rounded-2xl uppercase tracking-[0.4em] text-[10px] shadow-2xl hover:translate-y-[-2px] transition-all flex items-center justify-center gap-4">
                 <span class="material-symbols-outlined text-lg">send</span>
                 Transmit Signal
              </button>
            </form>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  .fluid-shadow {
    box-shadow: 0 32px 64px -12px rgba(13, 65, 116, 0.08);
  }
</style>
