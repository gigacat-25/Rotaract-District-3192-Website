---
const currentYear = new Date().getFullYear();
---

<footer class="bg-surface-container-low text-on-surface pt-24 pb-12 px-6 lg:px-12">
  <div class="max-w-screen-2xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-20">
      
      <!-- Brand & Mission -->
      <div class="space-y-8">
        <a href="/" class="flex flex-col group inline-block">
          <span class="text-2xl font-black tracking-tighter text-primary group-hover:text-primary-container transition-colors font-headline">
            Rotaract 3192
          </span>
          <span class="text-[10px] uppercase tracking-[0.2em] text-on-surface-variant font-bold leading-none mt-1 opacity-70">
            The Fluid Authority
          </span>
        </a>
        <p class="text-sm leading-relaxed text-on-surface-variant font-medium opacity-80 max-w-xs">
          Harnessing the power of youth leadership and service to create ripples of positive change across our global community.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center text-primary hover:bg-primary hover:text-on-primary transition-all duration-300">
            <span class="material-symbols-outlined text-lg">public</span>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center text-primary hover:bg-primary hover:text-on-primary transition-all duration-300">
            <span class="material-symbols-outlined text-lg">share</span>
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center text-primary hover:bg-primary hover:text-on-primary transition-all duration-300">
            <span class="material-symbols-outlined text-lg">mail</span>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-primary font-black text-xs uppercase tracking-widest mb-8 font-headline">Explore District</h3>
        <ul class="space-y-4">
          <li><a href="/about" class="text-sm text-on-surface-variant hover:text-primary font-bold transition-colors">Our Mission</a></li>
          <li><a href="/clubs" class="text-sm text-on-surface-variant hover:text-primary font-bold transition-colors">Club Directory</a></li>
          <li><a href="/events" class="text-sm text-on-surface-variant hover:text-primary font-bold transition-colors">Waves of Action</a></li>
          <li><a href="/news" class="text-sm text-on-surface-variant hover:text-primary font-bold transition-colors">Impact Stories</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-primary font-black text-xs uppercase tracking-widest mb-8 font-headline">Resources</h3>
        <ul class="space-y-4">
          <li><a href="/resources" class="text-sm text-on-surface-variant hover:text-primary font-bold transition-colors">Shared Files</a></li>
          <li><a href="/newsletter" class="text-sm text-on-surface-variant hover:text-primary font-bold transition-colors">Newsletters</a></li>
          <li><a href="/brand-centre" class="text-sm text-on-surface-variant hover:text-primary font-bold transition-colors">Brand Centre</a></li>
          <li><a href="/jobs" class="text-sm text-on-surface-variant hover:text-primary font-bold transition-colors">Opportunities</a></li>
        </ul>
      </div>

      <!-- Contact / Address -->
      <div>
        <h3 class="text-primary font-black text-xs uppercase tracking-widest mb-8 font-headline">Get in Touch</h3>
        <address class="not-italic text-sm space-y-6 text-on-surface-variant font-medium">
          <p class="opacity-80">
            <strong class="text-primary block mb-1 font-bold">Rotaract District 3192</strong>
            Bengaluru / Karnataka / South India
          </p>
          <p>
            <a href="mailto:info@rotaract3192.org" class="hover:text-primary transition-colors border-b border-outline-variant pb-1">info@rotaract3192.org</a>
          </p>
        </address>
      </div>

    </div>

    <!-- Divider & Copyright -->
    <div class="border-t border-outline-variant pt-12 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex flex-wrap justify-center gap-8 text-[10px] font-black uppercase tracking-widest text-on-surface-variant opacity-60">
        <a href="#" class="hover:text-primary transition-colors">Charter</a>
        <a href="#" class="hover:text-primary transition-colors">Bylaws</a>
        <a href="#" class="hover:text-primary transition-colors">Privacy</a>
        <a href="#" class="hover:text-primary transition-colors">Sitemap</a>
      </div>
      <p class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant opacity-40">
        &copy; {currentYear} Rotaract District 3192. All rights reserved.
      </p>
    </div>
  </div>
</footer>

